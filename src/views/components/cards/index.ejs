<% 
if (typeof(tipo) != 'undefined' && tipo == 'secundario') {
  var cor = 'text-gray-500';
} else {
  cor = 'text-gray-700';
}

if ( tipo == 'hero') {
  shadow = 'shadow-xl';
  cor = 'text-green-700';
} else if ( tipo == 'pendentes') {
  shadow = 'shadow-none';
  cor = 'text-yellow-700';
} 
else if (tipo == 'auditados') {
  shadow = 'shadow-xl';
  cor = 'text-green-700';
} 
else if (tipo == 'negativo') {
  shadow = 'shadow-xl';
  cor = 'text-red-700';
} else {
  shadow = 'shadow-none';
}
%>
  
  <div class="w-full bg-white rounded-xl p-8 border border-gray-200 <%= shadow %>">
    <p class="text-gray-500"><%= titulo %></p>
    <div class="flex flex-col gap-2">
      <h2 id="valor" class="text-4xl font-bold <%= cor %>">
        <%= valor %>
      </h2>
    </div>
  </div>