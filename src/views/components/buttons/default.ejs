<%
const isLink = typeof link !== 'undefined' && link;
const buttonId = typeof id !== 'undefined' ? id : '';
const labelText = typeof label !== 'undefined' ? label : 'Botao';
const iconType = typeof icon !== 'undefined' ? String(icon) : '';
const showPlus = iconType === 'plus' || iconType === 'add';
const customClass = typeof className !== 'undefined' ? className : '';
const isDisabled = typeof disabled !== 'undefined' && disabled === true;
const disabledClass = isDisabled ? 'opacity-50 cursor-not-allowed pointer-events-none' : '';
const baseClass = `w-full inline-flex items-center justify-center gap-3 rounded-full border border-gray-200 bg-white px-5 py-2 text-lg font-medium text-slate-600 shadow-md transition hover:shadow-lg hover:bg-gray-50 ${disabledClass} ${customClass}`;
%>

<% if (isLink) { %>
  <a href="<%= link %>" class="<%= baseClass %>">
    <% if (showPlus) { %>
      <span class="inline-flex h-6 w-6 items-center justify-center rounded-full border-2 border-emerald-500 text-emerald-500">
        <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M9 4a1 1 0 112 0v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4z"></path>
        </svg>
      </span>
    <% } %>
    <span><%= labelText %></span>
  </a>
<% } else { %>
  <button id="<%= buttonId %>" type="button" class="<%= baseClass %>" <%= isDisabled ? 'disabled' : '' %>>
    <% if (showPlus) { %>
      <span class="inline-flex h-6 w-6 items-center justify-center rounded-full border-2 border-emerald-500 text-emerald-500">
        <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M9 4a1 1 0 112 0v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4z"></path>
        </svg>
      </span>
    <% } %>
    <span><%= labelText %></span>
  </button>
<% } %>
