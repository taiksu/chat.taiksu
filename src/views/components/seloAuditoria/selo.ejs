<% if (status == 'revisado') { %>
    <div id="selo" class="<% if (layout != 'mini') { %> rounded-md <% } else { %> rounded-full <% } %> flex flex-row items-center gap-2 bg-green-400 text-sm cursor-pointer text-white p-1">
        <img class="h-5 w-5" src="/images/icons/verificado1.png"/>
        <% if (layout != 'mini') { %>
            Ver auditoria
        <% } %>
    </div>
<% } else { %>
    <div class="<% if (layout != 'mini') { %> rounded-md <% } else { %> rounded-full <% } %> flex flex-row items-center gap-2 bg-orange-100 text-sm text-gray-600 p-1">
        <img class="h-5 w-5" src="/images/icons/clock.png"/>
        <% if (layout != 'mini') { %>
            Pendente
        <% } %>
    </div>
<% } %>