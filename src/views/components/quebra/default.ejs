<% if(typeof layout === 'undefined') { 
    layout = 'default';
}
%>

<a href="/fechamento/<%= quebra.fechamento_id %>" class="w-full flex flex-row justify-between items-center bg-white rounded-xl px-8 py-4 border border-gray-200 group">
        <div class="flex flex-row items-center gap-3">
            <div class="p-0.5 rounded-full <%= quebra.tipo === 'positivo' ? 'bg-green-100' : 'bg-red-100' %> group-hover:shadow-xl group-hover:scale-110 transition-all duration-500">
                <img class="h-6" alt="icone" src="/images/icons/<%= quebra.tipo === 'positivo' ? 'positiva.png' : 'quebra.png' %> ">
            </div>
            <div class="flex flex-col gap-0 text-left">
                <p class="text-green-800 font-bold text-md"><%= Number(quebra.valor).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %></p>
                <p class="text-gray-500 text-xs"><%= quebra.createdAt.toLocaleString('pt-BR', { day: '2-digit', month: 'short'}) %></p>
            </div>
        </div>
        <div class="flex flex-row items-center gap-3">
            <div class="flex flex-row items-center gap-2">
                <img data-user-id="<%= quebra.user_id %>" src="" class="h-6 rounded-full <%= layout === 'operador' ? 'hidden' : '' %>">
                <p data-user-id="<%= quebra.user_id %>" class="username text-gray-500 text-sm hidden">  </p>
            </div>
            <img alt="seta" src="/images/seta.png" class="group-hover:h-5 h-0 opacity-0 group-hover:opacity-100 transition-all duration-300">
        </div>
</a>