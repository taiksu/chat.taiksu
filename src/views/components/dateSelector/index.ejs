<div class="flex flex-row items-center gap-2">
    <button id="prev-month-btn" class="hover:shadow-lg h-7 w-7 flex items-center justify-center bg-white rounded-full border border-gray-200 hover:bg-gray-50 transition cursor-pointer focus:outline-none">
        <img class="h-5 rotate-180" src="https://login.taiksu.com.br/frontend/img/seta.png" alt="Mês anterior">
    </button>
    
    <div id="date-display" data-mes="<%= mes %>" data-ano="<%= ano %>" class="px-4 py-1 border border-gray-200 rounded-full text-sm bg-white font-medium text-green-700 capitalize whitespace-nowrap min-w-[120px] text-center">
        <%= new Date(ano, mes).toLocaleDateString('pt-BR', { month: 'short' }) %> <%= ano %>
    </div>

     <button id="next-month-btn" class="hover:shadow-lg h-7 w-7 flex items-center justify-center bg-white rounded-full border border-gray-200 hover:bg-gray-50 transition cursor-pointer focus:outline-none">
         <img class="h-5" src="https://login.taiksu.com.br/frontend/img/seta.png" alt="Próximo mês">
    </button>
</div>