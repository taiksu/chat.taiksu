<%
    let icon = '';
    switch (deposito.status) {
        case 'pendente':
            icon = 'wait.png';
            bgcolor = 'bg-orange-200';
            break;
    
        case 'auditado':
            icon = 'ok.png';
            bgcolor = 'bg-green-200';
            break;
    
        case 'contestado':
            icon = 'failed.png';
            bgcolor = 'bg-red-200';
            break;
    }
%>

<a href="/depositos/<%= deposito.id %>" class="w-full flex flex-row justify-between items-center bg-white rounded-xl px-8 py-4 border border-gray-200 group">
        <div class="flex flex-row items-center gap-3">
            <div class="p-0.5 rounded-full <%= bgcolor %> group-hover:shadow-xl group-hover:scale-110 transition-all duration-500">
                <img class="h-6" alt="icone" src="/images/icons/<%= icon %>">
            </div>
            <div class="flex flex-col gap-0 text-left">
                <p class="text-green-800 font-bold text-md"><%= Number(deposito.valor_depositado).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %></p>
                <p class="text-gray-500 text-xs"><%= deposito.createdAt.toLocaleString('pt-BR', { day: '2-digit', month: 'short'}) %></p>
            </div>
        </div>
        <div class="flex flex-row items-center gap-3">
            <div class="flex flex-row items-center gap-2 px-3 py-1 bg-gray-100 rounded-full">
                <img src="https://login.taiksu.com.br/applications/68f47df22d26e.png" class="h-4">
                <p class="text-gray-600 text-sm"><%= deposito.banco.nome %></p>
            </div>
            <img alt="seta" src="https://login.taiksu.com.br/frontend/img/seta.png" class="group-hover:h-5 h-0 opacity-0 group-hover:opacity-100 transition-all duration-300">
        </div>
</a>