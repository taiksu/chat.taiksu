<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Erro</title>
  <link rel="stylesheet" href="/css/tailwind.css">
</head>
<body class="flex min-h-dvh items-center justify-center bg-[radial-gradient(circle_at_top,#6366f1_0%,#4f46e5_40%,#0f172a_100%)] p-4">
  <main class="w-full max-w-md rounded-2xl border border-white/20 bg-white p-8 text-center shadow-2xl">
    <div class="text-5xl">X</div>
    <h1 class="mt-3 text-2xl font-bold text-indigo-700">Erro</h1>
    <p class="mt-3 text-sm leading-relaxed text-slate-600"><%= message %></p>
    <a href="/" class="mt-6 inline-block rounded-xl bg-indigo-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-indigo-700">Voltar para Home</a>
  </main>
</body>
</html>