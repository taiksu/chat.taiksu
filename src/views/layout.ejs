<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,300..900;1,300..900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/tailwind.css">
  <link rel="stylesheet" href="/css/theme.css">
</head>
<body class="min-h-dvh bg-green-50 text-green-700">
  <nav class="bg-gradient-to-r from-green-400 to-green-500 px-3 py-3 text-white shadow-sm sm:px-5">
    <div class="mx-auto flex w-full max-w-7xl flex-wrap items-center justify-between gap-2">
      <h1 class="text-base font-bold sm:text-lg">Chat Taiksu</h1>
      <div class="flex flex-wrap items-center justify-end gap-2 text-sm">
        <% if (user) { %>
          <span class="hidden text-green-50 sm:inline"><%= user.name %></span>
          <div class="flex h-9 w-9 items-center justify-center overflow-hidden rounded-full bg-white text-xs font-bold text-green-700">
            <% if (user.avatar) { %>
              <img src="<%= user.avatar %>" alt="Avatar de <%= user.name %>" class="h-full w-full object-cover">
            <% } else { %>
              <span><%= user.name.charAt(0).toUpperCase() %></span>
            <% } %>
          </div>
          <a href="/dashboard" class="rounded-lg bg-white/20 px-3 py-2 text-xs font-semibold transition hover:bg-white/30 sm:text-sm">Dashboard</a>
          <a href="/chat/rooms" class="rounded-lg bg-white/20 px-3 py-2 text-xs font-semibold transition hover:bg-white/30 sm:text-sm">Chat</a>
          <a href="/dashboard/qa-chat" class="rounded-lg bg-white/20 px-3 py-2 text-xs font-semibold transition hover:bg-white/30 sm:text-sm">QA do Chat</a>
          <a href="/auth/logout" class="rounded-lg bg-white/20 px-3 py-2 text-xs font-semibold transition hover:bg-white/30 sm:text-sm">Sair</a>
        <% } else { %>
          <a href="/auth/login" class="rounded-lg bg-white/20 px-3 py-2 text-xs font-semibold transition hover:bg-white/30 sm:text-sm">Entrar</a>
        <% } %>
      </div>
    </div>
  </nav>

  <main class="mx-auto w-full max-w-7xl px-3 py-4 sm:px-5 sm:py-6">
    <%- body %>
  </main>
</body>
</html>
