<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/tailwind.css">
  <link rel="stylesheet" href="/css/theme.css">
</head>
<body class="flex min-h-dvh items-center justify-center bg-green-50 p-4 text-green-700">
  <main class="w-full max-w-md rounded-2xl border border-green-100 bg-white p-6 shadow-xl">
    <h1 class="mb-5 text-center text-2xl font-bold text-green-700">Login</h1>

    <% if (message) { %>
      <div class="mb-4 rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700"><%= message %></div>
    <% } %>

    <form method="POST" action="/auth/login" class="space-y-4">
      <div>
        <label for="email" class="mb-1 block text-sm font-semibold text-gray-500">Email</label>
        <input type="email" id="email" name="email" required placeholder="seu@email.com" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-700 outline-none transition focus:border-green-400 focus:shadow-[0_0_0_3px_rgba(74,222,128,0.2)]">
      </div>

      <div>
        <label for="password" class="mb-1 block text-sm font-semibold text-gray-500">Senha</label>
        <input type="password" id="password" name="password" required placeholder="Sua senha" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-700 outline-none transition focus:border-green-400 focus:shadow-[0_0_0_3px_rgba(74,222,128,0.2)]">
      </div>

      <button type="submit" class="w-full rounded-xl bg-green-400 px-4 py-2 text-sm font-semibold text-white transition hover:bg-green-500">Entrar</button>
    </form>

    <p class="mt-5 text-center text-sm text-gray-500">Nao tem conta? <a href="/auth/register" class="font-semibold text-green-700 hover:underline">Registre-se aqui</a></p>
  </main>
</body>
</html>
