<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/tailwind.css">
  <link rel="stylesheet" href="/css/theme.css">
</head>
<body class="min-h-dvh bg-green-50 text-green-700">
  <div id="sidebarOverlay" class="fixed inset-0 z-20 bg-black/30 opacity-0 pointer-events-none transition lg:hidden"></div>
  <%- include('../partials/sidebar', { user, active: 'template' }) %>

  <div class="lg:pl-72">
    <%- include('../partials/topbar', { user, pageTitle: 'Template Lab' }) %>

    <main class="mx-auto w-full max-w-7xl space-y-5 px-4 py-6 sm:px-6 lg:px-10 lg:py-8">
      <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <h1 class="text-xl font-bold text-green-800">Laboratorio de template unico</h1>
        <p class="mt-1 text-sm text-gray-500">Use esta tela para validar o widget e abrir a mesma sala no chat real com usuarios diferentes.</p>

        <div class="mt-4 grid gap-3 md:grid-cols-3">
          <label class="text-sm md:col-span-2">
            <span class="mb-1 block font-semibold text-gray-500">Sala ou chamado</span>
            <select id="roomSelect" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
              <% rooms.forEach((room) => { %>
                <option value="<%= room.id %>" <%= selectedRoomId === room.id ? 'selected' : '' %>>
                  [<%= room.roomType === 'chamado' ? 'Chamado' : 'Sala' %>] <%= room.name %> (<%= room.id %><%= room.chamadoId ? ` / #${room.chamadoId}` : '' %>)
                </option>
              <% }); %>
            </select>
          </label>
          <label class="text-sm">
            <span class="mb-1 block font-semibold text-gray-500">Usuario do widget</span>
            <select id="widgetUser" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
              <option value="user_alice">Alice</option>
              <option value="user_bob">Bob</option>
              <option value="user_carol">Carol</option>
              <option value="user_dave">Dave</option>
            </select>
          </label>
        </div>

        <div class="mt-4 flex flex-wrap gap-2">
          <button id="initWidgetBtn" type="button" class="rounded-xl bg-green-500 px-4 py-2 text-sm font-semibold text-white transition hover:bg-green-600">Iniciar widget inline</button>
          <button id="openRoomBtn" type="button" class="rounded-xl border border-green-300 bg-white px-4 py-2 text-sm font-semibold text-green-700 transition hover:bg-green-50">Abrir sala real</button>
          <a href="/dashboard/qa-chat" class="rounded-xl border border-green-300 bg-white px-4 py-2 text-sm font-semibold text-green-700 transition hover:bg-green-50">Ir para QA do Chat</a>
        </div>
      </section>

      <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <h2 class="text-lg font-bold text-green-800">Preview do widget (template compartilhado em evolução)</h2>
        <p class="mt-1 text-sm text-gray-500">A ideia desta view e validar comportamento visual antes de integrar total com a sala admin.</p>
        <div id="widgetMount" class="mt-4 min-h-[720px] rounded-2xl border border-green-100 bg-green-50/40 p-3"></div>
      </section>
    </main>
  </div>

  <%- include('../partials/sidebar-script') %>

  <script src="/js/taiksu-widget.js"></script>
  <script>
    const defaultServerUrl = <%- JSON.stringify(appUrl || '') %> || `${window.location.protocol}//${window.location.host}`;
    const roomSelect = document.getElementById('roomSelect');
    const widgetUser = document.getElementById('widgetUser');
    const mount = '#widgetMount';

    function roomId() {
      return roomSelect.value;
    }

    function userId() {
      return widgetUser.value;
    }

    function initWidget() {
      if (!roomId()) {
        alert('Selecione uma sala/chamado.');
        return;
      }
      window.TaiksuChat.destroy?.();
      window.TaiksuChat.init({
        serverUrl: defaultServerUrl,
        roomId: roomId(),
        userId: userId(),
        userName: userId(),
        mode: 'inline',
        mountSelector: mount,
        autoOpen: true,
        title: `Template Lab - ${roomId()}`
      });
      window.TaiksuChat.open();
    }

    function openRealRoom() {
      if (!roomId()) return;
      window.open(`/chat/room/${encodeURIComponent(roomId())}`, '_blank');
    }

    document.getElementById('initWidgetBtn').addEventListener('click', initWidget);
    document.getElementById('openRoomBtn').addEventListener('click', openRealRoom);
    roomSelect.addEventListener('change', () => {
      const next = `/dashboard/template-lab?roomId=${encodeURIComponent(roomId())}`;
      window.history.replaceState({}, '', next);
    });

    initWidget();
  </script>
</body>
</html>
