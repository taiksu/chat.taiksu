<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="min-h-dvh text-green-700">
  <div id="sidebarOverlay" class="fixed inset-0 z-20 bg-black/30 opacity-0 pointer-events-none transition"></div>
  <%- include('../partials/sidebar', { user, active: 'template' }) %>

  <div>
    <%- include('../partials/topbar', {
      user,
      pageTitle: 'Template Lab'
    }) %>

    <main class="mx-auto w-full max-w-7xl space-y-5 px-4 py-6 sm:px-6 lg:px-10 lg:py-8">
      <%- include('../components/breadcrumb/index', {
        link: '/dashboard',
        paginaAnterior: 'Dashboard',
        paginaAtual: 'Template Lab'
      }) %>
      <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <h1 class="text-xl font-bold text-green-800">Laboratorio de template unico</h1>
        <p class="mt-1 text-sm text-gray-500">Use esta tela para validar o widget e abrir a mesma sala no chat real com usuarios diferentes.</p>

        <div class="mt-4 grid gap-3 md:grid-cols-3">
          <label class="text-sm md:col-span-2">
            <span class="mb-1 block font-semibold text-gray-500">Sala ou chamado</span>
            <select id="roomSelect" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
              <% rooms.forEach((room) => { %>
                <option value="<%= room.id %>" <%= selectedRoomId === room.id ? 'selected' : '' %>>
                  [<%= room.roomType === 'chamado' ? 'Chamado' : 'Sala' %>] <%= room.name %> (<%= room.id %><%= room.chamadoId ? ` / #${room.chamadoId}` : '' %>)
                </option>
              <% }); %>
            </select>
          </label>
          <label class="text-sm">
            <span class="mb-1 block font-semibold text-gray-500">Usuario do widget</span>
            <select id="widgetUser" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400"></select>
          </label>
          <label class="text-sm">
            <span class="mb-1 block font-semibold text-gray-500">chat_state (teste)</span>
            <select id="chatStatePicker" class="w-full rounded-xl border border-emerald-200 px-3 py-2 text-sm text-emerald-800 outline-none focus:border-emerald-400">
              <option value="NEW">NEW</option>
              <option value="IA">IA</option>
              <option value="AGUARDANDO_HUMANO">AGUARDANDO_HUMANO</option>
              <option value="FILA">FILA</option>
              <option value="HUMANO">HUMANO</option>
              <option value="FECHADO">FECHADO</option>
            </select>
          </label>
        </div>

        <div class="mt-4 flex flex-wrap gap-2">
          <button id="initWidgetBtn" type="button" class="rounded-xl0 px-4 py-2 text-sm font-semibold text-white transition hover:bg-green-600">Iniciar widget inline</button>
          <button id="applyChatStateBtn" type="button" class="rounded-xl border border-emerald-300 bg-emerald-50 px-4 py-2 text-sm font-semibold text-emerald-800 transition hover:bg-emerald-100">Aplicar chat_state</button>
          <button id="openRoomBtn" type="button" class="rounded-xl border border-green-300 bg-white px-4 py-2 text-sm font-semibold text-green-700 transition hover:bg-green-50">Abrir sala real</button>
          <a href="/dashboard/qa-chat" class="rounded-xl border border-green-300 bg-white px-4 py-2 text-sm font-semibold text-green-700 transition hover:bg-green-50">Ir para QA do Chat</a>
        </div>
        <p class="mt-2 text-xs font-semibold text-gray-600">
          <span id="roomStateInfo">chat_state: - | status: -</span>
          <span id="chatStateResult" class="ml-2"></span>
        </p>
      </section>

      <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <h2 class="text-lg font-bold text-green-800">Preview do widget (template compartilhado em evolução)</h2>
        <p class="mt-1 text-sm text-gray-500">A ideia desta view e validar comportamento visual antes de integrar total com a sala admin.</p>
        <div id="widgetMount" class="mt-4 min-h-[720px] rounded-2xl border border-green-100/40 p-3"></div>
      </section>
    </main>
  </div>

  <%- include('../partials/sidebar-script') %>

  <script src="/js/taiksu-widget.js"></script>
  <script>
    const defaultServerUrl = <%- JSON.stringify(appUrl || '') %> || `${window.location.protocol}//${window.location.host}`;
    const roomsData = <%- JSON.stringify(rooms || []) %>;
    const sessionUser = <%- JSON.stringify(user || null) %>;
    const roomSelect = document.getElementById('roomSelect');
    const widgetUser = document.getElementById('widgetUser');
    const chatStatePicker = document.getElementById('chatStatePicker');
    const roomStateInfo = document.getElementById('roomStateInfo');
    const chatStateResult = document.getElementById('chatStateResult');
    const mount = '#widgetMount';

    function roomId() {
      return roomSelect.value;
    }

    function selectedUser() {
      const selected = widgetUser.options[widgetUser.selectedIndex];
      if (!selected) return null;
      return {
        id: String(selected.value || ''),
        name: String(selected.dataset.name || selected.textContent || '')
      };
    }

    function normalizeParticipant(participant) {
      if (!participant || !participant.id) return null;
      return {
        id: String(participant.id),
        name: String(participant.name || `Usuario ${participant.id}`)
      };
    }

    function buildUserOptions() {
      const room = roomsData.find((item) => String(item.id) === String(roomId()));
      const participants = Array.isArray(room?.participants) ? room.participants : [];
      const options = [];
      const seen = new Set();

      if (sessionUser && sessionUser.id) {
        const me = normalizeParticipant(sessionUser);
        if (me) {
          seen.add(me.id);
          options.push(me);
        }
      }

      participants.forEach((participant) => {
        const normalized = normalizeParticipant(participant);
        if (!normalized || seen.has(normalized.id)) return;
        seen.add(normalized.id);
        options.push(normalized);
      });

      widgetUser.innerHTML = options.map((item) => (
        `<option value="${item.id}" data-name="${item.name.replace(/"/g, '&quot;')}">${item.name} (${item.id})</option>`
      )).join('');

      if (sessionUser && sessionUser.id && seen.has(String(sessionUser.id))) {
        widgetUser.value = String(sessionUser.id);
      }
    }

    function selectedRoom() {
      return roomsData.find((item) => String(item.id) === String(roomId())) || null;
    }

    function renderRoomStateInfo() {
      const room = selectedRoom();
      if (!room) {
        roomStateInfo.textContent = 'chat_state: - | status: -';
        return;
      }
      roomStateInfo.textContent = `chat_state: ${String(room.chatState || 'NEW').toUpperCase()} | status: ${String(room.status || 'aberto').toLowerCase()}`;
      chatStatePicker.value = String(room.chatState || 'NEW').toUpperCase();
    }

    function setChatStateResult(text, type = 'info') {
      const colors = {
        info: 'text-gray-600',
        success: 'text-emerald-700',
        error: 'text-red-700'
      };
      chatStateResult.className = `ml-2 ${colors[type] || colors.info}`;
      chatStateResult.textContent = text;
    }

    function userId() {
      return selectedUser()?.id || '';
    }

    function userName() {
      return selectedUser()?.name || '';
    }

    function initWidget() {
      if (!roomId()) {
        alert('Selecione uma sala/chamado.');
        return;
      }
      if (!userId()) {
        alert('Selecione um usuario valido para o widget.');
        return;
      }
      window.TaiksuChat.destroy?.();
      window.TaiksuChat.init({
        serverUrl: defaultServerUrl,
        roomId: roomId(),
        userId: userId(),
        userName: userName(),
        mode: 'inline',
        mountSelector: mount,
        autoOpen: true,
        title: `Template Lab - ${roomId()}`
      });
      window.TaiksuChat.open();
    }

    function openRealRoom() {
      if (!roomId()) return;
      window.open(`/chat/room/${encodeURIComponent(roomId())}`, '_blank');
    }

    async function applyChatState() {
      if (!roomId()) return;
      const nextState = String(chatStatePicker.value || '').trim().toUpperCase();
      if (!nextState) return;
      setChatStateResult('Aplicando...', 'info');

      const response = await fetch(`/api/chat/rooms/${encodeURIComponent(roomId())}/chat-state`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ chatState: nextState })
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok || !data.success) {
        throw new Error(data.error || `Falha HTTP ${response.status}`);
      }

      const room = selectedRoom();
      if (room) room.chatState = String(data.chatState || nextState).toUpperCase();
      renderRoomStateInfo();
      setChatStateResult(`chat_state atualizado para ${String(data.chatState || nextState).toUpperCase()}`, 'success');
    }

    document.getElementById('initWidgetBtn').addEventListener('click', initWidget);
    document.getElementById('applyChatStateBtn').addEventListener('click', () => applyChatState().catch((err) => setChatStateResult(err.message, 'error')));
    document.getElementById('openRoomBtn').addEventListener('click', openRealRoom);
    roomSelect.addEventListener('change', () => {
      buildUserOptions();
      renderRoomStateInfo();
      const next = `/dashboard/template-lab?roomId=${encodeURIComponent(roomId())}`;
      window.history.replaceState({}, '', next);
    });
    widgetUser.addEventListener('change', initWidget);

    buildUserOptions();
    renderRoomStateInfo();
    initWidget();
  </script>
</body>
</html>
