<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .help-modal-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.35);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 80;
      padding: 16px;
    }
    .help-modal-backdrop.open { display: flex; }
    .help-modal {
      width: min(920px, 100%);
      max-height: 90vh;
      overflow: auto;
      border-radius: 16px;
      background: #fff;
      border: 1px solid #d1fae5;
      box-shadow: 0 20px 60px rgba(15, 23, 42, 0.2);
      padding: 16px;
    }
    .kbd-chip {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      border: 1px solid #bfdbfe;
      background: #eff6ff;
      color: #1d4ed8;
      font-size: 11px;
      font-weight: 700;
      padding: 2px 8px;
    }
    .wizard-step-btn.active {
      border-color: #10b981;
      background: #ecfdf5;
      color: #047857;
    }
    .wizard-panel-hidden {
      display: none;
    }
  </style>
</head>
<body class="min-h-dvh text-green-700">
  <div id="sidebarOverlay" class="fixed inset-0 z-20 bg-black/30 opacity-0 pointer-events-none transition"></div>
  <%- include('../partials/sidebar', { user, active: 'ai' }) %>

  <div>
    <%- include('../partials/topbar', { user, pageTitle: 'IA - Tools' }) %>

    <main class="mx-auto w-full max-w-7xl space-y-5 px-4 py-6 sm:px-6 lg:px-10 lg:py-8">
      <%- include('../components/breadcrumb/index', {
        link: '/dashboard',
        paginaAnterior: 'Dashboard',
        paginaAtual: 'IA > Tools'
      }) %>

      <%- include('./partials/ai-tabs', { aiTab: typeof aiTab !== 'undefined' ? aiTab : 'tools' }) %>

      <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <div class="flex flex-wrap items-start justify-between gap-2">
          <div>
            <h1 class="text-xl font-bold text-green-800">Ferramentas da IA</h1>
            <p class="mt-1 text-sm text-gray-500">Interface simplificada para cadastrar, testar e habilitar ferramentas com seguranca.</p>
          </div>
          <button id="openJsonHelpBtn" type="button" class="inline-flex items-center gap-2 rounded-full border border-blue-300 bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700 hover:bg-blue-100">
            <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-blue-200 text-blue-800">?</span>
            Padrao JSON para IA
          </button>
        </div>
        <div class="mt-3 grid gap-2 md:grid-cols-3">
          <div class="rounded-xl border border-green-100 bg-green-50 p-3">
            <p class="text-xs font-semibold text-green-700">Passo 1</p>
            <p class="mt-1 text-sm font-semibold text-slate-700">Aplicar template inicial</p>
          </div>
          <div class="rounded-xl border border-green-100 bg-green-50 p-3">
            <p class="text-xs font-semibold text-green-700">Passo 2</p>
            <p class="mt-1 text-sm font-semibold text-slate-700">Salvar e testar argumentos</p>
          </div>
          <div class="rounded-xl border border-green-100 bg-green-50 p-3">
            <p class="text-xs font-semibold text-green-700">Passo 3</p>
            <p class="mt-1 text-sm font-semibold text-slate-700">Validar JSON de resposta</p>
          </div>
        </div>
      </section>

      <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <div class="flex flex-wrap items-center gap-2">
          <button id="wizardStep1Btn" type="button" class="wizard-step-btn active rounded-full border border-gray-300 bg-white px-3 py-1 text-xs font-semibold text-gray-700">1. Contrato</button>
          <button id="wizardStep2Btn" type="button" class="wizard-step-btn rounded-full border border-gray-300 bg-white px-3 py-1 text-xs font-semibold text-gray-700">2. Teste</button>
          <button id="wizardStep3Btn" type="button" class="wizard-step-btn rounded-full border border-gray-300 bg-white px-3 py-1 text-xs font-semibold text-gray-700">3. Revisao IA</button>
          <span id="wizardStatus" class="ml-auto text-xs font-semibold text-gray-500">Etapa atual: Contrato</span>
        </div>
      </section>

      <section class="grid gap-4 lg:grid-cols-2">
        <article class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
          <div class="flex items-center justify-between">
            <h2 class="text-base font-bold text-green-800">Ferramentas cadastradas</h2>
            <button id="newToolBtn" type="button" class="rounded-full border border-green-300 bg-green-50 px-3 py-1 text-xs font-semibold text-green-700 hover:bg-green-100">Nova</button>
          </div>
          <div id="toolsList" class="mt-3 space-y-2"></div>
        </article>

        <article id="wizardPanelStep1" data-step-panel="1" class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
          <h2 class="text-base font-bold text-green-800">Contrato da ferramenta</h2>
          <div class="mt-3 rounded-xl border border-blue-200 bg-blue-50 p-3">
            <p class="text-xs font-semibold text-blue-700">Configuracao rapida</p>
            <div class="mt-2 flex flex-wrap gap-2">
              <button id="applyOpenTicketTemplateBtn" type="button" class="rounded-full border border-blue-300 bg-white px-3 py-1 text-xs font-semibold text-blue-700 hover:bg-blue-100">
                Primeira ferramenta: Abrir chamado
              </button>
              <button id="openImportOpenApiBtn" type="button" class="rounded-full border border-indigo-300 bg-white px-3 py-1 text-xs font-semibold text-indigo-700 hover:bg-indigo-100">
                Importar OpenAPI YAML
              </button>
            </div>
            <p class="mt-2 text-xs text-blue-700">Preenche automaticamente os campos principais para voce so ajustar o endpoint e domínios.</p>
          </div>
          <div class="mt-3 grid gap-3">
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-gray-600">Nome</span>
              <input id="toolName" type="text" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm outline-none focus:border-green-400">
            </label>
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-gray-600">Slug</span>
              <input id="toolSlug" type="text" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm outline-none focus:border-green-400" placeholder="abrir-chamado">
            </label>
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-gray-600">Descricao</span>
              <textarea id="toolDescription" rows="2" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm outline-none focus:border-green-400"></textarea>
            </label>
            <div class="grid gap-3 sm:grid-cols-2">
              <label class="text-sm">
                <span class="mb-1 block font-semibold text-gray-600">Metodo</span>
                <select id="toolMethod" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm outline-none focus:border-green-400">
                  <option>POST</option>
                  <option>GET</option>
                  <option>PUT</option>
                  <option>PATCH</option>
                  <option>DELETE</option>
                </select>
              </label>
              <label class="text-sm">
                <span class="mb-1 block font-semibold text-gray-600">Timeout (ms)</span>
                <input id="toolTimeoutMs" type="number" min="3000" max="45000" value="12000" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm outline-none focus:border-green-400">
              </label>
            </div>
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-gray-600">Endpoint URL</span>
              <input id="toolEndpointUrl" type="text" placeholder="https://ajuda.taiksu.com.br/api/..." class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm outline-none focus:border-green-400">
            </label>
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-gray-600">Dominios permitidos (1 por linha)</span>
              <textarea id="toolAllowedDomains" rows="2" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm outline-none focus:border-green-400" placeholder="ajuda.taiksu.com.br"></textarea>
            </label>
            <details class="rounded-xl border border-green-100 bg-green-50 p-3">
              <summary class="cursor-pointer text-sm font-semibold text-green-800">Campos avancados (headers, schema e payload)</summary>
              <div class="mt-3 grid gap-3">
                <label class="text-sm">
                  <span class="mb-1 block font-semibold text-gray-600">Headers JSON</span>
                  <textarea id="toolHeaders" rows="3" class="w-full rounded-xl border border-green-200 px-3 py-2 font-mono text-xs outline-none focus:border-green-400">{}</textarea>
                  <p id="toolHeadersValidation" class="mt-1 text-xs text-gray-500">JSON valido.</p>
                </label>
                <label class="text-sm">
                  <span class="mb-1 block font-semibold text-gray-600">Input Schema JSON</span>
                  <textarea id="toolInputSchema" rows="5" class="w-full rounded-xl border border-green-200 px-3 py-2 font-mono text-xs outline-none focus:border-green-400">{
  "type": "object",
  "required": [],
  "properties": {}
}</textarea>
                  <p id="toolInputSchemaValidation" class="mt-1 text-xs text-gray-500">JSON valido.</p>
                </label>
                <label class="text-sm">
                  <span class="mb-1 block font-semibold text-gray-600">Payload Template (JSON com {{variavel}})</span>
                  <textarea id="toolPayloadTemplate" rows="5" class="w-full rounded-xl border border-green-200 px-3 py-2 font-mono text-xs outline-none focus:border-green-400">{}</textarea>
                  <p id="toolPayloadTemplateValidation" class="mt-1 text-xs text-gray-500">JSON valido.</p>
                </label>
              </div>
            </details>
            <label class="inline-flex items-center gap-2 text-sm font-semibold text-gray-700">
              <input id="toolEnabled" type="checkbox" class="h-4 w-4 rounded border-gray-300 text-green-600 focus:ring-green-500" checked>
              Ferramenta habilitada
            </label>
          </div>
          <div class="mt-4 flex flex-wrap items-center gap-2">
            <button id="saveToolBtn" type="button" class="rounded-full border border-green-300 bg-green-50 px-4 py-2 text-sm font-semibold text-green-700 hover:bg-green-100">Salvar</button>
            <button id="deleteToolBtn" type="button" class="rounded-full border border-red-300 bg-red-50 px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-100">Excluir</button>
            <button id="wizardNextToTestBtn" type="button" class="rounded-full border border-blue-300 bg-blue-50 px-4 py-2 text-sm font-semibold text-blue-700 hover:bg-blue-100">Ir para teste</button>
            <span id="toolStatus" class="text-xs font-semibold text-gray-500">Aguardando</span>
          </div>
        </article>
      </section>

      <section class="grid gap-4 lg:grid-cols-2">
        <article id="wizardPanelStep2" data-step-panel="2" class="wizard-panel-hidden rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
          <h2 class="text-base font-bold text-green-800">Teste da ferramenta</h2>
          <label class="mt-3 block text-sm">
            <span class="mb-1 block font-semibold text-gray-600">Arguments JSON</span>
            <textarea id="toolTestArgs" rows="6" class="w-full rounded-xl border border-green-200 px-3 py-2 font-mono text-xs outline-none focus:border-green-400">{
  "chamadoId": "12345",
  "titulo": "Erro no caixa"
}</textarea>
            <p id="toolTestArgsValidation" class="mt-1 text-xs text-gray-500">JSON valido.</p>
          </label>
          <div class="mt-3 flex items-center gap-2">
            <button id="testToolBtn" type="button" class="rounded-full border border-blue-300 bg-blue-50 px-4 py-2 text-sm font-semibold text-blue-700 hover:bg-blue-100">Testar</button>
            <button id="wizardBackToContractBtn" type="button" class="rounded-full border border-gray-300 bg-white px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-100">Voltar contrato</button>
            <button id="wizardNextToReviewBtn" type="button" class="rounded-full border border-purple-300 bg-purple-50 px-4 py-2 text-sm font-semibold text-purple-700 hover:bg-purple-100">Ir para revisao IA</button>
          </div>
          <pre id="toolTestOutput" class="mt-3 overflow-auto rounded-xl border border-gray-200 bg-gray-50 p-3 text-xs text-gray-700">Sem execucao.</pre>
        </article>

        <article id="wizardPanelStep3" data-step-panel="3" class="wizard-panel-hidden rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
          <h2 class="text-base font-bold text-green-800">Resultado esperado para IA</h2>
          <p class="mt-1 text-xs text-gray-500">Padronizacao automatica do retorno para a IA interpretar com clareza.</p>
          <pre id="toolAiExpectedOutput" class="mt-3 overflow-auto rounded-xl border border-blue-200 bg-blue-50 p-3 text-xs text-blue-900">{
  "success": true,
  "message": "Sem execucao ainda.",
  "data": {}
}</pre>
          <div class="mt-2 flex items-center gap-2">
            <button id="copyExpectedOutputBtn" type="button" class="rounded-full border border-blue-300 bg-white px-3 py-1 text-xs font-semibold text-blue-700 hover:bg-blue-100">Copiar JSON esperado</button>
            <button id="wizardBackToTestBtn" type="button" class="rounded-full border border-gray-300 bg-white px-3 py-1 text-xs font-semibold text-gray-700 hover:bg-gray-100">Voltar teste</button>
          </div>
        </article>

        <article class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
          <h2 class="text-base font-bold text-green-800">Execucoes recentes</h2>
          <div id="toolRuns" class="mt-3 space-y-2 text-sm text-gray-700"></div>
        </article>
      </section>
    </main>
  </div>

  <div id="jsonHelpModal" class="help-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="jsonHelpTitle">
    <div class="help-modal">
      <div class="flex items-start justify-between gap-3">
        <div>
          <h3 id="jsonHelpTitle" class="text-lg font-bold text-green-800">Padrao de resposta JSON para IA</h3>
          <p class="mt-1 text-sm text-gray-500">Use sempre a mesma estrutura para a IA interpretar com clareza e previsibilidade.</p>
        </div>
        <button id="closeJsonHelpBtn" type="button" class="rounded-full border border-gray-300 px-3 py-1 text-xs font-semibold text-gray-700 hover:bg-gray-100">Fechar</button>
      </div>
      <div class="mt-4 space-y-3">
        <div class="rounded-xl border border-green-100 bg-green-50 p-3">
          <p class="text-xs font-semibold text-green-700">Sucesso</p>
          <pre id="jsonHelpSuccess" class="mt-2 overflow-auto rounded-lg border border-green-200 bg-white p-3 text-xs text-gray-700">{
  "success": true,
  "tool": "abrir-chamado",
  "message": "Chamado criado com sucesso",
  "data": {
    "chamadoId": "12345",
    "status": "aberto",
    "prioridade": "media",
    "url": "https://ajuda.taiksu.com.br/chamados/12345"
  },
  "next_action": "acompanhar_chamado"
}</pre>
          <button data-copy-from="jsonHelpSuccess" type="button" class="mt-2 rounded-full border border-green-300 bg-white px-3 py-1 text-xs font-semibold text-green-700 hover:bg-green-100">Copiar exemplo de sucesso</button>
        </div>
        <div class="rounded-xl border border-red-100 bg-red-50 p-3">
          <p class="text-xs font-semibold text-red-700">Erro padrao</p>
          <pre id="jsonHelpError" class="mt-2 overflow-auto rounded-lg border border-red-200 bg-white p-3 text-xs text-gray-700">{
  "success": false,
  "error": {
    "code": "VALIDATION_ERROR",
    "message": "Campo titulo e obrigatorio",
    "fields": ["titulo"]
  }
}</pre>
          <button data-copy-from="jsonHelpError" type="button" class="mt-2 rounded-full border border-red-300 bg-white px-3 py-1 text-xs font-semibold text-red-700 hover:bg-red-100">Copiar exemplo de erro</button>
        </div>
        <div class="rounded-xl border border-blue-100 bg-blue-50 p-3 text-xs text-blue-800">
          <p class="font-semibold">Boas praticas</p>
          <p class="mt-1">1) Sempre retorne <span class="kbd-chip">success</span> e <span class="kbd-chip">message</span>.</p>
          <p class="mt-1">2) Coloque dados principais em <span class="kbd-chip">data</span> com nomes estaveis.</p>
          <p class="mt-1">3) Em erro, use <span class="kbd-chip">error.code</span> e <span class="kbd-chip">error.message</span>.</p>
        </div>
      </div>
    </div>
  </div>

  <div id="importOpenApiModal" class="help-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="importOpenApiTitle">
    <div class="help-modal">
      <div class="flex items-start justify-between gap-3">
        <div>
          <h3 id="importOpenApiTitle" class="text-lg font-bold text-green-800">Importar OpenAPI YAML</h3>
          <p class="mt-1 text-sm text-gray-500">Cole YAML/JSON OpenAPI e preencha automaticamente o contrato da ferramenta.</p>
        </div>
        <button id="closeImportOpenApiBtn" type="button" class="rounded-full border border-gray-300 px-3 py-1 text-xs font-semibold text-gray-700 hover:bg-gray-100">Fechar</button>
      </div>
      <label class="mt-3 block text-sm">
        <span class="mb-1 block font-semibold text-gray-600">Especificacao OpenAPI</span>
        <textarea id="openApiSpecInput" rows="16" class="w-full rounded-xl border border-green-200 px-3 py-2 font-mono text-xs outline-none focus:border-green-400" placeholder="openapi: 3.0.3&#10;info: ..."></textarea>
      </label>
      <div class="mt-3 flex flex-wrap items-center gap-2">
        <button id="importOpenApiApplyBtn" type="button" class="rounded-full border border-indigo-300 bg-indigo-50 px-4 py-2 text-sm font-semibold text-indigo-700 hover:bg-indigo-100">Importar e aplicar</button>
        <button id="importOpenApiClearBtn" type="button" class="rounded-full border border-gray-300 bg-white px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-100">Limpar</button>
        <span id="importOpenApiStatus" class="text-xs font-semibold text-gray-500">Aguardando especificacao.</span>
      </div>
    </div>
  </div>

  <%- include('../partials/sidebar-script') %>
  <script>
    const listEl = document.getElementById('toolsList');
    const statusEl = document.getElementById('toolStatus');
    const wizardStatusEl = document.getElementById('wizardStatus');
    const runsEl = document.getElementById('toolRuns');
    const outputEl = document.getElementById('toolTestOutput');
    const expectedOutputEl = document.getElementById('toolAiExpectedOutput');
    const ids = {
      name: 'toolName',
      slug: 'toolSlug',
      description: 'toolDescription',
      method: 'toolMethod',
      timeoutMs: 'toolTimeoutMs',
      endpointUrl: 'toolEndpointUrl',
      allowedDomains: 'toolAllowedDomains',
      headers: 'toolHeaders',
      inputSchema: 'toolInputSchema',
      payloadTemplate: 'toolPayloadTemplate',
      enabled: 'toolEnabled'
    };
    let tools = [];
    let selectedId = '';
    let currentWizardStep = 1;
    const openTicketTemplate = {
      name: 'Abrir chamado de suporte',
      slug: 'abrir-chamado',
      description: 'Cria chamado operacional quando o usuario reporta problema no caixa.',
      method: 'POST',
      timeoutMs: 12000,
      endpointUrl: 'https://ajuda.taiksu.com.br/api/chamados',
      allowedDomains: 'ajuda.taiksu.com.br',
      headers: {
        'Content-Type': 'application/json'
      },
      inputSchema: {
        type: 'object',
        required: ['titulo', 'descricao'],
        properties: {
          titulo: { type: 'string' },
          descricao: { type: 'string' },
          prioridade: { type: 'string' },
          lojaId: { type: 'string' }
        }
      },
      payloadTemplate: {
        titulo: '{{titulo}}',
        descricao: '{{descricao}}',
        prioridade: '{{prioridade}}',
        lojaId: '{{lojaId}}'
      },
      testArgs: {
        titulo: 'Erro no modo caixa',
        descricao: 'Nao estou conseguindo fechar gaveta.',
        prioridade: 'media',
        lojaId: 'loja-001'
      }
    };

    function el(id) { return document.getElementById(id); }

    function setStatus(text, type = 'info') {
      const colors = { info: 'text-gray-500', success: 'text-emerald-700', error: 'text-red-700' };
      statusEl.textContent = text;
      statusEl.className = `text-xs font-semibold ${colors[type] || colors.info}`;
    }

    function setWizardStep(step) {
      currentWizardStep = Number(step || 1);
      const titles = { 1: 'Contrato', 2: 'Teste', 3: 'Revisao IA' };
      wizardStatusEl.textContent = `Etapa atual: ${titles[currentWizardStep] || 'Contrato'}`;
      [1, 2, 3].forEach((index) => {
        const panel = document.querySelector(`[data-step-panel="${index}"]`);
        const btn = document.getElementById(`wizardStep${index}Btn`);
        if (panel) panel.classList.toggle('wizard-panel-hidden', index !== currentWizardStep);
        if (btn) btn.classList.toggle('active', index === currentWizardStep);
      });
    }

    function validateJsonField(fieldId, feedbackId) {
      const input = el(fieldId);
      const feedback = el(feedbackId);
      if (!input || !feedback) return true;
      const raw = String(input.value || '').trim();
      if (!raw) {
        input.classList.remove('border-red-300', 'border-emerald-300');
        input.classList.add('border-green-200');
        feedback.className = 'mt-1 text-xs text-gray-500';
        feedback.textContent = 'Campo vazio. Use {} para objeto vazio.';
        return true;
      }
      try {
        JSON.parse(raw);
        input.classList.remove('border-red-300');
        input.classList.add('border-emerald-300');
        feedback.className = 'mt-1 text-xs text-emerald-700';
        feedback.textContent = 'JSON valido.';
        return true;
      } catch (error) {
        input.classList.remove('border-emerald-300');
        input.classList.add('border-red-300');
        feedback.className = 'mt-1 text-xs text-red-700';
        feedback.textContent = `JSON invalido: ${error.message}`;
        return false;
      }
    }

    function validateAllJsonFields() {
      const a = validateJsonField(ids.headers, 'toolHeadersValidation');
      const b = validateJsonField(ids.inputSchema, 'toolInputSchemaValidation');
      const c = validateJsonField(ids.payloadTemplate, 'toolPayloadTemplateValidation');
      const d = validateJsonField('toolTestArgs', 'toolTestArgsValidation');
      return a && b && c && d;
    }

    function renderExpectedAiResult(rawResult) {
      const source = rawResult && typeof rawResult === 'object' ? rawResult : {};
      const expected = {
        success: typeof source.success === 'boolean' ? source.success : true,
        message: String(
          source.message
            || source.summary
            || (source.success === false ? 'Ferramenta retornou erro.' : 'Ferramenta executada com sucesso.')
        ).trim(),
        data: source.data && typeof source.data === 'object' ? source.data : source,
        error: source.success === false
          ? {
            code: String(source?.error?.code || source?.code || 'TOOL_ERROR'),
            message: String(source?.error?.message || source?.message || 'Falha na ferramenta')
          }
          : undefined
      };
      expectedOutputEl.textContent = JSON.stringify(expected, null, 2);
    }

    async function fetchJson(url, init) {
      const response = await fetch(url, { credentials: 'include', ...init });
      const data = await response.json().catch(() => ({}));
      if (!response.ok) throw new Error(data.error || `Falha HTTP ${response.status}`);
      return data;
    }

    function currentPayload() {
      return {
        name: el(ids.name).value,
        slug: el(ids.slug).value,
        description: el(ids.description).value,
        method: el(ids.method).value,
        timeoutMs: Number(el(ids.timeoutMs).value || 12000),
        endpointUrl: el(ids.endpointUrl).value,
        allowedDomains: el(ids.allowedDomains).value,
        headers: el(ids.headers).value,
        inputSchema: el(ids.inputSchema).value,
        payloadTemplate: el(ids.payloadTemplate).value,
        enabled: el(ids.enabled).checked
      };
    }

    function clearForm() {
      selectedId = '';
      el(ids.name).value = '';
      el(ids.slug).value = '';
      el(ids.description).value = '';
      el(ids.method).value = 'POST';
      el(ids.timeoutMs).value = '12000';
      el(ids.endpointUrl).value = '';
      el(ids.allowedDomains).value = '';
      el(ids.headers).value = '{}';
      el(ids.inputSchema).value = '{\n  "type": "object",\n  "required": [],\n  "properties": {}\n}';
      el(ids.payloadTemplate).value = '{}';
      el(ids.enabled).checked = true;
      outputEl.textContent = 'Sem execucao.';
      expectedOutputEl.textContent = JSON.stringify({
        success: true,
        message: 'Sem execucao ainda.',
        data: {}
      }, null, 2);
      runsEl.innerHTML = '';
      renderTools();
      validateAllJsonFields();
    }

    function fillForm(item) {
      if (!item) return clearForm();
      selectedId = item.id;
      el(ids.name).value = item.name || '';
      el(ids.slug).value = item.slug || '';
      el(ids.description).value = item.description || '';
      el(ids.method).value = item.method || 'POST';
      el(ids.timeoutMs).value = String(item.timeoutMs || 12000);
      el(ids.endpointUrl).value = item.endpointUrl || '';
      el(ids.allowedDomains).value = Array.isArray(item.allowedDomains) ? item.allowedDomains.join('\n') : '';
      el(ids.headers).value = JSON.stringify(item.headers || {}, null, 2);
      el(ids.inputSchema).value = JSON.stringify(item.inputSchema || {}, null, 2);
      el(ids.payloadTemplate).value = item.payloadTemplate || '{}';
      el(ids.enabled).checked = Boolean(item.enabled);
      renderTools();
      loadRuns();
      validateAllJsonFields();
    }

    function applyOpenTicketTemplate() {
      selectedId = '';
      el(ids.name).value = openTicketTemplate.name;
      el(ids.slug).value = openTicketTemplate.slug;
      el(ids.description).value = openTicketTemplate.description;
      el(ids.method).value = openTicketTemplate.method;
      el(ids.timeoutMs).value = String(openTicketTemplate.timeoutMs);
      el(ids.endpointUrl).value = openTicketTemplate.endpointUrl;
      el(ids.allowedDomains).value = openTicketTemplate.allowedDomains;
      el(ids.headers).value = JSON.stringify(openTicketTemplate.headers, null, 2);
      el(ids.inputSchema).value = JSON.stringify(openTicketTemplate.inputSchema, null, 2);
      el(ids.payloadTemplate).value = JSON.stringify(openTicketTemplate.payloadTemplate, null, 2);
      el('toolTestArgs').value = JSON.stringify(openTicketTemplate.testArgs, null, 2);
      el(ids.enabled).checked = true;
      outputEl.textContent = 'Template aplicado. Revise endpoint, salve e teste.';
      runsEl.innerHTML = '<p class="text-sm text-gray-500">Salve a ferramenta para ver execucoes.</p>';
      renderTools();
      setStatus('Template "Abrir chamado" aplicado.', 'success');
      validateAllJsonFields();
      setWizardStep(1);
    }

    function applyImportedTool(item) {
      if (!item || typeof item !== 'object') return;
      selectedId = '';
      el(ids.name).value = String(item.name || '');
      el(ids.slug).value = String(item.slug || '');
      el(ids.description).value = String(item.description || '');
      el(ids.method).value = String(item.method || 'POST').toUpperCase();
      el(ids.timeoutMs).value = String(item.timeoutMs || 12000);
      el(ids.endpointUrl).value = String(item.endpointUrl || '');
      el(ids.allowedDomains).value = Array.isArray(item.allowedDomains) ? item.allowedDomains.join('\n') : '';
      el(ids.headers).value = JSON.stringify(item.headers || {}, null, 2);
      el(ids.inputSchema).value = JSON.stringify(item.inputSchema || {}, null, 2);
      el(ids.payloadTemplate).value = JSON.stringify(item.payloadTemplate || {}, null, 2);
      el('toolTestArgs').value = JSON.stringify(item.testArgs || {}, null, 2);
      el(ids.enabled).checked = true;
      outputEl.textContent = 'OpenAPI importado. Revise, salve e teste.';
      renderExpectedAiResult({
        success: true,
        message: 'Contrato gerado via OpenAPI.',
        data: {
          operationId: item?.meta?.operationId || '',
          method: item?.meta?.pickedMethod || '',
          path: item?.meta?.pickedPath || ''
        }
      });
      validateAllJsonFields();
      setWizardStep(1);
      setStatus('OpenAPI importado e aplicado no formulario.', 'success');
    }

    function renderTools() {
      if (!tools.length) {
        listEl.innerHTML = '<p class="text-sm text-gray-500">Nenhuma ferramenta cadastrada.</p>';
        return;
      }
      listEl.innerHTML = tools.map((item) => {
        const active = String(item.id) === String(selectedId);
        return `
          <button type="button" data-tool-id="${item.id}" class="w-full rounded-xl border px-3 py-2 text-left transition ${active ? 'border-green-300 bg-green-50' : 'border-gray-200 bg-white hover:border-green-200'}">
            <div class="flex items-center justify-between gap-2">
              <p class="text-sm font-semibold text-slate-800">${item.name}</p>
              <span class="rounded-full px-2 py-0.5 text-[10px] font-bold ${item.enabled ? 'bg-emerald-100 text-emerald-700' : 'bg-gray-200 text-gray-600'}">${item.enabled ? 'ON' : 'OFF'}</span>
            </div>
            <p class="mt-1 text-xs text-gray-500">${item.method} ${item.endpointUrl}</p>
            <p class="mt-1 text-[11px] text-gray-400">slug: ${item.slug}</p>
          </button>
        `;
      }).join('');
      listEl.querySelectorAll('button[data-tool-id]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const item = tools.find((t) => String(t.id) === String(btn.getAttribute('data-tool-id')));
          fillForm(item || null);
        });
      });
    }

    function renderRuns(items) {
      const rows = Array.isArray(items) ? items : [];
      if (!rows.length) {
        runsEl.innerHTML = '<p class="text-sm text-gray-500">Sem execucoes para esta ferramenta.</p>';
        return;
      }
      runsEl.innerHTML = rows.map((run) => `
        <article class="rounded-xl border border-gray-200 p-3">
          <div class="flex items-center justify-between gap-2">
            <strong class="text-sm text-slate-800">${run.status}</strong>
            <span class="text-xs text-gray-500">${new Date(run.createdAt).toLocaleString('pt-BR')}</span>
          </div>
          <p class="mt-1 text-xs text-gray-600">HTTP: ${run.responseStatus || '-'} | ${run.latencyMs || 0} ms</p>
          ${run.errorMessage ? `<p class="mt-1 text-xs font-semibold text-red-700">${run.errorMessage}</p>` : ''}
        </article>
      `).join('');
    }

    async function loadTools() {
      setStatus('Carregando ferramentas...');
      try {
        const data = await fetchJson('/api/ai-tools');
        tools = Array.isArray(data.items) ? data.items : [];
        renderTools();
        setStatus('Ferramentas carregadas', 'success');
      } catch (error) {
        setStatus(error.message, 'error');
      }
    }

    async function loadRuns() {
      if (!selectedId) {
        runsEl.innerHTML = '<p class="text-sm text-gray-500">Selecione uma ferramenta para ver execucoes.</p>';
        return;
      }
      try {
        const data = await fetchJson(`/api/ai-tools/${encodeURIComponent(selectedId)}/runs?limit=20`);
        renderRuns(data.items || []);
      } catch (error) {
        runsEl.innerHTML = `<p class="text-sm text-red-700">${error.message}</p>`;
      }
    }

    async function saveTool() {
      if (!validateAllJsonFields()) {
        setWizardStep(1);
        return setStatus('Corrija os campos JSON invalidos antes de salvar.', 'error');
      }
      const payload = currentPayload();
      try {
        setStatus('Salvando ferramenta...');
        if (selectedId) {
          await fetchJson(`/api/ai-tools/${encodeURIComponent(selectedId)}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          setStatus('Ferramenta atualizada', 'success');
        } else {
          const created = await fetchJson('/api/ai-tools', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          selectedId = created?.item?.id || '';
          setStatus('Ferramenta criada', 'success');
        }
        await loadTools();
        if (selectedId) {
          const selected = tools.find((t) => String(t.id) === String(selectedId));
          if (selected) fillForm(selected);
        }
      } catch (error) {
        setStatus(error.message, 'error');
      }
    }

    async function deleteTool() {
      if (!selectedId) return setStatus('Selecione uma ferramenta para excluir', 'error');
      if (!confirm('Excluir esta ferramenta?')) return;
      try {
        await fetchJson(`/api/ai-tools/${encodeURIComponent(selectedId)}`, { method: 'DELETE' });
        setStatus('Ferramenta excluida', 'success');
        clearForm();
        await loadTools();
      } catch (error) {
        setStatus(error.message, 'error');
      }
    }

    async function testTool() {
      if (!selectedId) return setStatus('Salve e selecione uma ferramenta para testar', 'error');
      if (!validateJsonField('toolTestArgs', 'toolTestArgsValidation')) {
        setWizardStep(2);
        return setStatus('Arguments JSON invalido', 'error');
      }
      let args = {};
      try {
        args = JSON.parse(String(el('toolTestArgs').value || '{}'));
      } catch (_err) {
        return setStatus('Arguments JSON invalido', 'error');
      }
      setStatus('Executando teste...');
      outputEl.textContent = 'Executando...';
      try {
        const data = await fetchJson(`/api/ai-tools/${encodeURIComponent(selectedId)}/test`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ arguments: args })
        });
        outputEl.textContent = JSON.stringify(data.result || {}, null, 2);
        renderExpectedAiResult(data.result || {});
        setWizardStep(3);
        setStatus('Teste finalizado', 'success');
        await loadRuns();
      } catch (error) {
        outputEl.textContent = error.message;
        renderExpectedAiResult({
          success: false,
          error: { code: 'TEST_ERROR', message: error.message }
        });
        setStatus(error.message, 'error');
      }
    }

    document.getElementById('newToolBtn').addEventListener('click', clearForm);
    document.getElementById('applyOpenTicketTemplateBtn').addEventListener('click', applyOpenTicketTemplate);
    document.getElementById('saveToolBtn').addEventListener('click', saveTool);
    document.getElementById('deleteToolBtn').addEventListener('click', deleteTool);
    document.getElementById('testToolBtn').addEventListener('click', testTool);
    document.getElementById('wizardStep1Btn').addEventListener('click', () => setWizardStep(1));
    document.getElementById('wizardStep2Btn').addEventListener('click', () => setWizardStep(2));
    document.getElementById('wizardStep3Btn').addEventListener('click', () => setWizardStep(3));
    document.getElementById('wizardNextToTestBtn').addEventListener('click', () => setWizardStep(2));
    document.getElementById('wizardBackToContractBtn').addEventListener('click', () => setWizardStep(1));
    document.getElementById('wizardNextToReviewBtn').addEventListener('click', () => setWizardStep(3));
    document.getElementById('wizardBackToTestBtn').addEventListener('click', () => setWizardStep(2));
    document.getElementById('copyExpectedOutputBtn').addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(expectedOutputEl.textContent || '');
        setStatus('JSON esperado copiado.', 'success');
      } catch (_err) {
        setStatus('Falha ao copiar JSON esperado.', 'error');
      }
    });

    [ids.headers, ids.inputSchema, ids.payloadTemplate, 'toolTestArgs'].forEach((fieldId) => {
      const input = el(fieldId);
      if (!input) return;
      const feedbackId = fieldId === ids.headers
        ? 'toolHeadersValidation'
        : fieldId === ids.inputSchema
          ? 'toolInputSchemaValidation'
          : fieldId === ids.payloadTemplate
            ? 'toolPayloadTemplateValidation'
            : 'toolTestArgsValidation';
      input.addEventListener('input', () => validateJsonField(fieldId, feedbackId));
      input.addEventListener('blur', () => validateJsonField(fieldId, feedbackId));
    });

    const jsonHelpModal = document.getElementById('jsonHelpModal');
    function openJsonHelp() { jsonHelpModal.classList.add('open'); }
    function closeJsonHelp() { jsonHelpModal.classList.remove('open'); }
    document.getElementById('openJsonHelpBtn').addEventListener('click', openJsonHelp);
    document.getElementById('closeJsonHelpBtn').addEventListener('click', closeJsonHelp);
    jsonHelpModal.addEventListener('click', (event) => {
      if (event.target === jsonHelpModal) closeJsonHelp();
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeJsonHelp();
    });
    document.querySelectorAll('button[data-copy-from]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const source = document.getElementById(btn.getAttribute('data-copy-from'));
        if (!source) return;
        try {
          await navigator.clipboard.writeText(source.textContent || '');
          setStatus('Exemplo JSON copiado.', 'success');
        } catch (_err) {
          setStatus('Nao foi possivel copiar. Copie manualmente.', 'error');
        }
      });
    });

    const importOpenApiModal = document.getElementById('importOpenApiModal');
    const importOpenApiStatusEl = document.getElementById('importOpenApiStatus');
    const openApiSpecInputEl = document.getElementById('openApiSpecInput');
    function setImportStatus(text, type = 'info') {
      const colors = { info: 'text-gray-500', success: 'text-emerald-700', error: 'text-red-700' };
      importOpenApiStatusEl.textContent = text;
      importOpenApiStatusEl.className = `text-xs font-semibold ${colors[type] || colors.info}`;
    }
    function openImportOpenApi() { importOpenApiModal.classList.add('open'); }
    function closeImportOpenApi() { importOpenApiModal.classList.remove('open'); }
    document.getElementById('openImportOpenApiBtn').addEventListener('click', openImportOpenApi);
    document.getElementById('closeImportOpenApiBtn').addEventListener('click', closeImportOpenApi);
    document.getElementById('importOpenApiClearBtn').addEventListener('click', () => {
      openApiSpecInputEl.value = '';
      setImportStatus('Campo limpo.', 'info');
    });
    document.getElementById('importOpenApiApplyBtn').addEventListener('click', async () => {
      const spec = String(openApiSpecInputEl.value || '').trim();
      if (!spec) return setImportStatus('Cole a especificacao OpenAPI.', 'error');
      setImportStatus('Importando especificacao...', 'info');
      try {
        const data = await fetchJson('/api/ai-tools/import-openapi', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ spec })
        });
        applyImportedTool(data.item || {});
        setImportStatus('Importacao concluida com sucesso.', 'success');
        closeImportOpenApi();
      } catch (error) {
        setImportStatus(error.message, 'error');
      }
    });
    importOpenApiModal.addEventListener('click', (event) => {
      if (event.target === importOpenApiModal) closeImportOpenApi();
    });

    clearForm();
    validateAllJsonFields();
    setWizardStep(1);
    loadTools();
  </script>
</body>
</html>
