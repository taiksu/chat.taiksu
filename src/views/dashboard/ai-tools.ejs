<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="min-h-dvh text-green-700">
  <div id="sidebarOverlay" class="fixed inset-0 z-20 bg-black/30 opacity-0 pointer-events-none transition"></div>
  <%- include('../partials/sidebar', { user, active: 'ai' }) %>

  <div>
    <%- include('../partials/topbar', { user, pageTitle: 'IA - Tools' }) %>

    <main class="mx-auto w-full max-w-7xl space-y-5 px-4 py-6 sm:px-6 lg:px-10 lg:py-8">
      <%- include('../components/breadcrumb/index', {
        link: '/dashboard',
        paginaAnterior: 'Dashboard',
        paginaAtual: 'IA > Tools'
      }) %>

      <%- include('./partials/ai-tabs', { aiTab: typeof aiTab !== 'undefined' ? aiTab : 'tools' }) %>

      <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <h1 class="text-xl font-bold text-green-800">Ferramentas da IA</h1>
        <p class="mt-1 text-sm text-gray-500">Cadastre o contrato da API de ferramenta e teste execucao antes de habilitar em producao.</p>
      </section>

      <section class="grid gap-4 lg:grid-cols-2">
        <article class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
          <div class="flex items-center justify-between">
            <h2 class="text-base font-bold text-green-800">Ferramentas cadastradas</h2>
            <button id="newToolBtn" type="button" class="rounded-full border border-green-300 bg-green-50 px-3 py-1 text-xs font-semibold text-green-700 hover:bg-green-100">Nova</button>
          </div>
          <div id="toolsList" class="mt-3 space-y-2"></div>
        </article>

        <article class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
          <h2 class="text-base font-bold text-green-800">Contrato da ferramenta</h2>
          <div class="mt-3 grid gap-3">
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-gray-600">Nome</span>
              <input id="toolName" type="text" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm outline-none focus:border-green-400">
            </label>
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-gray-600">Slug</span>
              <input id="toolSlug" type="text" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm outline-none focus:border-green-400" placeholder="abrir-chamado">
            </label>
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-gray-600">Descricao</span>
              <textarea id="toolDescription" rows="2" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm outline-none focus:border-green-400"></textarea>
            </label>
            <div class="grid gap-3 sm:grid-cols-2">
              <label class="text-sm">
                <span class="mb-1 block font-semibold text-gray-600">Metodo</span>
                <select id="toolMethod" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm outline-none focus:border-green-400">
                  <option>POST</option>
                  <option>GET</option>
                  <option>PUT</option>
                  <option>PATCH</option>
                  <option>DELETE</option>
                </select>
              </label>
              <label class="text-sm">
                <span class="mb-1 block font-semibold text-gray-600">Timeout (ms)</span>
                <input id="toolTimeoutMs" type="number" min="3000" max="45000" value="12000" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm outline-none focus:border-green-400">
              </label>
            </div>
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-gray-600">Endpoint URL</span>
              <input id="toolEndpointUrl" type="text" placeholder="https://ajuda.taiksu.com.br/api/..." class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm outline-none focus:border-green-400">
            </label>
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-gray-600">Dominios permitidos (1 por linha)</span>
              <textarea id="toolAllowedDomains" rows="2" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm outline-none focus:border-green-400" placeholder="ajuda.taiksu.com.br"></textarea>
            </label>
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-gray-600">Headers JSON</span>
              <textarea id="toolHeaders" rows="3" class="w-full rounded-xl border border-green-200 px-3 py-2 font-mono text-xs outline-none focus:border-green-400">{}</textarea>
            </label>
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-gray-600">Input Schema JSON</span>
              <textarea id="toolInputSchema" rows="5" class="w-full rounded-xl border border-green-200 px-3 py-2 font-mono text-xs outline-none focus:border-green-400">{
  "type": "object",
  "required": [],
  "properties": {}
}</textarea>
            </label>
            <label class="text-sm">
              <span class="mb-1 block font-semibold text-gray-600">Payload Template (JSON com {{variavel}})</span>
              <textarea id="toolPayloadTemplate" rows="5" class="w-full rounded-xl border border-green-200 px-3 py-2 font-mono text-xs outline-none focus:border-green-400">{}</textarea>
            </label>
            <label class="inline-flex items-center gap-2 text-sm font-semibold text-gray-700">
              <input id="toolEnabled" type="checkbox" class="h-4 w-4 rounded border-gray-300 text-green-600 focus:ring-green-500" checked>
              Ferramenta habilitada
            </label>
          </div>
          <div class="mt-4 flex flex-wrap items-center gap-2">
            <button id="saveToolBtn" type="button" class="rounded-full border border-green-300 bg-green-50 px-4 py-2 text-sm font-semibold text-green-700 hover:bg-green-100">Salvar</button>
            <button id="deleteToolBtn" type="button" class="rounded-full border border-red-300 bg-red-50 px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-100">Excluir</button>
            <span id="toolStatus" class="text-xs font-semibold text-gray-500">Aguardando</span>
          </div>
        </article>
      </section>

      <section class="grid gap-4 lg:grid-cols-2">
        <article class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
          <h2 class="text-base font-bold text-green-800">Teste da ferramenta</h2>
          <label class="mt-3 block text-sm">
            <span class="mb-1 block font-semibold text-gray-600">Arguments JSON</span>
            <textarea id="toolTestArgs" rows="6" class="w-full rounded-xl border border-green-200 px-3 py-2 font-mono text-xs outline-none focus:border-green-400">{
  "chamadoId": "12345",
  "titulo": "Erro no caixa"
}</textarea>
          </label>
          <div class="mt-3 flex items-center gap-2">
            <button id="testToolBtn" type="button" class="rounded-full border border-blue-300 bg-blue-50 px-4 py-2 text-sm font-semibold text-blue-700 hover:bg-blue-100">Testar</button>
          </div>
          <pre id="toolTestOutput" class="mt-3 overflow-auto rounded-xl border border-gray-200 bg-gray-50 p-3 text-xs text-gray-700">Sem execucao.</pre>
        </article>

        <article class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
          <h2 class="text-base font-bold text-green-800">Execucoes recentes</h2>
          <div id="toolRuns" class="mt-3 space-y-2 text-sm text-gray-700"></div>
        </article>
      </section>
    </main>
  </div>

  <%- include('../partials/sidebar-script') %>
  <script>
    const listEl = document.getElementById('toolsList');
    const statusEl = document.getElementById('toolStatus');
    const runsEl = document.getElementById('toolRuns');
    const outputEl = document.getElementById('toolTestOutput');
    const ids = {
      name: 'toolName',
      slug: 'toolSlug',
      description: 'toolDescription',
      method: 'toolMethod',
      timeoutMs: 'toolTimeoutMs',
      endpointUrl: 'toolEndpointUrl',
      allowedDomains: 'toolAllowedDomains',
      headers: 'toolHeaders',
      inputSchema: 'toolInputSchema',
      payloadTemplate: 'toolPayloadTemplate',
      enabled: 'toolEnabled'
    };
    let tools = [];
    let selectedId = '';

    function el(id) { return document.getElementById(id); }

    function setStatus(text, type = 'info') {
      const colors = { info: 'text-gray-500', success: 'text-emerald-700', error: 'text-red-700' };
      statusEl.textContent = text;
      statusEl.className = `text-xs font-semibold ${colors[type] || colors.info}`;
    }

    async function fetchJson(url, init) {
      const response = await fetch(url, { credentials: 'include', ...init });
      const data = await response.json().catch(() => ({}));
      if (!response.ok) throw new Error(data.error || `Falha HTTP ${response.status}`);
      return data;
    }

    function currentPayload() {
      return {
        name: el(ids.name).value,
        slug: el(ids.slug).value,
        description: el(ids.description).value,
        method: el(ids.method).value,
        timeoutMs: Number(el(ids.timeoutMs).value || 12000),
        endpointUrl: el(ids.endpointUrl).value,
        allowedDomains: el(ids.allowedDomains).value,
        headers: el(ids.headers).value,
        inputSchema: el(ids.inputSchema).value,
        payloadTemplate: el(ids.payloadTemplate).value,
        enabled: el(ids.enabled).checked
      };
    }

    function clearForm() {
      selectedId = '';
      el(ids.name).value = '';
      el(ids.slug).value = '';
      el(ids.description).value = '';
      el(ids.method).value = 'POST';
      el(ids.timeoutMs).value = '12000';
      el(ids.endpointUrl).value = '';
      el(ids.allowedDomains).value = '';
      el(ids.headers).value = '{}';
      el(ids.inputSchema).value = '{\n  "type": "object",\n  "required": [],\n  "properties": {}\n}';
      el(ids.payloadTemplate).value = '{}';
      el(ids.enabled).checked = true;
      outputEl.textContent = 'Sem execucao.';
      runsEl.innerHTML = '';
      renderTools();
    }

    function fillForm(item) {
      if (!item) return clearForm();
      selectedId = item.id;
      el(ids.name).value = item.name || '';
      el(ids.slug).value = item.slug || '';
      el(ids.description).value = item.description || '';
      el(ids.method).value = item.method || 'POST';
      el(ids.timeoutMs).value = String(item.timeoutMs || 12000);
      el(ids.endpointUrl).value = item.endpointUrl || '';
      el(ids.allowedDomains).value = Array.isArray(item.allowedDomains) ? item.allowedDomains.join('\n') : '';
      el(ids.headers).value = JSON.stringify(item.headers || {}, null, 2);
      el(ids.inputSchema).value = JSON.stringify(item.inputSchema || {}, null, 2);
      el(ids.payloadTemplate).value = item.payloadTemplate || '{}';
      el(ids.enabled).checked = Boolean(item.enabled);
      renderTools();
      loadRuns();
    }

    function renderTools() {
      if (!tools.length) {
        listEl.innerHTML = '<p class="text-sm text-gray-500">Nenhuma ferramenta cadastrada.</p>';
        return;
      }
      listEl.innerHTML = tools.map((item) => {
        const active = String(item.id) === String(selectedId);
        return `
          <button type="button" data-tool-id="${item.id}" class="w-full rounded-xl border px-3 py-2 text-left transition ${active ? 'border-green-300 bg-green-50' : 'border-gray-200 bg-white hover:border-green-200'}">
            <div class="flex items-center justify-between gap-2">
              <p class="text-sm font-semibold text-slate-800">${item.name}</p>
              <span class="rounded-full px-2 py-0.5 text-[10px] font-bold ${item.enabled ? 'bg-emerald-100 text-emerald-700' : 'bg-gray-200 text-gray-600'}">${item.enabled ? 'ON' : 'OFF'}</span>
            </div>
            <p class="mt-1 text-xs text-gray-500">${item.method} ${item.endpointUrl}</p>
            <p class="mt-1 text-[11px] text-gray-400">slug: ${item.slug}</p>
          </button>
        `;
      }).join('');
      listEl.querySelectorAll('button[data-tool-id]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const item = tools.find((t) => String(t.id) === String(btn.getAttribute('data-tool-id')));
          fillForm(item || null);
        });
      });
    }

    function renderRuns(items) {
      const rows = Array.isArray(items) ? items : [];
      if (!rows.length) {
        runsEl.innerHTML = '<p class="text-sm text-gray-500">Sem execucoes para esta ferramenta.</p>';
        return;
      }
      runsEl.innerHTML = rows.map((run) => `
        <article class="rounded-xl border border-gray-200 p-3">
          <div class="flex items-center justify-between gap-2">
            <strong class="text-sm text-slate-800">${run.status}</strong>
            <span class="text-xs text-gray-500">${new Date(run.createdAt).toLocaleString('pt-BR')}</span>
          </div>
          <p class="mt-1 text-xs text-gray-600">HTTP: ${run.responseStatus || '-'} | ${run.latencyMs || 0} ms</p>
          ${run.errorMessage ? `<p class="mt-1 text-xs font-semibold text-red-700">${run.errorMessage}</p>` : ''}
        </article>
      `).join('');
    }

    async function loadTools() {
      setStatus('Carregando ferramentas...');
      try {
        const data = await fetchJson('/api/ai-tools');
        tools = Array.isArray(data.items) ? data.items : [];
        renderTools();
        setStatus('Ferramentas carregadas', 'success');
      } catch (error) {
        setStatus(error.message, 'error');
      }
    }

    async function loadRuns() {
      if (!selectedId) {
        runsEl.innerHTML = '<p class="text-sm text-gray-500">Selecione uma ferramenta para ver execucoes.</p>';
        return;
      }
      try {
        const data = await fetchJson(`/api/ai-tools/${encodeURIComponent(selectedId)}/runs?limit=20`);
        renderRuns(data.items || []);
      } catch (error) {
        runsEl.innerHTML = `<p class="text-sm text-red-700">${error.message}</p>`;
      }
    }

    async function saveTool() {
      const payload = currentPayload();
      try {
        setStatus('Salvando ferramenta...');
        if (selectedId) {
          await fetchJson(`/api/ai-tools/${encodeURIComponent(selectedId)}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          setStatus('Ferramenta atualizada', 'success');
        } else {
          const created = await fetchJson('/api/ai-tools', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          selectedId = created?.item?.id || '';
          setStatus('Ferramenta criada', 'success');
        }
        await loadTools();
        if (selectedId) {
          const selected = tools.find((t) => String(t.id) === String(selectedId));
          if (selected) fillForm(selected);
        }
      } catch (error) {
        setStatus(error.message, 'error');
      }
    }

    async function deleteTool() {
      if (!selectedId) return setStatus('Selecione uma ferramenta para excluir', 'error');
      if (!confirm('Excluir esta ferramenta?')) return;
      try {
        await fetchJson(`/api/ai-tools/${encodeURIComponent(selectedId)}`, { method: 'DELETE' });
        setStatus('Ferramenta excluida', 'success');
        clearForm();
        await loadTools();
      } catch (error) {
        setStatus(error.message, 'error');
      }
    }

    async function testTool() {
      if (!selectedId) return setStatus('Salve e selecione uma ferramenta para testar', 'error');
      let args = {};
      try {
        args = JSON.parse(String(el('toolTestArgs').value || '{}'));
      } catch (_err) {
        return setStatus('Arguments JSON invalido', 'error');
      }
      setStatus('Executando teste...');
      outputEl.textContent = 'Executando...';
      try {
        const data = await fetchJson(`/api/ai-tools/${encodeURIComponent(selectedId)}/test`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ arguments: args })
        });
        outputEl.textContent = JSON.stringify(data.result || {}, null, 2);
        setStatus('Teste finalizado', 'success');
        await loadRuns();
      } catch (error) {
        outputEl.textContent = error.message;
        setStatus(error.message, 'error');
      }
    }

    document.getElementById('newToolBtn').addEventListener('click', clearForm);
    document.getElementById('saveToolBtn').addEventListener('click', saveTool);
    document.getElementById('deleteToolBtn').addEventListener('click', deleteTool);
    document.getElementById('testToolBtn').addEventListener('click', testTool);

    clearForm();
    loadTools();
  </script>
</body>
</html>
