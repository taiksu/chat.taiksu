<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
</head>
<body class="min-h-dvh text-green-700">
  <div id="sidebarOverlay" class="fixed inset-0 z-20 bg-black/30 opacity-0 pointer-events-none transition"></div>
  <%- include('../partials/sidebar', { user, active: 'dashboard' }) %>

  <div>
    <%- include('../partials/topbar', {
      user,
      pageTitle: 'Dashboard'
    }) %>

    <main class="mx-auto w-full max-w-6xl space-y-5 px-4 py-6 sm:px-6 lg:px-10 lg:py-8">
      <div class="flex items-center gap-4">
        <div class="flex h-12 w-12 items-center justify-center overflow-hidden rounded-full bg-green-100 text-sm font-bold text-green-700">
          <% if (user && user.avatar) { %>
            <img src="<%= user.avatar %>" alt="Avatar de <%= user.name %>" class="h-full w-full object-cover">
          <% } else if (user && user.name) { %>
            <span><%= user.name.charAt(0).toUpperCase() %></span>
          <% } else { %>
            <span>U</span>
          <% } %>
        </div>
        <h1 class="text-xl font-medium text-gray-600">
          Olá, <span class="text-green-700 font-semibold"><%= (user && user.name) ? user.name : 'Usuario' %></span>
        </h1>
      </div>
    <section class="grid grid-cols-1 gap-3 sm:grid-cols-2 xl:grid-cols-5">
      <article class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500">Usuarios ativos</h3>
        <p class="mt-2 text-3xl font-bold text-green-700"><%= activeUsers %></p>
      </article>
      <article class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500">Total de usuarios</h3>
        <p class="mt-2 text-3xl font-bold text-green-700"><%= totalUsers %></p>
      </article>
      <article class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500">Salas de chat</h3>
        <p class="mt-2 text-3xl font-bold text-green-700"><%= totalRooms %></p>
      </article>
      <article class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500">Total de mensagens</h3>
        <p class="mt-2 text-3xl font-bold text-green-700"><%= totalMessages %></p>
      </article>
      <article class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm sm:col-span-2 xl:col-span-1">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500">Mensagens nao lidas</h3>
        <p class="mt-2 text-3xl font-bold text-green-700"><%= unreadMessages %></p>
      </article>
    </section>

      <section class="rounded-2xl border border-green-100 bg-white p-3 shadow-sm sm:p-5">
        <h2 class="mb-3 text-lg font-bold text-green-700 sm:text-xl">Metricas dos ultimos 30 dias</h2>
        <div class="relative h-64 sm:h-80">
          <canvas id="metricsChart"></canvas>
        </div>
      </section>

      <section class="rounded-2xl border border-amber-100 bg-white p-4 shadow-sm">
        <div class="flex items-center justify-between gap-2">
          <h2 class="text-lg font-bold text-amber-700">Chamados aguardando humano</h2>
          <span id="pendingHumanCount" class="rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700">0</span>
        </div>
        <div id="pendingHumanList" class="mt-3 space-y-2 text-sm text-slate-600">
          <p>Nenhuma pendencia no momento.</p>
        </div>
      </section>
    </main>
  </div>

  <%- include('../partials/sidebar-script') %>

  <script>
    fetch('/dashboard/metrics')
      .then(res => res.json())
      .then(metrics => {
        const ctx = document.getElementById('metricsChart').getContext('2d');
        new Chart(ctx, {
          type: 'line',
          data: {
            labels: metrics.map(m => m.date),
            datasets: [
              {
                label: 'Mensagens',
                data: metrics.map(m => m.messages_count),
                borderColor: '#22c55e',
                backgroundColor: 'rgba(34, 197, 94, 0.12)',
                tension: 0.35
              },
              {
                label: 'Usuarios Ativos',
                data: metrics.map(m => m.active_users),
                borderColor: '#15803d',
                backgroundColor: 'rgba(21, 128, 61, 0.1)',
                tension: 0.35
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: {
                position: 'top'
              }
            },
            scales: {
              y: {
                beginAtZero: true
              }
            }
          }
        });
      });

    function renderPendingHumans(items) {
      const countEl = document.getElementById('pendingHumanCount');
      const listEl = document.getElementById('pendingHumanList');
      const rows = Array.isArray(items) ? items : [];
      countEl.textContent = String(rows.length);
      if (!rows.length) {
        listEl.innerHTML = '<p>Nenhuma pendencia no momento.</p>';
        return;
      }
      listEl.innerHTML = rows.map((item) => {
        const roomId = String(item.roomId || '');
        const name = String(item.name || 'Sala sem nome');
        const wait = Number(item.waitMinutes || 0);
        const state = String(item.chatState || '');
        const called = item.chamadoId ? `#${item.chamadoId}` : 'sem chamado';
        return `
          <a href="/chat/room/${encodeURIComponent(roomId)}" class="block rounded-xl border border-amber-100 bg-amber-50 px-3 py-2 transition hover:bg-amber-100">
            <div class="flex items-center justify-between gap-2">
              <strong class="text-amber-800">${name}</strong>
              <span class="text-xs font-semibold text-red-700">${wait} min</span>
            </div>
            <div class="mt-1 text-xs text-slate-600">Estado: ${state} | Chamado: ${called}</div>
          </a>
        `;
      }).join('');
    }

    async function refreshPendingHumans() {
      try {
        const response = await fetch('/dashboard/alerts/pending');
        if (!response.ok) return;
        const data = await response.json();
        renderPendingHumans(data.items || []);
      } catch (_err) {}
    }

    refreshPendingHumans();
    setInterval(refreshPendingHumans, 15000);
  </script>
</body>
</html>
