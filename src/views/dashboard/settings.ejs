<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="min-h-dvh text-green-700">
  <div id="sidebarOverlay" class="fixed inset-0 z-20 bg-black/30 opacity-0 pointer-events-none transition"></div>
  <%- include('../partials/sidebar', { user, active: typeof activeNav !== 'undefined' ? activeNav : 'ai' }) %>

  <div>
    <%- include('../partials/topbar', { user, pageTitle: 'Configuracoes' }) %>

    <main class="mx-auto w-full max-w-5xl space-y-5 px-4 py-6 sm:px-6 lg:px-10 lg:py-8">
      <%- include('../components/breadcrumb/index', {
        link: '/dashboard',
        paginaAnterior: 'Dashboard',
        paginaAtual: 'Configuracoes'
      }) %>

      <%- include('./partials/ai-tabs', { aiTab: typeof aiTab !== 'undefined' ? aiTab : 'agent' }) %>

      <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <h1 class="text-xl font-bold text-green-800">Configuracoes gerais</h1>
        <p class="mt-1 text-sm text-gray-500">Ajuste alertas para administradores e controle global da IA atendente.</p>
      </section>

      <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <h2 class="text-lg font-bold text-green-800">Modo IA Atendente</h2>
        <label class="mt-3 flex items-center gap-3 rounded-xl border border-green-100 p-3">
          <input id="aiAttendantEnabled" type="checkbox" class="h-4 w-4 rounded border-gray-300 text-green-600 focus:ring-green-500" <%= settings.aiAttendantEnabled ? 'checked' : '' %>>
          <span class="text-sm font-semibold text-slate-700">Ativar IA no primeiro atendimento do chat</span>
        </label>
        <p class="mt-2 text-xs text-gray-500">Quando desativado, a IA para de responder automaticamente no chat.</p>

        <div class="mt-4 rounded-xl border border-amber-100 bg-amber-50 p-3">
          <label class="flex items-center gap-3">
            <input id="aiBetaModeEnabled" type="checkbox" class="h-4 w-4 rounded border-gray-300 text-green-600 focus:ring-green-500" <%= settings.aiBetaModeEnabled ? 'checked' : '' %>>
            <span class="text-sm font-semibold text-slate-700">Ativar modo beta (somente usuarios selecionados)</span>
          </label>
          <label class="mt-3 block text-sm">
            <span class="mb-1 block font-semibold text-gray-600">Usuarios liberados para IA (ID ou e-mail, 1 por linha)</span>
            <textarea id="aiBetaAllowlist" rows="4" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400" placeholder="user_carol&#10;carol@dev.com"><%= Array.isArray(settings.aiBetaAllowlist) ? settings.aiBetaAllowlist.join('\n') : '' %></textarea>
          </label>
          <p class="mt-2 text-xs text-gray-500">Se o modo beta estiver ativo, apenas os usuarios listados recebem respostas da IA.</p>
        </div>

        <label class="mt-4 flex items-center gap-3 rounded-xl border border-green-100 p-3">
          <input id="kbAutoPublishEnabled" type="checkbox" class="h-4 w-4 rounded border-gray-300 text-green-600 focus:ring-green-500" <%= settings.kbAutoPublishEnabled ? 'checked' : '' %>>
          <span class="text-sm font-semibold text-slate-700">Publicar automaticamente importacoes da Base IA</span>
        </label>
        <p class="mt-2 text-xs text-gray-500">Quando ativo, novos arquivos importados ja entram em producao sem etapa manual de publicar draft.</p>
      </section>

      <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <h2 class="text-lg font-bold text-green-800">Perfil do Agente IA</h2>
        <p class="mt-1 text-sm text-gray-500">Personalize identidade e comportamento da assistente sem editar arquivo de ambiente.</p>
        <div class="mt-3 grid gap-3 sm:grid-cols-2">
          <label class="text-sm">
            <span class="mb-1 block font-semibold text-gray-600">Nome do agente</span>
            <input id="aiAgentName" type="text" value="<%= settings.aiAgentName %>" placeholder="Marina" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
          </label>
          <label class="text-sm">
            <span class="mb-1 block font-semibold text-gray-600">Avatar (URL ou caminho)</span>
            <input id="aiAgentAvatar" type="text" value="<%= settings.aiAgentAvatar %>" placeholder="/images/seta.png" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
          </label>
          <label class="text-sm sm:col-span-2">
            <span class="mb-1 block font-semibold text-gray-600">Prompt de personalidade</span>
            <textarea id="aiPersonalityPrompt" rows="4" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400"><%= settings.aiPersonalityPrompt %></textarea>
          </label>
          <label class="text-sm">
            <span class="mb-1 block font-semibold text-gray-600">Temperatura (0-2)</span>
            <input id="aiTemperature" type="number" min="0" max="2" step="0.05" value="<%= settings.aiTemperature %>" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
          </label>
          <label class="text-sm">
            <span class="mb-1 block font-semibold text-gray-600">Max output tokens</span>
            <input id="aiMaxOutputTokens" type="number" min="64" max="2048" step="1" value="<%= settings.aiMaxOutputTokens %>" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
          </label>
          <label class="text-sm sm:col-span-2">
            <span class="mb-1 block font-semibold text-gray-600">Limite de caracteres da resposta</span>
            <input id="aiMaxReplyChars" type="number" min="120" max="4000" step="1" value="<%= settings.aiMaxReplyChars %>" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
          </label>
        </div>
      </section>

      <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <h2 class="text-lg font-bold text-green-800">Teste de Prompt</h2>
        <p class="mt-1 text-sm text-gray-500">Valide a resposta da IA com as configuracoes atuais antes de salvar em producao.</p>
        <div class="mt-3 grid gap-3">
          <label class="text-sm">
            <span class="mb-1 block font-semibold text-gray-600">Mensagem de teste</span>
            <textarea id="testMessage" rows="3" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">Quero entender melhor o modo estrito.</textarea>
          </label>
          <div class="w-full sm:w-72">
            <%- include('../components/buttons/default', {
              id: 'testPromptBtn',
              label: 'Testar Prompt'
            }) %>
          </div>
          <div id="testPromptResult" class="rounded-xl border border-gray-200 bg-gray-50 p-3 text-sm text-gray-600">
            Nenhum teste executado ainda.
          </div>
        </div>
      </section>

      <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <h2 class="text-lg font-bold text-green-800">Alertas por e-mail</h2>
        <div class="mt-3 grid gap-3 sm:grid-cols-2">
          <label class="text-sm sm:col-span-2">
            <span class="mb-1 block font-semibold text-gray-600">Ativar envio por e-mail</span>
            <input id="alertEmailEnabled" type="checkbox" class="h-4 w-4 rounded border-gray-300 text-green-600 focus:ring-green-500" <%= settings.alertEmailEnabled ? 'checked' : '' %>>
          </label>
          <label class="text-sm sm:col-span-2">
            <span class="mb-1 block font-semibold text-gray-600">Destinatarios (separados por virgula)</span>
            <input id="alertEmailTo" type="text" value="<%= settings.alertEmailTo %>" placeholder="admin@taiksu.com.br,dev@taiksu.com.br" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
          </label>
          <label class="text-sm">
            <span class="mb-1 block font-semibold text-gray-600">Email Service ID</span>
            <input id="alertEmailServiceId" type="number" min="1" value="<%= settings.alertEmailServiceId %>" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
          </label>
          <label class="text-sm">
            <span class="mb-1 block font-semibold text-gray-600">URL da API de e-mail</span>
            <input id="alertEmailApiUrl" type="text" value="<%= settings.alertEmailApiUrl %>" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
          </label>
          <label class="text-sm sm:col-span-2">
            <span class="mb-1 block font-semibold text-gray-600">Token da API de e-mail</span>
            <input id="alertEmailToken" type="password" placeholder="<%= settings.hasAlertEmailToken ? 'Token configurado (digite para substituir)' : 'Cole o token Bearer aqui' %>" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
          </label>
        </div>
      </section>

      <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <div class="flex flex-wrap items-center gap-2">
          <div class="w-full sm:w-72">
            <%- include('../components/buttons/default', {
              id: 'saveSettingsBtn',
              label: 'Salvar Configuracoes'
            }) %>
          </div>
          <span id="settingsStatus" class="text-sm font-semibold text-gray-600">Aguardando alteracoes</span>
        </div>
      </section>
    </main>
  </div>

  <%- include('../partials/sidebar-script') %>
  <script>
    const statusEl = document.getElementById('settingsStatus');

    function setStatus(text, type) {
      const colors = {
        info: 'text-gray-600',
        success: 'text-emerald-700',
        error: 'text-red-700'
      };
      statusEl.textContent = text;
      statusEl.className = `text-sm font-semibold ${colors[type] || colors.info}`;
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    async function saveSettings() {
      const payload = {
        aiAttendantEnabled: document.getElementById('aiAttendantEnabled').checked,
        aiBetaModeEnabled: document.getElementById('aiBetaModeEnabled').checked,
        aiBetaAllowlist: document.getElementById('aiBetaAllowlist').value || '',
        aiAgentName: document.getElementById('aiAgentName').value || '',
        aiAgentAvatar: document.getElementById('aiAgentAvatar').value || '',
        aiPersonalityPrompt: document.getElementById('aiPersonalityPrompt').value || '',
        aiTemperature: Number(document.getElementById('aiTemperature').value || 0.35),
        aiMaxOutputTokens: Number(document.getElementById('aiMaxOutputTokens').value || 360),
        aiMaxReplyChars: Number(document.getElementById('aiMaxReplyChars').value || 520),
        kbAutoPublishEnabled: document.getElementById('kbAutoPublishEnabled').checked,
        alertEmailEnabled: document.getElementById('alertEmailEnabled').checked,
        alertEmailTo: document.getElementById('alertEmailTo').value || '',
        alertEmailServiceId: Number(document.getElementById('alertEmailServiceId').value || 1),
        alertEmailApiUrl: document.getElementById('alertEmailApiUrl').value || '',
        alertEmailToken: document.getElementById('alertEmailToken').value || undefined
      };

      try {
        const response = await fetch('/api/settings', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
          credentials: 'include'
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok) throw new Error(data.error || `Erro HTTP ${response.status}`);
        document.getElementById('alertEmailToken').value = '';
        setStatus('Configuracoes salvas com sucesso', 'success');
      } catch (error) {
        setStatus(error.message, 'error');
      }
    }

    async function testPrompt() {
      const resultBox = document.getElementById('testPromptResult');
      const payload = {
        aiAgentName: document.getElementById('aiAgentName').value || '',
        aiPersonalityPrompt: document.getElementById('aiPersonalityPrompt').value || '',
        aiTemperature: Number(document.getElementById('aiTemperature').value || 0.35),
        aiMaxOutputTokens: Number(document.getElementById('aiMaxOutputTokens').value || 360),
        aiMaxReplyChars: Number(document.getElementById('aiMaxReplyChars').value || 520),
        testMessage: document.getElementById('testMessage').value || ''
      };

      resultBox.className = 'rounded-xl border border-blue-200 bg-blue-50 p-3 text-sm text-blue-700';
      resultBox.textContent = 'Testando prompt...';
      try {
        const response = await fetch('/api/settings/test-prompt', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
          credentials: 'include'
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok || !data.success) throw new Error(data.error || `Erro HTTP ${response.status}`);
        const model = data?.result?.model || '-';
        const provider = data?.result?.provider || '-';
        const latency = Number(data?.result?.latencyMs || 0);
        const reply = String(data?.result?.reply || '').trim() || '(sem resposta)';
        resultBox.className = 'rounded-xl border border-emerald-200 bg-emerald-50 p-3 text-sm text-emerald-800';
        resultBox.innerHTML = `
          <p class="text-xs font-semibold text-emerald-700">Provider: ${escapeHtml(provider)} | Modelo: ${escapeHtml(model)} | Latencia: ${latency}ms</p>
          <p class="mt-2 whitespace-pre-wrap">${escapeHtml(reply)}</p>
        `;
      } catch (error) {
        resultBox.className = 'rounded-xl border border-red-200 bg-red-50 p-3 text-sm text-red-700';
        resultBox.textContent = error.message;
      }
    }

    document.getElementById('saveSettingsBtn').addEventListener('click', saveSettings);
    document.getElementById('testPromptBtn').addEventListener('click', testPrompt);
  </script>
</body>
</html>
