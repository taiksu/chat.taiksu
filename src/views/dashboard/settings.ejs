<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .switch-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      border: 1px solid #d1fae5;
      border-radius: 12px;
      padding: 12px;
      background: #fff;
    }
    .switch-control {
      position: relative;
      width: 44px;
      height: 24px;
      flex: 0 0 auto;
    }
    .switch-control input {
      position: absolute;
      opacity: 0;
      width: 1px;
      height: 1px;
      pointer-events: none;
    }
    .switch-track {
      position: absolute;
      inset: 0;
      border-radius: 999px;
      background: #cbd5e1;
      transition: all .2s ease;
      cursor: pointer;
    }
    .switch-track::after {
      content: '';
      position: absolute;
      top: 2px;
      left: 2px;
      width: 20px;
      height: 20px;
      border-radius: 999px;
      background: #fff;
      box-shadow: 0 1px 3px rgba(0, 0, 0, .24);
      transition: transform .2s ease;
    }
    .switch-control input:checked + .switch-track {
      background: #10b981;
    }
    .switch-control input:checked + .switch-track::after {
      transform: translateX(20px);
    }
    .fold-section > summary {
      list-style: none;
      cursor: pointer;
    }
    .fold-section > summary::-webkit-details-marker {
      display: none;
    }
    .sticky-save {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 40;
      padding: 10px 16px;
      background: linear-gradient(to top, rgba(255, 255, 255, 0.98), rgba(255, 255, 255, 0.86));
      border-top: 1px solid #d1fae5;
      backdrop-filter: blur(3px);
    }
    .settings-subcard {
      border: 1px solid #dcfce7;
      border-radius: 14px;
      background: #f9fffb;
      padding: 12px;
    }
  </style>
</head>
<body class="min-h-dvh text-green-700">
  <div id="sidebarOverlay" class="fixed inset-0 z-20 bg-black/30 opacity-0 pointer-events-none transition"></div>
  <%- include('../partials/sidebar', { user, active: typeof activeNav !== 'undefined' ? activeNav : 'ai' }) %>

  <div>
    <%- include('../partials/topbar', { user, pageTitle: 'IA - Agente' }) %>

    <main class="mx-auto w-full max-w-7xl space-y-5 px-4 py-6 pb-28 sm:px-6 lg:px-10 lg:py-8 lg:pb-32">
      <%- include('../components/breadcrumb/index', {
        link: '/dashboard',
        paginaAnterior: 'Dashboard',
        paginaAtual: 'IA'
      }) %>

      <%- include('./partials/ai-tabs', { aiTab: typeof aiTab !== 'undefined' ? aiTab : 'agent' }) %>

      <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <h1 class="text-xl font-bold text-green-800">Agente da IA</h1>
        <p class="mt-1 text-sm text-gray-500">Configure o atendimento automatico, perfil da assistente e parametros de resposta.</p>
      </section>

      <section class="grid gap-5 xl:grid-cols-12">
        <div class="space-y-5 xl:col-span-7">
          <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
            <h2 class="text-lg font-bold text-green-800">Operacao da IA</h2>
            <p class="mt-1 text-sm text-gray-500">Ative/desative comportamentos principais de atendimento.</p>
            <label class="switch-row mt-3">
              <span class="text-sm font-semibold text-slate-700">Ativar IA no primeiro atendimento do chat</span>
              <span class="switch-control">
                <input id="aiAttendantEnabled" type="checkbox" <%= settings.aiAttendantEnabled ? 'checked' : '' %>>
                <span class="switch-track"></span>
              </span>
            </label>
            <p class="mt-2 text-xs text-gray-500">Quando desativado, a IA para de responder automaticamente no chat.</p>

            <label class="switch-row mt-3">
              <span class="text-sm font-semibold text-slate-700">Permitir que ADMIN converse com a IA no chat</span>
              <span class="switch-control">
                <input id="aiAllowAdminChat" type="checkbox" <%= settings.aiAllowAdminChat ? 'checked' : '' %>>
                <span class="switch-track"></span>
              </span>
            </label>
            <p class="mt-2 text-xs text-gray-500">Quando ativo, usuarios com perfil ADMIN podem trocar mensagens com a IA sem forcar estado HUMANO.</p>

            <label class="switch-row mt-3">
              <span class="text-sm font-semibold text-slate-700">Publicar automaticamente importacoes da Base IA</span>
              <span class="switch-control">
                <input id="kbAutoPublishEnabled" type="checkbox" <%= settings.kbAutoPublishEnabled ? 'checked' : '' %>>
                <span class="switch-track"></span>
              </span>
            </label>
            <p class="mt-2 text-xs text-gray-500">Quando ativo, novos arquivos importados ja entram em producao sem etapa manual de publicar draft.</p>

            <div class="mt-4 rounded-xl border border-amber-100 bg-amber-50 p-3 space-y-2">
              <label class="switch-row border-amber-200">
                <span class="text-sm font-semibold text-slate-700">Ativar modo beta (somente usuarios selecionados)</span>
                <span class="switch-control">
                  <input id="aiBetaModeEnabled" type="checkbox" <%= settings.aiBetaModeEnabled ? 'checked' : '' %>>
                  <span class="switch-track"></span>
                </span>
              </label>
              <label class="mt-3 block text-sm">
                <span class="mb-1 block font-semibold text-gray-600">Usuarios liberados para IA (ID ou e-mail, 1 por linha)</span>
                <textarea id="aiBetaAllowlist" rows="4" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400" placeholder="user_carol&#10;carol@dev.com"><%= Array.isArray(settings.aiBetaAllowlist) ? settings.aiBetaAllowlist.join('\n') : '' %></textarea>
              </label>
              <p class="mt-2 text-xs text-gray-500">Se o modo beta estiver ativo, apenas os usuarios listados recebem respostas da IA.</p>
            </div>
          </section>

          <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
            <h2 class="text-lg font-bold text-green-800">Perfil do Agente IA</h2>
            <p class="mt-1 text-sm text-gray-500">Personalize identidade e comportamento da assistente sem editar arquivo de ambiente.</p>
            <div class="mt-3 grid gap-3 sm:grid-cols-2">
              <label class="text-sm">
                <span class="mb-1 block font-semibold text-gray-600">Nome do agente</span>
                <input id="aiAgentName" type="text" value="<%= settings.aiAgentName %>" placeholder="Marina" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
              </label>
              <label class="text-sm">
                <span class="mb-1 block font-semibold text-gray-600">Avatar (URL ou caminho)</span>
                <input id="aiAgentAvatar" type="text" value="<%= settings.aiAgentAvatar %>" placeholder="/images/marina.png" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
              </label>
              <label class="text-sm sm:col-span-2">
                <span class="mb-1 block font-semibold text-gray-600">Prompt de personalidade</span>
                <textarea id="aiPersonalityPrompt" rows="4" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400"><%= settings.aiPersonalityPrompt %></textarea>
              </label>
              <label class="text-sm">
                <span class="mb-1 block font-semibold text-gray-600">Temperatura (0-2)</span>
                <input id="aiTemperature" type="number" min="0" max="2" step="0.05" value="<%= settings.aiTemperature %>" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
              </label>
              <label class="text-sm">
                <span class="mb-1 block font-semibold text-gray-600">Max output tokens</span>
                <input id="aiMaxOutputTokens" type="number" min="64" max="2048" step="1" value="<%= settings.aiMaxOutputTokens %>" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
              </label>
              <label class="text-sm sm:col-span-2">
                <span class="mb-1 block font-semibold text-gray-600">Limite de caracteres da resposta</span>
                <input id="aiMaxReplyChars" type="number" min="120" max="4000" step="1" value="<%= settings.aiMaxReplyChars %>" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
              </label>
            </div>
          </section>
        </div>

        <div class="space-y-5 xl:col-span-5">
          <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
            <div class="flex flex-wrap items-start justify-between gap-2">
              <div>
                <h2 class="text-lg font-bold text-green-800">Modelo de IA</h2>
                <p class="mt-1 text-sm text-gray-500">Organize modelo principal, transcricao e credenciais em blocos separados.</p>
              </div>
              <button id="reloadModelsBtn" type="button" class="rounded-lg border border-green-200 px-3 py-2 text-xs font-semibold text-green-700 hover:bg-green-50">Atualizar lista</button>
            </div>

            <div class="mt-3 space-y-3">
              <div class="settings-subcard">
                <div class="mb-3">
                  <p class="text-sm font-semibold text-green-900">Modelo principal</p>
                  <p class="text-xs text-gray-500">Define provider e modelo usado no atendimento padrao.</p>
                </div>
                <div class="grid gap-3 sm:grid-cols-2">
                  <label class="text-sm">
                    <span class="mb-1 block font-semibold text-gray-600">Provider padrao</span>
                    <select id="aiPreferredProvider" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
                      <option value="ollama" <%= settings.aiPreferredProvider === 'ollama' ? 'selected' : '' %>>Ollama</option>
                    </select>
                  </label>
                  <label class="text-sm">
                    <span class="mb-1 block font-semibold text-gray-600">Modelo padrao</span>
                    <select id="aiPreferredModel" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
                      <option value="<%= settings.aiPreferredModel %>" selected><%= settings.aiPreferredModel %></option>
                    </select>
                  </label>
                </div>
              </div>

              <div class="settings-subcard">
                <div class="mb-3">
                  <p class="text-sm font-semibold text-green-900">Transcricao de audio</p>
                  <p class="text-xs text-gray-500">Ative STT no widget e configure endpoint/token da API.</p>
                </div>
                <div class="grid gap-3 sm:grid-cols-2">
                  <label class="text-sm">
                    <span class="mb-1 block font-semibold text-gray-600">Provider de transcricao</span>
                    <select id="aiTranscriptionProvider" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
                      <option value="ollama" <%= settings.aiTranscriptionProvider === 'ollama' ? 'selected' : '' %>>Ollama</option>
                    </select>
                  </label>
                  <label class="text-sm">
                    <span class="mb-1 block font-semibold text-gray-600">Ativar transcricao</span>
                    <div class="switch-row">
                      <span class="text-xs font-semibold text-slate-700">Ativar no widget</span>
                      <span class="switch-control">
                        <input id="aiAudioTranscriptionEnabled" type="checkbox" <%= settings.aiAudioTranscriptionEnabled ? 'checked' : '' %>>
                        <span class="switch-track"></span>
                      </span>
                    </div>
                  </label>
                  <label class="text-sm">
                    <span class="mb-1 block font-semibold text-gray-600">Modelo de transcricao</span>
                    <select id="aiTranscriptionModel" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
                      <option value="<%= settings.aiTranscriptionModel %>" selected><%= settings.aiTranscriptionModel || 'Selecione um modelo STT' %></option>
                    </select>
                  </label>
                  <label class="text-sm">
                    <span class="mb-1 block font-semibold text-gray-600">Idioma da transcricao</span>
                    <input id="aiTranscriptionLanguage" type="text" value="<%= settings.aiTranscriptionLanguage || 'pt' %>" placeholder="pt" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
                  </label>
                  <label class="text-sm sm:col-span-2">
                    <span class="mb-1 block font-semibold text-gray-600">Endpoint de transcricao (Whisper)</span>
                    <input id="aiTranscriptionApiUrl" type="text" value="<%= settings.aiTranscriptionApiUrl || '' %>" placeholder="https://whisper.taiksu.com.br/api/transcribe" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
                  </label>
                  <label class="text-sm sm:col-span-2">
                    <span class="mb-1 block font-semibold text-gray-600">Token da API de transcricao</span>
                    <input id="aiTranscriptionApiToken" type="password" placeholder="<%= settings.hasAiTranscriptionApiToken ? 'Token configurado (digite para substituir)' : 'Cole o token Bearer aqui' %>" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
                  </label>
                  <label class="text-sm">
                    <span class="mb-1 block font-semibold text-gray-600">Formato da resposta</span>
                    <input id="aiTranscriptionResponseFormat" type="text" value="<%= settings.aiTranscriptionResponseFormat || 'json' %>" placeholder="json" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
                  </label>
                </div>
              </div>

              <div class="settings-subcard">
                <div class="mb-3">
                  <p class="text-sm font-semibold text-green-900">Autenticacao Ollama</p>
                  <p class="text-xs text-gray-500">Gerencie o token usado para autenticar chamadas no servidor.</p>
                </div>
                <label class="text-sm">
                  <span class="mb-1 block font-semibold text-gray-600">Token da API Ollama</span>
                  <div class="grid gap-2 sm:grid-cols-[1fr_auto_auto] lg:grid-cols-[1fr_auto_auto_auto_auto]">
                    <input id="ollamaApiToken" type="password" placeholder="<%= settings.hasOllamaApiToken ? 'Token configurado (digite para substituir)' : 'Cole o token Bearer ou x-api-key' %>" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
                    <button id="copyOllamaTokenBtn" type="button" class="rounded-lg border border-blue-200 px-3 py-2 text-xs font-semibold text-blue-700 hover:bg-blue-50">Copiar</button>
                    <button id="rotateOllamaTokenBtn" type="button" class="rounded-lg border border-amber-200 px-3 py-2 text-xs font-semibold text-amber-700 hover:bg-amber-50">Rotacionar</button>
                    <button id="generateOllamaTokenBtn" type="button" class="rounded-lg border border-green-200 px-3 py-2 text-xs font-semibold text-green-700 hover:bg-green-50">Gerar token</button>
                    <button id="clearOllamaTokenBtn" type="button" class="rounded-lg border border-red-200 px-3 py-2 text-xs font-semibold text-red-700 hover:bg-red-50">Limpar</button>
                  </div>
                </label>
                <p id="ollamaTokenStatus" class="mt-2 text-xs font-semibold text-gray-500">Salvo no banco/config local. Para ativar no servidor Ollama em nuvem, atualize o mesmo token no lado do agente.</p>
                <div class="mt-2">
                  <p class="text-xs font-semibold text-gray-600">Auditoria de rotacao (recente)</p>
                  <div id="ollamaTokenAudit" class="mt-1 rounded-lg border border-gray-200 bg-gray-50 p-2 text-xs text-gray-600">Carregando historico...</div>
                </div>
              </div>
            </div>
            <div class="mt-3 rounded-xl border border-green-100 bg-green-50 px-3 py-2">
              <p class="text-[11px] font-semibold uppercase tracking-wide text-green-700">Status do catalogo</p>
              <p id="modelsStatus" class="mt-1 text-xs font-semibold text-gray-500">Lista de modelos aguardando atualizacao.</p>
            </div>

            <details class="fold-section mt-3 rounded-xl border border-green-100 bg-green-50 p-3">
              <summary class="flex items-center justify-between text-sm font-semibold text-green-800">
                <span>Configuracoes avancadas de modelos</span>
                <span class="text-xs text-green-600">abrir</span>
              </summary>
              <div class="mt-3 grid gap-3">
                <label class="text-sm">
                  <span class="mb-1 block font-semibold text-gray-600">Adicionar modelo manualmente</span>
                  <div class="grid gap-2 sm:grid-cols-3">
                    <select id="customModelProvider" class="rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
                      <option value="ollama">Ollama</option>
                    </select>
                    <input id="customModelName" type="text" placeholder="qwen2.5:3b-instruct ou llama3.1:8b" class="sm:col-span-2 rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
                  </div>
                  <div class="mt-2 flex flex-wrap gap-2">
                    <button id="addCustomModelBtn" type="button" class="rounded-lg border border-green-200 px-3 py-2 text-xs font-semibold text-green-700 hover:bg-green-50">Adicionar no cadastro</button>
                    <span class="text-xs text-gray-500">Formato salvo: provider:modelo</span>
                  </div>
                </label>
                <label class="text-sm">
                  <span class="mb-1 block font-semibold text-gray-600">Modelos customizados (1 por linha, formato provider:modelo)</span>
                  <textarea id="aiCustomModels" rows="4" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400" placeholder="ollama:qwen2.5:3b-instruct&#10;ollama:llama3.1:8b"><%= Array.isArray(settings.aiCustomModels) ? settings.aiCustomModels.join('\n') : '' %></textarea>
                </label>
              </div>
            </details>
          </section>

          <details class="fold-section rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
            <summary class="flex items-center justify-between">
              <div>
                <h2 class="text-lg font-bold text-green-800">Teste de Prompt</h2>
                <p class="mt-1 text-sm text-gray-500">Valide a resposta da IA antes de salvar em producao.</p>
              </div>
              <span class="text-xs font-semibold text-green-700">abrir</span>
            </summary>
            <div class="mt-3 grid gap-3">
              <label class="text-sm">
                <span class="mb-1 block font-semibold text-gray-600">Mensagem de teste</span>
                <textarea id="testMessage" rows="3" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">Quero entender melhor o modo estrito.</textarea>
              </label>
              <div class="w-full sm:w-72">
                <button id="testPromptBtn" type="button" class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-emerald-700 sm:w-auto">Testar Prompt</button>
              </div>
              <div id="testPromptResult" class="rounded-xl border border-gray-200 bg-gray-50 p-3 text-sm text-gray-600">
                Nenhum teste executado ainda.
              </div>
            </div>
          </details>

          <details class="fold-section rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
            <summary class="flex items-center justify-between">
              <div>
                <h2 class="text-lg font-bold text-green-800">Alertas por e-mail</h2>
                <p class="mt-1 text-sm text-gray-500">Configuracoes de notificacao para eventos importantes.</p>
              </div>
              <span class="text-xs font-semibold text-green-700">abrir</span>
            </summary>
            <div class="mt-3 grid gap-3 sm:grid-cols-2">
              <label class="text-sm sm:col-span-2">
                <div class="switch-row">
                  <span class="font-semibold text-gray-600">Ativar envio por e-mail</span>
                  <span class="switch-control">
                    <input id="alertEmailEnabled" type="checkbox" <%= settings.alertEmailEnabled ? 'checked' : '' %>>
                    <span class="switch-track"></span>
                  </span>
                </div>
              </label>
              <label class="text-sm sm:col-span-2">
                <span class="mb-1 block font-semibold text-gray-600">Destinatarios (separados por virgula)</span>
                <input id="alertEmailTo" type="text" value="<%= settings.alertEmailTo %>" placeholder="admin@taiksu.com.br,dev@taiksu.com.br" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
              </label>
              <label class="text-sm">
                <span class="mb-1 block font-semibold text-gray-600">Email Service ID</span>
                <input id="alertEmailServiceId" type="number" min="1" value="<%= settings.alertEmailServiceId %>" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
              </label>
              <label class="text-sm">
                <span class="mb-1 block font-semibold text-gray-600">URL da API de e-mail</span>
                <input id="alertEmailApiUrl" type="text" value="<%= settings.alertEmailApiUrl %>" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
              </label>
              <label class="text-sm sm:col-span-2">
                <span class="mb-1 block font-semibold text-gray-600">Token da API de e-mail</span>
                <input id="alertEmailToken" type="password" placeholder="<%= settings.hasAlertEmailToken ? 'Token configurado (digite para substituir)' : 'Cole o token Bearer aqui' %>" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
              </label>
            </div>
          </details>
        </div>
      </section>
    </main>
  </div>

  <div class="sticky-save">
    <div class="mx-auto flex w-full max-w-7xl items-center justify-between gap-3 rounded-xl border border-green-100 bg-white px-3 py-2 shadow-sm">
      <span id="settingsStatus" class="text-sm font-semibold text-gray-600">Aguardando alteracoes</span>
      <button id="saveSettingsBtn" type="button" class="inline-flex items-center justify-center rounded-xl bg-emerald-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-emerald-700">Salvar Configuracoes</button>
    </div>
  </div>

  <%- include('../partials/sidebar-script') %>
  <script>
    const statusEl = document.getElementById('settingsStatus');
    const modelsStatusEl = document.getElementById('modelsStatus');
    const providerEl = document.getElementById('aiPreferredProvider');
    const modelEl = document.getElementById('aiPreferredModel');
    const transcriptionProviderEl = document.getElementById('aiTranscriptionProvider');
    const transcriptionModelEl = document.getElementById('aiTranscriptionModel');
    const transcriptionApiUrlEl = document.getElementById('aiTranscriptionApiUrl');
    const transcriptionApiTokenEl = document.getElementById('aiTranscriptionApiToken');
    const transcriptionLanguageEl = document.getElementById('aiTranscriptionLanguage');
    const transcriptionResponseFormatEl = document.getElementById('aiTranscriptionResponseFormat');
    const ollamaApiTokenEl = document.getElementById('ollamaApiToken');
    const ollamaTokenStatusEl = document.getElementById('ollamaTokenStatus');
    const ollamaTokenAuditEl = document.getElementById('ollamaTokenAudit');
    let ollamaTokenDirty = false;
    let transcriptionTokenDirty = false;
    let providerModels = { ollama: [] };

    function setStatus(text, type) {
      const colors = {
        info: 'text-gray-600',
        success: 'text-emerald-700',
        error: 'text-red-700'
      };
      statusEl.textContent = text;
      statusEl.className = `text-sm font-semibold ${colors[type] || colors.info}`;
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function setModelsStatus(text, type) {
      const colors = {
        info: 'text-gray-500',
        success: 'text-emerald-700',
        error: 'text-red-700'
      };
      modelsStatusEl.textContent = text;
      modelsStatusEl.className = `mt-2 text-xs font-semibold ${colors[type] || colors.info}`;
    }

    function uniqueModels(models) {
      return Array.from(new Set((models || []).map((item) => String(item || '').trim()).filter(Boolean)));
    }

    function setOllamaTokenStatus(text, type = 'info') {
      const colors = {
        info: 'text-gray-500',
        success: 'text-emerald-700',
        error: 'text-red-700'
      };
      ollamaTokenStatusEl.textContent = text;
      ollamaTokenStatusEl.className = `text-xs font-semibold ${colors[type] || colors.info}`;
    }

    function renderOllamaTokenAudit(items) {
      const rows = Array.isArray(items) ? items : [];
      if (!rows.length) {
        ollamaTokenAuditEl.innerHTML = '<p>Nenhuma rotacao registrada ainda.</p>';
        return;
      }
      ollamaTokenAuditEl.innerHTML = rows.map((entry) => {
        const when = entry?.timestamp
          ? new Date(entry.timestamp).toLocaleString('pt-BR')
          : '-';
        const actor = String(entry?.actorName || entry?.actorId || 'sistema');
        const source = String(entry?.source || 'n/a');
        return `<p>${escapeHtml(when)} | ${escapeHtml(actor)} | ${escapeHtml(source)}</p>`;
      }).join('');
    }

    async function loadOllamaTokenAudit() {
      try {
        const response = await fetch('/api/settings/ollama-token/audit?limit=8', {
          method: 'GET',
          credentials: 'include'
        });
        const data = await parseApiJson(response);
        if (!response.ok || !data.success) throw new Error(data.error || `Erro HTTP ${response.status}`);
        renderOllamaTokenAudit(data.items || []);
      } catch (error) {
        ollamaTokenAuditEl.innerHTML = `<p class="text-red-700">${escapeHtml(error.message)}</p>`;
      }
    }

    async function parseApiJson(response) {
      const data = await response.json().catch(() => ({}));
      if (response.status === 401 && data?.redirect) {
        window.location.href = data.redirect;
        throw new Error('Sessao expirada. Redirecionando para login...');
      }
      return data;
    }

    function generateRandomTokenHex(lengthBytes = 32) {
      const bytes = new Uint8Array(lengthBytes);
      if (window.crypto && typeof window.crypto.getRandomValues === 'function') {
        window.crypto.getRandomValues(bytes);
      } else {
        for (let i = 0; i < bytes.length; i += 1) {
          bytes[i] = Math.floor(Math.random() * 256);
        }
      }
      return Array.from(bytes).map((value) => value.toString(16).padStart(2, '0')).join('');
    }

    function parseCustomModels(rawValue) {
      const lines = String(rawValue || '')
        .split(/\r?\n|[,;]+/g)
        .map((line) => String(line || '').trim())
        .filter(Boolean);
      const byProvider = { ollama: [] };
      lines.forEach((entry) => {
        const idx = entry.indexOf(':');
        if (idx <= 0) return;
        const provider = String(entry.slice(0, idx) || '').trim().toLowerCase();
        const model = String(entry.slice(idx + 1) || '').trim();
        if (!model) return;
        if (provider === 'ollama') {
          byProvider[provider].push(model);
        }
      });
      byProvider.ollama = uniqueModels(byProvider.ollama);
      return byProvider;
    }

    function renderModelOptions(preferredModel) {
      const provider = providerEl.value;
      const custom = parseCustomModels(document.getElementById('aiCustomModels').value || '');
      const catalog = uniqueModels([...(providerModels[provider] || []), ...(custom[provider] || [])]);
      modelEl.innerHTML = '';
      catalog.forEach((modelName) => {
        const option = document.createElement('option');
        option.value = modelName;
        option.textContent = modelName;
        modelEl.appendChild(option);
      });

      const targetModel = String(preferredModel || modelEl.value || '').trim();
      if (targetModel && !catalog.includes(targetModel)) {
        const option = document.createElement('option');
        option.value = targetModel;
        option.textContent = `${targetModel} (manual)`;
        modelEl.appendChild(option);
      }
      if (targetModel) modelEl.value = targetModel;
    }

    function renderTranscriptionModelOptions(preferredModel) {
      const provider = transcriptionProviderEl.value;
      const custom = parseCustomModels(document.getElementById('aiCustomModels').value || '');
      const catalog = uniqueModels([...(providerModels[provider] || []), ...(custom[provider] || [])]);
      transcriptionModelEl.innerHTML = '';
      catalog.forEach((modelName) => {
        const option = document.createElement('option');
        option.value = modelName;
        option.textContent = modelName;
        transcriptionModelEl.appendChild(option);
      });

      const targetModel = String(preferredModel || transcriptionModelEl.value || '').trim();
      if (targetModel && !catalog.includes(targetModel)) {
        const option = document.createElement('option');
        option.value = targetModel;
        option.textContent = `${targetModel} (manual)`;
        transcriptionModelEl.appendChild(option);
      }
      if (targetModel) transcriptionModelEl.value = targetModel;
    }

    async function refreshModelCatalog() {
      setModelsStatus('Carregando modelos disponiveis...', 'info');
      try {
        const response = await fetch('/api/settings/ai-models', {
          method: 'GET',
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
          credentials: 'include'
        });
        const data = await parseApiJson(response);
        if (!response.ok || !data.success) throw new Error(data.error || `Erro HTTP ${response.status}`);
        providerModels = { ollama: [] };
        (Array.isArray(data.providers) ? data.providers : []).forEach((entry) => {
          if (!entry || !entry.provider) return;
          providerModels[entry.provider] = uniqueModels(entry.models || []);
        });
        if (data?.selected?.provider) providerEl.value = data.selected.provider;
        renderModelOptions(data?.selected?.model || modelEl.value);
        renderTranscriptionModelOptions(transcriptionModelEl.value);
        const warn = (Array.isArray(data.providers) ? data.providers : [])
          .map((entry) => entry?.error ? `${entry.provider}: ${entry.error}` : '')
          .filter(Boolean);
        if (warn.length) {
          setModelsStatus(`Modelos carregados com alertas (${warn.join(' | ')})`, 'error');
        } else {
          setModelsStatus('Modelos carregados automaticamente com sucesso.', 'success');
        }
      } catch (error) {
        renderModelOptions(modelEl.value);
        renderTranscriptionModelOptions(transcriptionModelEl.value);
        setModelsStatus(`Falha ao carregar modelos automaticamente: ${error.message}`, 'error');
      }
    }

    async function saveSettings() {
      const ollamaTokenPayload = ollamaTokenDirty ? String(ollamaApiTokenEl.value || '').trim() : undefined;
      const transcriptionTokenPayload = transcriptionTokenDirty ? String(transcriptionApiTokenEl.value || '').trim() : undefined;
      const payload = {
        aiAttendantEnabled: document.getElementById('aiAttendantEnabled').checked,
        aiAllowAdminChat: document.getElementById('aiAllowAdminChat').checked,
        aiBetaModeEnabled: document.getElementById('aiBetaModeEnabled').checked,
        aiBetaAllowlist: document.getElementById('aiBetaAllowlist').value || '',
        aiAgentName: document.getElementById('aiAgentName').value || '',
        aiAgentAvatar: document.getElementById('aiAgentAvatar').value || '',
        aiPersonalityPrompt: document.getElementById('aiPersonalityPrompt').value || '',
        aiTemperature: Number(document.getElementById('aiTemperature').value || 0.35),
        aiMaxOutputTokens: Number(document.getElementById('aiMaxOutputTokens').value || 360),
        aiMaxReplyChars: Number(document.getElementById('aiMaxReplyChars').value || 520),
        aiPreferredProvider: providerEl.value || 'ollama',
        aiPreferredModel: modelEl.value || '',
        aiTranscriptionProvider: transcriptionProviderEl.value || 'ollama',
        aiTranscriptionModel: transcriptionModelEl.value || '',
        aiAudioTranscriptionEnabled: document.getElementById('aiAudioTranscriptionEnabled').checked,
        aiTranscriptionApiUrl: transcriptionApiUrlEl.value || '',
        aiTranscriptionApiToken: transcriptionTokenPayload,
        aiTranscriptionLanguage: transcriptionLanguageEl.value || 'pt',
        aiTranscriptionResponseFormat: transcriptionResponseFormatEl.value || 'json',
        aiCustomModels: document.getElementById('aiCustomModels').value || '',
        kbAutoPublishEnabled: document.getElementById('kbAutoPublishEnabled').checked,
        alertEmailEnabled: document.getElementById('alertEmailEnabled').checked,
        alertEmailTo: document.getElementById('alertEmailTo').value || '',
        alertEmailServiceId: Number(document.getElementById('alertEmailServiceId').value || 1),
        alertEmailApiUrl: document.getElementById('alertEmailApiUrl').value || '',
        alertEmailToken: document.getElementById('alertEmailToken').value || undefined,
        ollamaApiToken: ollamaTokenPayload
      };

      try {
        const response = await fetch('/api/settings', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
          credentials: 'include'
        });
        const data = await parseApiJson(response);
        if (!response.ok) throw new Error(data.error || `Erro HTTP ${response.status}`);
        document.getElementById('alertEmailToken').value = '';
        ollamaApiTokenEl.value = '';
        ollamaTokenDirty = false;
        transcriptionApiTokenEl.value = '';
        transcriptionTokenDirty = false;
        loadOllamaTokenAudit();
        setStatus('Configuracoes salvas com sucesso', 'success');
      } catch (error) {
        setStatus(error.message, 'error');
      }
    }

    async function testPrompt() {
      const resultBox = document.getElementById('testPromptResult');
      const payload = {
        aiAgentName: document.getElementById('aiAgentName').value || '',
        aiPersonalityPrompt: document.getElementById('aiPersonalityPrompt').value || '',
        aiTemperature: Number(document.getElementById('aiTemperature').value || 0.35),
        aiMaxOutputTokens: Number(document.getElementById('aiMaxOutputTokens').value || 360),
        aiMaxReplyChars: Number(document.getElementById('aiMaxReplyChars').value || 520),
        aiPreferredProvider: providerEl.value || 'ollama',
        aiPreferredModel: modelEl.value || '',
        testMessage: document.getElementById('testMessage').value || ''
      };

      resultBox.className = 'rounded-xl border border-blue-200 bg-blue-50 p-3 text-sm text-blue-700';
      resultBox.textContent = 'Testando prompt...';
      try {
        const response = await fetch('/api/settings/test-prompt', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
          credentials: 'include'
        });
        const data = await parseApiJson(response);
        if (!response.ok || !data.success) throw new Error(data.error || `Erro HTTP ${response.status}`);
        const model = data?.result?.model || '-';
        const provider = data?.result?.provider || '-';
        const latency = Number(data?.result?.latencyMs || 0);
        const reply = String(data?.result?.reply || '').trim() || '(sem resposta)';
        resultBox.className = 'rounded-xl border border-emerald-200 bg-emerald-50 p-3 text-sm text-emerald-800';
        resultBox.innerHTML = `
          <p class="text-xs font-semibold text-emerald-700">Provider: ${escapeHtml(provider)} | Modelo: ${escapeHtml(model)} | Latencia: ${latency}ms</p>
          <p class="mt-2 whitespace-pre-wrap">${escapeHtml(reply)}</p>
        `;
      } catch (error) {
        resultBox.className = 'rounded-xl border border-red-200 bg-red-50 p-3 text-sm text-red-700';
        resultBox.textContent = error.message;
      }
    }

    document.getElementById('saveSettingsBtn').addEventListener('click', (event) => {
      event.preventDefault();
      event.stopPropagation();
      saveSettings();
    });
    document.getElementById('testPromptBtn').addEventListener('click', (event) => {
      event.preventDefault();
      event.stopPropagation();
      testPrompt();
    });
    document.getElementById('reloadModelsBtn').addEventListener('click', (event) => {
      event.preventDefault();
      event.stopPropagation();
      refreshModelCatalog();
    });
    ollamaApiTokenEl.addEventListener('input', () => {
      ollamaTokenDirty = true;
    });
    transcriptionApiTokenEl.addEventListener('input', () => {
      transcriptionTokenDirty = true;
    });
    document.getElementById('copyOllamaTokenBtn').addEventListener('click', async (event) => {
      event.preventDefault();
      event.stopPropagation();
      const token = String(ollamaApiTokenEl.value || '').trim();
      if (!token) {
        setOllamaTokenStatus('Nao ha token no campo para copiar.', 'error');
        return;
      }
      try {
        await navigator.clipboard.writeText(token);
        setOllamaTokenStatus('Token copiado para a area de transferencia.', 'success');
      } catch (_err) {
        setOllamaTokenStatus('Falha ao copiar token. Copie manualmente.', 'error');
      }
    });
    document.getElementById('rotateOllamaTokenBtn').addEventListener('click', async (event) => {
      event.preventDefault();
      event.stopPropagation();
      setOllamaTokenStatus('Rotacionando token no servidor...', 'info');
      try {
        const response = await fetch('/api/settings/ollama-token/rotate', {
          method: 'POST',
          credentials: 'include'
        });
        const data = await parseApiJson(response);
        if (!response.ok || !data.success) throw new Error(data.error || `Erro HTTP ${response.status}`);
        ollamaApiTokenEl.value = String(data.token || '').trim();
        ollamaTokenDirty = false;
        renderOllamaTokenAudit(data.recent || []);
        setOllamaTokenStatus('Token rotacionado com sucesso. Copie e atualize o servidor do agente.', 'success');
      } catch (error) {
        setOllamaTokenStatus(error.message, 'error');
      }
    });
    document.getElementById('generateOllamaTokenBtn').addEventListener('click', (event) => {
      event.preventDefault();
      event.stopPropagation();
      ollamaApiTokenEl.value = generateRandomTokenHex(32);
      ollamaTokenDirty = true;
      setOllamaTokenStatus('Novo token gerado localmente. Clique em Salvar Configuracoes para persistir.', 'info');
    });
    document.getElementById('clearOllamaTokenBtn').addEventListener('click', (event) => {
      event.preventDefault();
      event.stopPropagation();
      ollamaApiTokenEl.value = '';
      ollamaTokenDirty = true;
      setOllamaTokenStatus('Token Ollama limpo no formulario. Clique em Salvar Configuracoes para persistir.', 'info');
    });
    providerEl.addEventListener('change', () => renderModelOptions(modelEl.value));
    transcriptionProviderEl.addEventListener('change', () => renderTranscriptionModelOptions(transcriptionModelEl.value));
    document.getElementById('aiCustomModels').addEventListener('input', () => {
      renderModelOptions(modelEl.value);
      renderTranscriptionModelOptions(transcriptionModelEl.value);
    });
    document.getElementById('addCustomModelBtn').addEventListener('click', (event) => {
      event.preventDefault();
      event.stopPropagation();
      const provider = document.getElementById('customModelProvider').value || 'ollama';
      const model = String(document.getElementById('customModelName').value || '').trim();
      if (!model) {
        setModelsStatus('Informe o nome do modelo para adicionar.', 'error');
        return;
      }
      const textarea = document.getElementById('aiCustomModels');
      const line = `${provider}:${model}`;
      const lines = String(textarea.value || '')
        .split(/\r?\n/g)
        .map((item) => String(item || '').trim())
        .filter(Boolean);
      if (!lines.includes(line)) lines.push(line);
      textarea.value = lines.join('\n');
      renderModelOptions(model);
      renderTranscriptionModelOptions(model);
      document.getElementById('customModelName').value = '';
      setModelsStatus(`Modelo ${line} adicionado no cadastro local. Salve para persistir.`, 'success');
    });
    loadOllamaTokenAudit();
    refreshModelCatalog();
  </script>
</body>
</html>
