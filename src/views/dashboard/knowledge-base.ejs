<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .kb-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
    }
    @media (min-width: 1024px) {
      .kb-grid { grid-template-columns: 360px 1fr; }
    }
  </style>
</head>
<body class="min-h-dvh text-green-700">
  <div id="sidebarOverlay" class="fixed inset-0 z-20 bg-black/30 opacity-0 pointer-events-none transition"></div>
  <%- include('../partials/sidebar', { user, active: 'knowledge' }) %>

  <div>
    <%- include('../partials/topbar', { user, pageTitle: 'Base de Conhecimento IA' }) %>

    <main class="mx-auto w-full max-w-7xl space-y-5 px-4 py-6 sm:px-6 lg:px-10 lg:py-8">
      <%- include('../components/breadcrumb/index', {
        link: '/dashboard',
        paginaAnterior: 'Dashboard',
        paginaAtual: 'Base IA'
      }) %>

      <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <h1 class="text-xl font-bold text-green-800">Fluxo de curadoria da IA</h1>
        <p class="mt-1 text-sm text-gray-500">Importe o Markdown, revise os blocos gerados e publique apenas o que estiver validado.</p>

        <div class="mt-4 grid gap-3 sm:grid-cols-3">
          <div class="rounded-xl border border-green-100 bg-green-50 px-3 py-2">
            <p class="text-xs font-semibold text-green-700">1. Importar</p>
            <p class="text-xs text-gray-600">Arquivo `.md` vira draft estruturado.</p>
          </div>
          <div class="rounded-xl border border-blue-100 bg-blue-50 px-3 py-2">
            <p class="text-xs font-semibold text-blue-700">2. Revisar</p>
            <p class="text-xs text-gray-600">Edite título, conteúdo, tags e URL.</p>
          </div>
          <div class="rounded-xl border border-amber-100 bg-amber-50 px-3 py-2">
            <p class="text-xs font-semibold text-amber-700">3. Publicar</p>
            <p class="text-xs text-gray-600">Substitui a base ativa e gera backup.</p>
          </div>
        </div>
      </section>

      <section class="kb-grid">
        <article class="space-y-4">
          <div class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
            <h2 class="text-base font-bold text-green-800">Resumo</h2>
            <div class="mt-3 grid gap-2">
              <div class="rounded-lg border border-green-100 bg-green-50 px-3 py-2">
                <p class="text-[11px] font-semibold text-green-700">Draft atual</p>
                <p id="draftCount" class="text-lg font-bold text-green-800"><%= draftCount %></p>
              </div>
              <div class="rounded-lg border border-blue-100 bg-blue-50 px-3 py-2">
                <p class="text-[11px] font-semibold text-blue-700">Base publicada</p>
                <p id="liveCount" class="text-lg font-bold text-blue-800"><%= liveCount %></p>
              </div>
              <div class="rounded-lg border border-gray-200 bg-gray-50 px-3 py-2">
                <p class="text-[11px] font-semibold text-gray-700">Status</p>
                <p id="statusText" class="text-sm font-semibold text-gray-700">Aguardando ação</p>
              </div>
            </div>
          </div>

          <div class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
            <h2 class="text-base font-bold text-green-800">Importar Markdown</h2>
            <form id="importForm" class="mt-3 space-y-3">
              <input id="mdFile" name="file" type="file" accept=".md,text/markdown" class="block w-full rounded-xl border border-green-200 bg-white px-3 py-2 text-sm text-green-800">
              <%- include('../components/buttons/default', {
                id: 'importBtn',
                label: 'Importar Arquivo'
              }) %>
            </form>
          </div>

          <div class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm space-y-2">
            <h2 class="text-base font-bold text-green-800">Ações do draft</h2>
            <%- include('../components/buttons/default', {
              id: 'publishBtn',
              label: 'Publicar Draft'
            }) %>
            <%- include('../components/buttons/default', {
              id: 'clearBtn',
              label: 'Limpar Draft'
            }) %>
          </div>
        </article>

        <article class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
          <div class="flex flex-wrap items-center gap-2">
            <h2 class="text-base font-bold text-green-800">Itens do draft</h2>
            <span id="resultCount" class="rounded-full bg-green-50 px-2 py-1 text-xs font-semibold text-green-700">0 itens</span>
            <button id="refreshBtn" type="button" class="ml-auto rounded-lg border border-green-300 bg-white px-3 py-1.5 text-xs font-semibold text-green-700 hover:bg-green-50">Atualizar</button>
          </div>

          <div class="mt-3 grid gap-2 sm:grid-cols-2">
            <input id="searchInput" placeholder="Buscar por titulo, conteúdo ou tags..." class="rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
            <select id="intentFilter" class="rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
              <option value="">Todos os intents</option>
              <option value="abrir_chamado">abrir_chamado</option>
              <option value="falar_humano">falar_humano</option>
              <option value="status_chamado">status_chamado</option>
              <option value="enviar_anexo">enviar_anexo</option>
              <option value="geral">geral</option>
            </select>
          </div>

          <div id="draftList" class="mt-4 space-y-3"></div>
        </article>
      </section>
    </main>
  </div>

  <%- include('../partials/sidebar-script') %>

  <script>
    const draftCountEl = document.getElementById('draftCount');
    const liveCountEl = document.getElementById('liveCount');
    const statusTextEl = document.getElementById('statusText');
    const resultCountEl = document.getElementById('resultCount');
    const draftListEl = document.getElementById('draftList');
    const mdFileEl = document.getElementById('mdFile');
    const searchInputEl = document.getElementById('searchInput');
    const intentFilterEl = document.getElementById('intentFilter');
    let draftItems = [];

    function setStatus(text, type) {
      const palette = {
        info: 'text-blue-700',
        success: 'text-emerald-700',
        warn: 'text-amber-700',
        error: 'text-red-700'
      };
      statusTextEl.textContent = text;
      statusTextEl.className = `text-sm font-semibold ${palette[type] || palette.info}`;
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    async function fetchJson(url, init) {
      const response = await fetch(url, init);
      const data = await response.json().catch(() => ({}));
      if (!response.ok) throw new Error(data.error || `Falha HTTP ${response.status}`);
      return data;
    }

    function filterDraftItems(items) {
      const query = String(searchInputEl.value || '').trim().toLowerCase();
      const intent = String(intentFilterEl.value || '').trim();
      return items.filter((item) => {
        const byIntent = !intent || String(item.intent || '') === intent;
        if (!byIntent) return false;
        if (!query) return true;
        const haystack = [
          item.id,
          item.title,
          item.content,
          Array.isArray(item.tags) ? item.tags.join(' ') : '',
          item.url
        ].join(' ').toLowerCase();
        return haystack.includes(query);
      });
    }

    function buildCard(item) {
      const tags = Array.isArray(item.tags) ? item.tags.join(', ') : '';
      return `
        <article class="rounded-xl border border-gray-200 p-3">
          <div class="flex items-start justify-between gap-2">
            <div>
              <p class="text-xs font-semibold text-gray-500">${escapeHtml(item.id)}</p>
              <p class="text-sm font-bold text-green-800">${escapeHtml(item.title || 'Sem título')}</p>
            </div>
            <span class="rounded-full bg-gray-100 px-2 py-0.5 text-[11px] font-semibold text-gray-700">${escapeHtml(item.intent || 'geral')}</span>
          </div>
          <div class="mt-3 grid gap-2">
            <input data-id="${escapeHtml(item.id)}" data-field="title" value="${escapeHtml(item.title)}" class="rounded-lg border border-gray-200 px-2 py-1 text-xs">
            <textarea data-id="${escapeHtml(item.id)}" data-field="content" rows="4" class="rounded-lg border border-gray-200 px-2 py-1 text-xs">${escapeHtml(item.content)}</textarea>
            <input data-id="${escapeHtml(item.id)}" data-field="tags" value="${escapeHtml(tags)}" class="rounded-lg border border-gray-200 px-2 py-1 text-xs" placeholder="tag1, tag2">
            <input data-id="${escapeHtml(item.id)}" data-field="url" value="${escapeHtml(item.url || '')}" class="rounded-lg border border-gray-200 px-2 py-1 text-xs" placeholder="https://...">
          </div>
          <div class="mt-3 flex gap-2">
            <button type="button" class="rounded-lg border border-emerald-300 bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-800" onclick="saveItem('${escapeHtml(item.id)}')">Salvar</button>
            <button type="button" class="rounded-lg border border-red-300 bg-red-50 px-3 py-1 text-xs font-semibold text-red-700" onclick="removeItem('${escapeHtml(item.id)}')">Excluir</button>
          </div>
        </article>
      `;
    }

    function renderDraftList() {
      const visible = filterDraftItems(draftItems);
      resultCountEl.textContent = `${visible.length} itens`;
      if (!visible.length) {
        draftListEl.innerHTML = '<p class="text-sm text-gray-500">Nenhum item encontrado no filtro atual.</p>';
        return;
      }
      draftListEl.innerHTML = visible.map(buildCard).join('');
    }

    async function refreshData() {
      const [draft, live] = await Promise.all([
        fetchJson('/api/kb/draft'),
        fetchJson('/api/kb/live')
      ]);
      draftItems = Array.isArray(draft.items) ? draft.items : [];
      draftCountEl.textContent = String(draftItems.length);
      liveCountEl.textContent = String((live.items || []).length);
      renderDraftList();
    }

    window.saveItem = async function saveItem(itemId) {
      try {
        const fields = Array.from(document.querySelectorAll('[data-id]'))
          .filter((el) => String(el.dataset.id || '') === String(itemId));
        const payload = {};
        fields.forEach((el) => {
          if (el.dataset.field === 'tags') {
            payload.tags = String(el.value || '').split(',').map((tag) => tag.trim()).filter(Boolean);
          } else {
            payload[el.dataset.field] = el.value;
          }
        });
        await fetchJson(`/api/kb/draft/${encodeURIComponent(itemId)}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        setStatus(`Item ${itemId} salvo`, 'success');
        await refreshData();
      } catch (error) {
        setStatus(error.message, 'error');
      }
    };

    window.removeItem = async function removeItem(itemId) {
      if (!confirm(`Excluir item ${itemId}?`)) return;
      try {
        await fetchJson(`/api/kb/draft/${encodeURIComponent(itemId)}`, { method: 'DELETE' });
        setStatus(`Item ${itemId} removido`, 'warn');
        await refreshData();
      } catch (error) {
        setStatus(error.message, 'error');
      }
    };

    document.getElementById('importForm').addEventListener('submit', async (event) => {
      event.preventDefault();
      const file = mdFileEl.files && mdFileEl.files[0];
      if (!file) {
        setStatus('Selecione um arquivo .md', 'error');
        return;
      }
      try {
        const formData = new FormData();
        formData.append('file', file);
        const result = await fetchJson('/api/kb/import-md', { method: 'POST', body: formData });
        setStatus(`Importação concluída: ${result.imported} itens`, 'success');
        await refreshData();
      } catch (error) {
        setStatus(error.message, 'error');
      }
    });

    document.getElementById('importBtn').addEventListener('click', () => {
      const form = document.getElementById('importForm');
      if (typeof form.requestSubmit === 'function') form.requestSubmit();
      else form.dispatchEvent(new Event('submit', { cancelable: true, bubbles: true }));
    });

    document.getElementById('publishBtn').addEventListener('click', async () => {
      if (!confirm('Publicar o draft na base oficial?')) return;
      try {
        const result = await fetchJson('/api/kb/publish', { method: 'POST' });
        setStatus(`Publicado com sucesso (${result.published} itens)`, 'success');
        await refreshData();
      } catch (error) {
        setStatus(error.message, 'error');
      }
    });

    document.getElementById('clearBtn').addEventListener('click', async () => {
      if (!confirm('Limpar todo o draft?')) return;
      try {
        await fetchJson('/api/kb/draft', { method: 'DELETE' });
        setStatus('Draft limpo', 'warn');
        await refreshData();
      } catch (error) {
        setStatus(error.message, 'error');
      }
    });

    document.getElementById('refreshBtn').addEventListener('click', async () => {
      try {
        await refreshData();
        setStatus('Lista atualizada', 'info');
      } catch (error) {
        setStatus(error.message, 'error');
      }
    });

    searchInputEl.addEventListener('input', renderDraftList);
    intentFilterEl.addEventListener('change', renderDraftList);

    refreshData().catch((error) => setStatus(error.message, 'error'));
  </script>
</body>
</html>
