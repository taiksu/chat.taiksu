<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .qa-msg-own { justify-content: flex-end; }
    .qa-msg-other { justify-content: flex-start; }
    .qa-bubble-own { background: #bbf7d0; border-radius: 16px 16px 4px 16px; }
    .qa-bubble-other { background: #ffffff; border-radius: 16px 16px 16px 4px; }
  </style>
</head>
<body class="min-h-dvh text-green-700">
  <div id="sidebarOverlay" class="fixed inset-0 z-20 bg-black/30 opacity-0 pointer-events-none transition"></div>
  <%- include('../partials/sidebar', { user, active: 'qa' }) %>

  <div>
    <%- include('../partials/topbar', {
      user,
      pageTitle: 'Laboratorio QA do Chat'
    }) %>

    <main class="mx-auto w-full max-w-7xl space-y-5 px-4 py-6 sm:px-6 lg:px-10 lg:py-8">
      <%- include('../components/breadcrumb/index', {
        link: '/dashboard',
        paginaAnterior: 'Dashboard',
        paginaAtual: 'Laboratorio QA'
      }) %>
      <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <div class="flex flex-wrap items-end gap-3">
          <label class="min-w-[260px] flex-1 text-sm">
            <span class="mb-1 block font-semibold text-gray-500">Sala para auditoria</span>
            <select id="roomPicker" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
              <% rooms.forEach((room) => { %>
                <option value="<%= room.id %>" <%= selectedRoomId === room.id ? 'selected' : '' %>>
                  [<%= room.roomType === 'chamado' ? 'Chamado' : 'Sala' %>] <%= room.name %> (<%= room.id %><%= room.chamadoId ? ` / #${room.chamadoId}` : '' %>)
                </option>
              <% }); %>
            </select>
          </label>
          <label class="min-w-[220px] text-sm">
            <span class="mb-1 block font-semibold text-gray-500">chat_state (teste)</span>
            <select id="chatStatePicker" class="w-full rounded-xl border border-emerald-200 px-3 py-2 text-sm text-emerald-800 outline-none focus:border-emerald-400">
              <option value="NEW">NEW</option>
              <option value="IA">IA</option>
              <option value="AGUARDANDO_HUMANO">AGUARDANDO_HUMANO</option>
              <option value="FILA">FILA</option>
              <option value="HUMANO">HUMANO</option>
              <option value="FECHADO">FECHADO</option>
            </select>
          </label>
          <button id="applyChatStateBtn" type="button" class="rounded-xl border border-emerald-300 bg-emerald-50 px-4 py-2 text-sm font-semibold text-emerald-800 transition hover:bg-emerald-100">Aplicar chat_state</button>
          <button id="refreshBtn" type="button" class="rounded-xl0 px-4 py-2 text-sm font-semibold text-white transition hover:bg-green-600">Atualizar dados</button>
          <button id="typingBtn" type="button" class="rounded-xl border border-green-300 bg-white px-4 py-2 text-sm font-semibold text-green-800 transition hover:bg-green-50">Simular digitando</button>
          <button id="auditBtn" type="button" class="rounded-xl border border-emerald-300 bg-emerald-50 px-4 py-2 text-sm font-semibold text-emerald-800 transition hover:bg-emerald-100">Executar auditoria</button>
          <div class="w-full text-xs font-semibold text-gray-600">
            <span id="roomStateInfo">chat_state: - | status: -</span>
            <span id="chatStateResult" class="ml-2"></span>
          </div>
        </div>
      </section>

      <section class="grid gap-4 lg:grid-cols-5">
        <article class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm lg:col-span-2">
          <h2 class="text-lg font-bold text-green-800">Checklist de qualidade</h2>
          <div id="qaChecklist" class="mt-3 space-y-2 text-sm"></div>
          <div class="mt-4 rounded-xl border border-green-100 p-3 text-xs text-green-900">
            <p class="font-semibold">Criterios validados</p>
            <p>- Conexao SSE ativa</p>
            <p>- Alinhamento proprio (direita) e terceiros (esquerda)</p>
            <p>- Indicador de digitacao em tempo real</p>
            <p>- Empilhamento de avatares por participantes</p>
            <p>- Render em duas perspectivas</p>
          </div>
        </article>

        <article class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm lg:col-span-3">
          <h2 class="text-lg font-bold text-green-800">Participantes e avatares</h2>
          <div id="avatarStack" class="mt-3 flex flex-wrap items-center gap-2"></div>
          <div id="participantsList" class="mt-3 grid gap-2 sm:grid-cols-2"></div>
        </article>
      </section>

      <section class="grid gap-4 xl:grid-cols-2">
        <article class="rounded-2xl border border-green-100 bg-white shadow-sm">
          <div class="border-b border-green-100 px-4 py-3">
            <p class="text-xs uppercase tracking-wide text-gray-500">Perspectiva A</p>
            <select id="viewerA" class="mt-2 w-full rounded-lg border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400"></select>
          </div>
          <div id="typingA" class="px-4 py-2 text-xs font-semibold text-emerald-700"></div>
          <div id="paneA" class="h-[420px] overflow-y-auto/60 px-4 py-4"></div>
        </article>

        <article class="rounded-2xl border border-green-100 bg-white shadow-sm">
          <div class="border-b border-green-100 px-4 py-3">
            <p class="text-xs uppercase tracking-wide text-gray-500">Perspectiva B</p>
            <select id="viewerB" class="mt-2 w-full rounded-lg border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400"></select>
          </div>
          <div id="typingB" class="px-4 py-2 text-xs font-semibold text-emerald-700"></div>
          <div id="paneB" class="h-[420px] overflow-y-auto/60 px-4 py-4"></div>
        </article>
      </section>

      <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <h2 class="text-lg font-bold text-green-800">Envio de teste (usuario logado)</h2>
        <div class="mt-3 flex flex-wrap items-center gap-2">
          <input id="testMessage" placeholder="Mensagem para validar alinhamento e stream..." class="min-w-[260px] flex-1 rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
          <button id="sendBtn" type="button" class="rounded-xl0 px-4 py-2 text-sm font-semibold text-white transition hover:bg-green-600">Enviar</button>
        </div>
      </section>

      <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <div class="flex items-center justify-between gap-2">
          <h2 class="text-lg font-bold text-green-800">Resultado da auditoria</h2>
          <span id="auditBadge" class="rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-600">Nao executada</span>
        </div>
        <div id="auditReport" class="mt-3 space-y-2 text-sm text-gray-600">
          <p>Execute a auditoria para validar saude funcional da sala selecionada.</p>
        </div>
      </section>
    </main>
  </div>

  <%- include('../partials/sidebar-script') %>

  <script>
    const initialRooms = <%- JSON.stringify(rooms || []) %>;
    const allUsers = <%- JSON.stringify(users || []) %>;
    const selectedRoomId = <%- JSON.stringify(selectedRoomId || '') %>;
    const sessionUser = <%- JSON.stringify(user || {}) %>;

    const state = {
      rooms: initialRooms,
      roomId: selectedRoomId,
      messages: [],
      participants: [],
      typing: {},
      sseConnected: false,
      updatesCount: 0,
      stream: null
    };

    const roomPicker = document.getElementById('roomPicker');
    const viewerA = document.getElementById('viewerA');
    const viewerB = document.getElementById('viewerB');
    const paneA = document.getElementById('paneA');
    const paneB = document.getElementById('paneB');
    const typingA = document.getElementById('typingA');
    const typingB = document.getElementById('typingB');
    const chatStatePicker = document.getElementById('chatStatePicker');
    const roomStateInfo = document.getElementById('roomStateInfo');
    const chatStateResult = document.getElementById('chatStateResult');

    function normalizeMessage(msg) {
      return {
        id: msg.id,
        userId: String(msg.user_id || msg.userId || ''),
        name: msg.name || 'Usuario',
        avatar: msg.avatar || '',
        content: msg.content || '',
        type: msg.type || 'text',
        fileUrl: msg.file_url || msg.fileUrl || '',
        createdAt: msg.created_at || msg.createdAt || new Date().toISOString()
      };
    }

    function getRoomById(id) {
      return state.rooms.find((room) => room.id === id) || null;
    }

    function renderRoomStateInfo() {
      const room = getRoomById(state.roomId);
      if (!room) {
        roomStateInfo.textContent = 'chat_state: - | status: -';
        return;
      }
      const chatState = String(room.chatState || 'NEW').toUpperCase();
      const status = String(room.status || 'aberto').toLowerCase();
      roomStateInfo.textContent = `chat_state: ${chatState} | status: ${status}`;
      chatStatePicker.value = chatState;
    }

    function setChatStateResult(text, type = 'info') {
      const colors = {
        info: 'text-gray-600',
        success: 'text-emerald-700',
        error: 'text-red-700'
      };
      chatStateResult.className = `ml-2 ${colors[type] || colors.info}`;
      chatStateResult.textContent = text;
    }

    function setParticipants(roomId) {
      const room = getRoomById(roomId);
      state.participants = (room && room.participants) ? room.participants : [];
    }

    function fillViewerOptions() {
      const fallbackUser = {
        id: String(sessionUser.id || 'viewer_a'),
        name: sessionUser.name || 'Usuario A',
        avatar: sessionUser.avatar || '',
        status: 'online'
      };
      const participants = state.participants.length ? state.participants : [fallbackUser];
      const globalUsers = allUsers.length ? allUsers : [fallbackUser];
      const optionsUsers = [];
      const seen = new Set();

      [...participants, ...globalUsers, fallbackUser].forEach((u) => {
        const id = String(u.id || '');
        if (!id || seen.has(id)) return;
        seen.add(id);
        optionsUsers.push(u);
      });

      const options = optionsUsers.map((p) => `<option value="${p.id}">${p.name} (${p.id})</option>`).join('');
      viewerA.innerHTML = options;
      viewerB.innerHTML = options;

      const defaultA = optionsUsers.find((p) => String(p.id) === String(sessionUser.id)) || optionsUsers[0];
      const defaultB = optionsUsers.find((p) => String(p.id) !== String(defaultA.id)) || optionsUsers[0];
      viewerA.value = defaultA.id;
      viewerB.value = defaultB.id;
    }

    function renderParticipants() {
      const stackEl = document.getElementById('avatarStack');
      const listEl = document.getElementById('participantsList');
      stackEl.innerHTML = '';
      listEl.innerHTML = '';

      if (!state.participants.length) {
        stackEl.innerHTML = '<p class="text-sm text-gray-500">Sem participantes mapeados.</p>';
        return;
      }

      state.participants.slice(0, 8).forEach((p, idx) => {
        const avatar = p.avatar
          ? `<img src="${p.avatar}" alt="${p.name}" class="h-full w-full object-cover">`
          : `<span>${String(p.name || 'U').charAt(0).toUpperCase()}</span>`;

        stackEl.insertAdjacentHTML('beforeend', `
          <div class="relative ${idx > 0 ? '-ml-2' : ''}">
            <div class="flex h-10 w-10 items-center justify-center overflow-hidden rounded-full border-2 border-white0 text-xs font-bold text-white shadow-sm">${avatar}</div>
            <span class="absolute -bottom-0.5 -right-0.5 h-3 w-3 rounded-full border border-white ${p.status === 'online' ? 'bg-emerald-400' : 'bg-gray-400'}"></span>
          </div>
        `);
      });

      state.participants.forEach((p) => {
        listEl.insertAdjacentHTML('beforeend', `
          <div class="rounded-lg border border-green-100 px-3 py-2 text-sm">
            <p class="font-semibold text-green-800">${p.name}</p>
            <p class="text-xs text-gray-500">${p.id}</p>
          </div>
        `);
      });
    }

    function messageHtml(msg, viewerId, previousUserId) {
      const own = String(msg.userId) === String(viewerId);
      const grouped = String(previousUserId || '') === String(msg.userId);
      const sideClass = own ? 'qa-msg-own' : 'qa-msg-other';
      const bubbleClass = own ? 'qa-bubble-own' : 'qa-bubble-other';
      const sender = own ? 'Voce' : (msg.name || 'Usuario');
      const body = msg.type === 'text'
        ? msg.content
        : (msg.fileUrl ? `<a class="underline" href="${msg.fileUrl}" target="_blank" rel="noreferrer">${msg.type}</a>` : msg.type);

      return `
        <div class="flex ${sideClass} ${grouped ? 'mt-1' : 'mt-4'}">
          <div class="max-w-[80%]">
            ${grouped ? '' : `<p class="mb-1 text-[11px] font-semibold uppercase tracking-wide text-green-700">${sender}</p>`}
            <div class="rounded-2xl px-3 py-2 text-sm text-gray-800 shadow-sm ${bubbleClass}">${body}</div>
            <p class="mt-1 text-[10px] text-gray-500">${new Date(msg.createdAt).toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' })}</p>
          </div>
        </div>
      `;
    }

    function renderPane(element, viewerId) {
      let previousUserId = null;
      const html = state.messages.map((msg) => {
        const block = messageHtml(msg, viewerId, previousUserId);
        previousUserId = msg.userId;
        return block;
      }).join('');
      element.innerHTML = html || '<p class="text-sm text-gray-500">Sem mensagens.</p>';
      element.scrollTop = element.scrollHeight;
    }

    function renderTypingStatus() {
      const aId = viewerA.value;
      const bId = viewerB.value;

      const typingForA = Object.values(state.typing).filter((t) => t.isTyping && String(t.userId) !== String(aId));
      const typingForB = Object.values(state.typing).filter((t) => t.isTyping && String(t.userId) !== String(bId));

      typingA.textContent = typingForA.length ? `${typingForA[0].userName} esta digitando...` : '';
      typingB.textContent = typingForB.length ? `${typingForB[0].userName} esta digitando...` : '';
    }

    function renderChecklist() {
      const checklist = document.getElementById('qaChecklist');
      const aId = viewerA.value;
      const bId = viewerB.value;
      const hasOwnA = state.messages.some((m) => String(m.userId) === String(aId));
      const hasOtherA = state.messages.some((m) => String(m.userId) !== String(aId));
      const hasOwnB = state.messages.some((m) => String(m.userId) === String(bId));
      const hasOtherB = state.messages.some((m) => String(m.userId) !== String(bId));
      const hasTyping = Object.values(state.typing).some((t) => t.isTyping);

      const checks = [
        { label: 'SSE conectado', ok: state.sseConnected },
        { label: 'chat_state visivel para teste', ok: Boolean(getRoomById(state.roomId)?.chatState) },
        { label: 'Avatar stack com participantes', ok: state.participants.length > 1 },
        { label: 'Perspectiva A mostra lados corretos', ok: hasOwnA && hasOtherA },
        { label: 'Perspectiva B mostra lados corretos', ok: hasOwnB && hasOtherB },
        { label: 'Eventos em tempo real recebidos', ok: state.updatesCount > 0 },
        { label: 'Digitacao detectada', ok: hasTyping }
      ];

      checklist.innerHTML = checks.map((item) => `
        <div class="flex items-center justify-between rounded-lg border px-3 py-2 ${item.ok ? 'border-emerald-200 bg-emerald-50' : 'border-rose-200 bg-rose-50'}">
          <span>${item.label}</span>
          <span class="text-xs font-bold uppercase ${item.ok ? 'text-emerald-700' : 'text-rose-700'}">${item.ok ? 'OK' : 'Pendente'}</span>
        </div>
      `).join('');
    }

    function setAuditReport(rows) {
      const badge = document.getElementById('auditBadge');
      const report = document.getElementById('auditReport');
      const failures = rows.filter((r) => !r.ok).length;
      if (!rows.length) {
        badge.className = 'rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-600';
        badge.textContent = 'Nao executada';
        report.innerHTML = '<p>Execute a auditoria para validar saude funcional da sala selecionada.</p>';
        return;
      }

      badge.className = failures
        ? 'rounded-full bg-rose-100 px-3 py-1 text-xs font-semibold text-rose-700'
        : 'rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700';
      badge.textContent = failures ? `Falhas: ${failures}` : 'Tudo certo';

      report.innerHTML = rows.map((row) => `
        <div class="flex items-center justify-between rounded-lg border px-3 py-2 ${row.ok ? 'border-emerald-200 bg-emerald-50' : 'border-rose-200 bg-rose-50'}">
          <div>
            <p class="font-semibold ${row.ok ? 'text-emerald-800' : 'text-rose-800'}">${row.name}</p>
            <p class="text-xs text-gray-600">${row.detail}</p>
          </div>
          <span class="text-xs font-bold uppercase ${row.ok ? 'text-emerald-700' : 'text-rose-700'}">${row.ok ? 'PASS' : 'FAIL'}</span>
        </div>
      `).join('');
    }

    async function runAudit() {
      const rows = [];
      const aId = viewerA.value;
      const bId = viewerB.value;

      rows.push({
        name: 'Conexao SSE',
        ok: state.sseConnected,
        detail: state.sseConnected ? 'stream ativo na sala' : 'stream desconectado'
      });

      const hasOwnA = state.messages.some((m) => String(m.userId) === String(aId));
      const hasOtherA = state.messages.some((m) => String(m.userId) !== String(aId));
      rows.push({
        name: 'Alinhamento perspectiva A',
        ok: hasOwnA && hasOtherA,
        detail: hasOwnA && hasOtherA ? 'mensagens proprias e de terceiros visiveis' : 'faltam mensagens para validar lados'
      });

      const hasOwnB = state.messages.some((m) => String(m.userId) === String(bId));
      const hasOtherB = state.messages.some((m) => String(m.userId) !== String(bId));
      rows.push({
        name: 'Alinhamento perspectiva B',
        ok: hasOwnB && hasOtherB,
        detail: hasOwnB && hasOtherB ? 'mensagens proprias e de terceiros visiveis' : 'faltam mensagens para validar lados'
      });

      const stackCount = document.querySelectorAll('#avatarStack > div').length;
      const expectedStack = Math.min(state.participants.length, 8);
      rows.push({
        name: 'Empilhamento de avatares',
        ok: stackCount === expectedStack && expectedStack > 0,
        detail: `renderizados ${stackCount} de ${expectedStack}`
      });

      try {
        await simulateTyping();
        await new Promise((resolve) => setTimeout(resolve, 200));
        const typingVisible = Object.values(state.typing).some((t) => t.isTyping);
        rows.push({
          name: 'Evento de digitacao',
          ok: typingVisible,
          detail: typingVisible ? 'typing_status recebido em tempo real' : 'nenhum typing_status detectado'
        });
      } catch (error) {
        rows.push({
          name: 'Evento de digitacao',
          ok: false,
          detail: `falha ao simular: ${error.message}`
        });
      }

      try {
        const form = new FormData();
        form.append('roomId', state.roomId);
        form.append('type', 'text');
        form.append('content', `[QA-AUDIT] ${new Date().toISOString()}`);
        const response = await fetch('/api/messages/send', { method: 'POST', body: form });
        rows.push({
          name: 'Envio de mensagem',
          ok: response.ok,
          detail: response.ok ? 'API de envio respondeu com sucesso' : `status ${response.status}`
        });
      } catch (error) {
        rows.push({
          name: 'Envio de mensagem',
          ok: false,
          detail: `erro no envio: ${error.message}`
        });
      }

      setAuditReport(rows);
    }

    function renderAll() {
      renderPane(paneA, viewerA.value);
      renderPane(paneB, viewerB.value);
      renderTypingStatus();
      renderRoomStateInfo();
      renderChecklist();
    }

    async function loadMessages() {
      const response = await fetch(`/api/messages/${encodeURIComponent(state.roomId)}?limit=150`);
      if (!response.ok) throw new Error('Falha ao carregar mensagens');
      const data = await response.json();
      state.messages = (data || []).map(normalizeMessage);
      renderAll();
    }

    function connectStream() {
      if (state.stream) {
        state.stream.close();
        state.stream = null;
      }

      state.sseConnected = false;
      renderChecklist();

      const stream = new EventSource(`/api/messages/stream/${encodeURIComponent(state.roomId)}`);
      state.stream = stream;

      stream.onopen = () => {
        state.sseConnected = true;
        renderChecklist();
      };

      stream.onmessage = (event) => {
        const payload = JSON.parse(event.data);
        if (payload.type === 'new_message' && payload.message) {
          state.messages.push(normalizeMessage(payload.message));
          state.updatesCount += 1;
        }

        if (payload.type === 'typing_status') {
          state.typing[payload.userId] = {
            userId: payload.userId,
            userName: payload.userName || 'Usuario',
            isTyping: Boolean(payload.isTyping)
          };
          state.updatesCount += 1;
        }

        if (payload.type === 'room_cleared') {
          state.messages = [];
        }

        if (payload.type === 'room_chat_state_changed') {
          const room = getRoomById(payload.roomId || state.roomId);
          if (room) room.chatState = String(payload.chatState || room.chatState || 'NEW').toUpperCase();
        }

        renderAll();
      };

      stream.onerror = () => {
        state.sseConnected = false;
        renderChecklist();
      };
    }

    async function sendMessage() {
      const input = document.getElementById('testMessage');
      const content = input.value.trim();
      if (!content) return;

      const form = new FormData();
      form.append('roomId', state.roomId);
      form.append('type', 'text');
      form.append('content', content);

      const response = await fetch('/api/messages/send', { method: 'POST', body: form });
      if (!response.ok) {
        alert('Falha ao enviar mensagem de teste');
        return;
      }
      input.value = '';
    }

    async function simulateTyping() {
      await fetch(`/api/messages/typing/${encodeURIComponent(state.roomId)}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ isTyping: true, activity: 'typing' })
      });
      setTimeout(() => {
        fetch(`/api/messages/typing/${encodeURIComponent(state.roomId)}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ isTyping: false, activity: 'idle' })
        });
      }, 1500);
    }

    function changeRoom(id) {
      window.location.href = `/dashboard/qa-chat?roomId=${encodeURIComponent(id)}`;
    }

    async function applyChatState() {
      const nextState = String(chatStatePicker.value || '').trim().toUpperCase();
      if (!nextState) return;
      setChatStateResult('Aplicando...', 'info');
      const response = await fetch(`/api/chat/rooms/${encodeURIComponent(state.roomId)}/chat-state`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ chatState: nextState })
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok || !data.success) {
        throw new Error(data.error || `Falha HTTP ${response.status}`);
      }

      const room = getRoomById(state.roomId);
      if (room) room.chatState = String(data.chatState || nextState).toUpperCase();
      renderAll();
      setChatStateResult(`chat_state atualizado para ${String(data.chatState || nextState).toUpperCase()}`, 'success');
    }

    function attachEvents() {
      roomPicker.addEventListener('change', () => changeRoom(roomPicker.value));
      viewerA.addEventListener('change', () => {
        if (viewerA.value === viewerB.value) {
          const other = Array.from(viewerB.options).find((opt) => opt.value !== viewerA.value);
          if (other) viewerB.value = other.value;
        }
        renderAll();
      });
      viewerB.addEventListener('change', () => {
        if (viewerA.value === viewerB.value) {
          const other = Array.from(viewerA.options).find((opt) => opt.value !== viewerB.value);
          if (other) viewerA.value = other.value;
        }
        renderAll();
      });
      document.getElementById('sendBtn').addEventListener('click', () => sendMessage().catch((err) => alert(err.message)));
      document.getElementById('typingBtn').addEventListener('click', () => simulateTyping().catch((err) => alert(err.message)));
      document.getElementById('refreshBtn').addEventListener('click', () => loadMessages().catch((err) => alert(err.message)));
      document.getElementById('auditBtn').addEventListener('click', () => runAudit().catch((err) => alert(err.message)));
      document.getElementById('applyChatStateBtn').addEventListener('click', () => applyChatState().catch((err) => setChatStateResult(err.message, 'error')));
    }

    async function bootstrap() {
      if (!state.roomId) {
        document.getElementById('qaChecklist').innerHTML = '<p class="text-sm text-gray-500">Nenhuma sala disponivel para auditoria.</p>';
        return;
      }

      setParticipants(state.roomId);
      fillViewerOptions();
      renderParticipants();
      renderChecklist();
      attachEvents();
      await loadMessages();
      connectStream();
    }

    bootstrap().catch((error) => {
      console.error(error);
      alert('Erro ao iniciar laboratorio QA: ' + error.message);
    });
  </script>
</body>
</html>
