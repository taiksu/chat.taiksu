<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="min-h-dvh text-green-700">
  <div id="sidebarOverlay" class="fixed inset-0 z-20 bg-black/30 opacity-0 pointer-events-none transition"></div>
  <%- include('../partials/sidebar', { user, active: typeof activeNav !== 'undefined' ? activeNav : 'ai' }) %>

  <div>
    <%- include('../partials/topbar', { user, pageTitle: 'IA - Aprendizado' }) %>

    <main class="mx-auto w-full max-w-7xl space-y-5 px-4 py-6 sm:px-6 lg:px-10 lg:py-8">
      <%- include('../components/breadcrumb/index', {
        link: '/dashboard',
        paginaAnterior: 'Dashboard',
        paginaAtual: 'IA Aprendizado'
      }) %>

      <%- include('./partials/ai-tabs', { aiTab: typeof aiTab !== 'undefined' ? aiTab : 'learning' }) %>

      <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <h1 class="text-xl font-bold text-green-800">Insights de aprendizado da IA</h1>
        <p class="mt-1 text-sm text-gray-500">Monitore sinais de qualidade capturados no fluxo real: loop de clarificacao, fuga de topico e feedback negativo.</p>

        <div class="mt-4 grid gap-3 sm:grid-cols-4">
          <label class="text-sm">
            <span class="mb-1 block font-semibold text-gray-600">Periodo (dias)</span>
            <select id="daysFilter" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
              <option value="3">Ultimos 3 dias</option>
              <option value="7" selected>Ultimos 7 dias</option>
              <option value="30">Ultimos 30 dias</option>
              <option value="90">Ultimos 90 dias</option>
            </select>
          </label>

          <label class="text-sm">
            <span class="mb-1 block font-semibold text-gray-600">Max eventos lidos</span>
            <select id="maxRowsFilter" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400">
              <option value="1000">1.000</option>
              <option value="2500" selected>2.500</option>
              <option value="5000">5.000</option>
              <option value="10000">10.000</option>
            </select>
          </label>

          <label class="text-sm">
            <span class="mb-1 block font-semibold text-gray-600">Filtro sala (opcional)</span>
            <input id="roomIdFilter" type="text" placeholder="ex: 123" class="w-full rounded-xl border border-green-200 px-3 py-2 text-sm text-green-800 outline-none focus:border-green-400" />
          </label>

          <div class="text-sm">
            <span class="mb-1 block font-semibold text-gray-600">Atualizar</span>
            <%- include('../components/buttons/default', {
              id: 'refreshBtn',
              label: 'Atualizar'
            }) %>
          </div>
        </div>
        <p id="statusText" class="mt-3 text-xs font-semibold text-gray-500">Carregando dados...</p>
      </section>

      <section class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        <article class="rounded-2xl border border-blue-100 bg-white p-4 shadow-sm">
          <p class="text-xs font-semibold uppercase text-gray-500">Eventos</p>
          <p id="eventsTotal" class="mt-2 text-2xl font-bold text-slate-800">0</p>
        </article>
        <article class="rounded-2xl border border-amber-100 bg-white p-4 shadow-sm">
          <p class="text-xs font-semibold uppercase text-gray-500">Loop detectado</p>
          <p id="loopTotal" class="mt-2 text-2xl font-bold text-amber-700">0</p>
        </article>
        <article class="rounded-2xl border border-rose-100 bg-white p-4 shadow-sm">
          <p class="text-xs font-semibold uppercase text-gray-500">Fuga de topico</p>
          <p id="mismatchTotal" class="mt-2 text-2xl font-bold text-rose-700">0</p>
        </article>
      </section>

      <section class="grid gap-4 lg:grid-cols-2">
        <article class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
          <h2 class="text-base font-bold text-green-800">Top salas com risco</h2>
          <div id="topRoomsList" class="mt-3 space-y-2"></div>
        </article>
        <article class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
          <h2 class="text-base font-bold text-green-800">Distribuicao por evento</h2>
          <div id="eventsByType" class="mt-3 space-y-2"></div>
        </article>
      </section>

      <section class="rounded-2xl border border-green-100 bg-white p-4 shadow-sm">
        <h2 class="text-base font-bold text-green-800">Ultimos sinais criticos</h2>
        <div id="flagsList" class="mt-3 space-y-3"></div>
      </section>
    </main>
  </div>

  <%- include('../partials/sidebar-script') %>

  <script>
    const statusTextEl = document.getElementById('statusText');
    const daysFilterEl = document.getElementById('daysFilter');
    const maxRowsFilterEl = document.getElementById('maxRowsFilter');
    const roomIdFilterEl = document.getElementById('roomIdFilter');
    const refreshBtnEl = document.getElementById('refreshBtn');
    const eventsTotalEl = document.getElementById('eventsTotal');
    const loopTotalEl = document.getElementById('loopTotal');
    const mismatchTotalEl = document.getElementById('mismatchTotal');
    const topRoomsListEl = document.getElementById('topRoomsList');
    const eventsByTypeEl = document.getElementById('eventsByType');
    const flagsListEl = document.getElementById('flagsList');

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function setStatus(text, type) {
      const palette = {
        info: 'text-gray-600',
        success: 'text-emerald-700',
        error: 'text-red-700'
      };
      statusTextEl.textContent = text;
      statusTextEl.className = `mt-3 text-xs font-semibold ${palette[type] || palette.info}`;
    }

    function asDate(value) {
      const date = new Date(value || 0);
      if (Number.isNaN(date.getTime())) return '-';
      return date.toLocaleString('pt-BR');
    }

    async function fetchJson(url) {
      const response = await fetch(url);
      const data = await response.json().catch(() => ({}));
      if (!response.ok) throw new Error(data.error || `Falha HTTP ${response.status}`);
      return data;
    }

    function renderTopRooms(items) {
      if (!Array.isArray(items) || !items.length) {
        topRoomsListEl.innerHTML = '<p class="text-sm text-gray-500">Sem dados para o filtro atual.</p>';
        return;
      }
      topRoomsListEl.innerHTML = items.map((item) => `
        <article class="rounded-xl border border-gray-200 p-3">
          <div class="flex items-center justify-between gap-2">
            <p class="text-sm font-semibold text-slate-800">Sala ${escapeHtml(item.roomId || 'n/a')}</p>
            <span class="rounded-full bg-amber-50 px-2 py-0.5 text-xs font-bold text-amber-700">${Number(item.qualityFlags || 0)} flags</span>
          </div>
          <p class="mt-1 text-xs text-gray-500">
            Eventos: ${Number(item.totalEvents || 0)} | 👎: ${Number(item.feedbackDown || 0)} | Ultimo: ${escapeHtml(asDate(item.lastAt))}
          </p>
        </article>
      `).join('');
    }

    function renderEventsByType(byEvent) {
      const entries = Object.entries(byEvent || {}).sort((a, b) => Number(b[1] || 0) - Number(a[1] || 0));
      if (!entries.length) {
        eventsByTypeEl.innerHTML = '<p class="text-sm text-gray-500">Sem eventos no periodo.</p>';
        return;
      }
      eventsByTypeEl.innerHTML = entries.map(([event, count]) => `
        <div class="flex items-center justify-between rounded-xl border border-gray-200 px-3 py-2 text-sm">
          <span class="font-semibold text-slate-700">${escapeHtml(event)}</span>
          <span class="rounded-full bg-green-50 px-2 py-0.5 text-xs font-bold text-green-700">${Number(count || 0)}</span>
        </div>
      `).join('');
    }

    function toneBySignal(signalType) {
      if (signalType === 'loop_risk') return 'border-amber-200 bg-amber-50';
      if (signalType === 'topic_mismatch') return 'border-rose-200 bg-rose-50';
      if (signalType === 'feedback_down') return 'border-red-200 bg-red-50';
      return 'border-gray-200 bg-white';
    }

    function renderFlags(items) {
      if (!Array.isArray(items) || !items.length) {
        flagsListEl.innerHTML = '<p class="text-sm text-gray-500">Nenhum sinal critico encontrado.</p>';
        return;
      }
      flagsListEl.innerHTML = items.map((item) => `
        <article class="rounded-xl border p-3 ${toneBySignal(item.signalType)}">
          <div class="flex flex-wrap items-center justify-between gap-2">
            <p class="text-sm font-semibold text-slate-800">${escapeHtml(item.signalType || 'quality_flag')}</p>
            <span class="text-xs font-semibold text-gray-600">${escapeHtml(asDate(item.ts))}</span>
          </div>
          <p class="mt-1 text-xs text-gray-600">
            Sala: ${escapeHtml(item.roomId || 'n/a')} | Evento: ${escapeHtml(item.event || '-')}
          </p>
          <p class="mt-2 text-sm text-slate-700"><strong>Usuario:</strong> ${escapeHtml(item.userMessage || '-')}</p>
          <p class="mt-1 text-sm text-slate-700"><strong>IA:</strong> ${escapeHtml(item.aiReply || '-')}</p>
        </article>
      `).join('');
    }

    async function loadData() {
      const days = Number(daysFilterEl.value || 7);
      const maxRows = Number(maxRowsFilterEl.value || 2500);
      const roomId = String(roomIdFilterEl.value || '').trim();
      const params = new URLSearchParams({ days: String(days), maxRows: String(maxRows) });
      if (roomId) params.set('roomId', roomId);

      setStatus('Atualizando insights de aprendizado...', 'info');
      try {
        const result = await fetchJson(`/dashboard/ai/learning/data?${params.toString()}`);
        const totals = result.totals || {};
        eventsTotalEl.textContent = String(Number(totals.events || 0));
        loopTotalEl.textContent = String(Number(totals.loopFlags || 0));
        mismatchTotalEl.textContent = String(Number(totals.topicMismatchFlags || 0));
        renderTopRooms(result.topRooms || []);
        renderEventsByType(result.byEvent || {});
        renderFlags(result.recentFlags || []);
        setStatus('Insights atualizados com sucesso', 'success');
      } catch (error) {
        setStatus(error.message, 'error');
      }
    }

    refreshBtnEl.addEventListener('click', loadData);
    daysFilterEl.addEventListener('change', loadData);
    maxRowsFilterEl.addEventListener('change', loadData);
    roomIdFilterEl.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') loadData();
    });

    loadData();
  </script>
</body>
</html>
