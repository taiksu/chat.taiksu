<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/tailwind.css">
  <link rel="stylesheet" href="/css/theme.css">
</head>
<body class="min-h-dvh bg-green-50 text-green-700">
  <div id="sidebarOverlay" class="fixed inset-0 z-20 bg-black/30 opacity-0 pointer-events-none transition lg:hidden"></div>
  <%- include('../partials/sidebar', { user, active: 'chamados' }) %>

  <div class="lg:pl-72">
    <%- include('../partials/topbar', { user, pageTitle: 'Chamados' }) %>

    <main class="mx-auto w-full max-w-6xl px-4 py-6 sm:px-6 lg:px-10 lg:py-8">
      <div class="mb-5 flex flex-wrap items-center justify-between gap-3">
        <h2 class="text-xl font-bold text-green-700 sm:text-2xl">Chats Criados por Chamado</h2>
        <button class="rounded-xl bg-green-400 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:-translate-y-0.5 hover:bg-green-500" onclick="createChamadoRoom()" type="button">
          + Criar Chat por Chamado
        </button>
      </div>

    <% if (!rooms || rooms.length === 0) { %>
      <div class="rounded-2xl border border-green-100 bg-white px-4 py-6 text-gray-500 shadow-sm">
        Nenhum chat de chamado criado ainda.
      </div>
    <% } %>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
      <% (rooms || []).forEach(room => { %>
        <article class="cursor-pointer overflow-hidden rounded-2xl border border-green-100 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-md" onclick="window.location.href='/chat/room/<%= room.id %>'">
          <div class="bg-gradient-to-r from-green-400 to-green-500 px-4 py-4 text-white">
            <div class="mb-1 text-xs font-semibold uppercase tracking-wide text-green-50">Chamado #<%= room.chamado_id %></div>
            <h3 class="truncate text-lg font-semibold"><%= room.name %></h3>
            <p class="mt-1 truncate text-sm text-green-50"><%= room.description || 'Sem descricao' %></p>
          </div>

          <div class="space-y-4 px-4 py-4">
            <div class="flex flex-wrap items-center justify-between gap-2 text-sm">
              <span class="text-gray-500"><%= room.participantsCount %> participantes</span>
              <% if (room.unreadCount > 0) { %>
                <span class="rounded-full bg-rose-500 px-3 py-1 text-xs font-semibold text-white"><%= room.unreadCount %> nao lidas</span>
              <% } else { %>
                <span class="rounded-full bg-green-400 px-3 py-1 text-xs font-semibold text-white">Tudo lido</span>
              <% } %>
            </div>
            <button class="w-full rounded-xl bg-green-400 px-3 py-2 text-sm font-semibold text-white transition hover:bg-green-500" type="button">Abrir Chat</button>
          </div>
        </article>
      <% }); %>
    </div>
    </main>
  </div>

  <%- include('../partials/sidebar-script') %>

  <script>
    async function createChamadoRoom() {
      const chamadoId = prompt('Informe o ID do chamado:');
      if (!chamadoId) return;

      const chamadoTitle = prompt('Titulo do chamado (opcional):') || '';
      const description = prompt('Descricao do chat (opcional):') || '';

      try {
        const response = await fetch(`/api/chat/chamados/${encodeURIComponent(chamadoId)}/room`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ chamadoTitle, description })
        });

        const data = await response.json();
        if (!response.ok || !data.success) {
          throw new Error(data.error || 'Falha ao criar sala do chamado');
        }

        window.location.href = `/chat/room/${data.room.id}`;
      } catch (err) {
        alert('Erro: ' + err.message);
      }
    }
  </script>
</body>
</html>
