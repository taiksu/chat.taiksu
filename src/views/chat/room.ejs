<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/tailwind.css">
  <link rel="stylesheet" href="/css/theme.css">
  <style>
    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes typing {
      0%, 60%, 100% {
        opacity: 0.3;
        transform: translateY(0);
      }
      30% {
        opacity: 1;
        transform: translateY(-6px);
      }
    }

    .message-enter {
      animation: slideIn 0.18s ease;
    }

    .typing-dot {
      display: inline-block;
      width: 8px;
      height: 8px;
      border-radius: 9999px;
      background: #6b7280;
      margin-right: 4px;
      animation: typing 1.4s infinite;
    }

    .typing-dot:nth-child(2) {
      animation-delay: 0.2s;
    }

    .typing-dot:nth-child(3) {
      animation-delay: 0.4s;
    }

    @keyframes equalize {
      0%, 100% { transform: scaleY(0.35); }
      50% { transform: scaleY(1); }
    }

    .audio-bar {
      transform-origin: center bottom;
    }

    .audio-player.is-playing .audio-bar { animation: equalize 0.9s ease-in-out infinite; }
    .audio-player.is-playing .audio-bar:nth-child(2n) { animation-duration: 1.05s; }
    .audio-player.is-playing .audio-bar:nth-child(3n) { animation-duration: 0.8s; }

    .audio-wa {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      width: min(340px, 100%);
      border-radius: 999px;
      padding: 0.45rem 0.65rem;
      background: rgba(255, 255, 255, 0.18);
    }

    .audio-wa-play {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2rem;
      height: 2rem;
      flex-shrink: 0;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.92);
      color: #065f46;
    }

    .audio-wa-main { min-width: 0; flex: 1; display: flex; flex-direction: column; gap: 0.2rem; }
    .audio-wa-wave { display: flex; align-items: center; gap: 0.35rem; min-height: 1rem; }
    .audio-wa-dot {
      width: 0.7rem;
      height: 0.7rem;
      border-radius: 999px;
      background: #38bdf8;
      flex-shrink: 0;
      box-shadow: 0 0 0 2px rgba(56, 189, 248, 0.2);
    }
    .audio-wa .audio-bars { height: 1.15rem; gap: 2px; }
    .audio-wa .audio-bar { width: 3px; border-radius: 999px; background: rgba(255, 255, 255, 0.88); }
    .audio-wa .audio-time { width: auto; text-align: left; font-size: 11px; font-weight: 700; color: rgba(255,255,255,0.96); }

    .message-bubble.bg-gray-100 .audio-wa {
      background: #c7ded0;
    }
    .message-bubble.bg-gray-100 .audio-wa-play {
      background: #f1f5f9;
      color: #334155;
    }
    .message-bubble.bg-gray-100 .audio-wa .audio-bar { background: #9ca3af; }
    .message-bubble.bg-gray-100 .audio-wa .audio-time { color: #475569; }

    @keyframes recordPulse {
      0%, 100% { transform: scale(1); opacity: 0.85; }
      50% { transform: scale(1.2); opacity: 1; }
    }

    .record-pulse {
      animation: recordPulse 1s ease-in-out infinite;
    }
  </style>
</head>
<body class="flex h-dvh min-h-dvh flex-col overflow-hidden bg-green-50 text-green-700">
  <nav class="bg-gradient-to-r from-emerald-600 to-emerald-700 px-3 py-3 text-white shadow-sm sm:px-5">
    <div class="mx-auto flex w-full max-w-7xl flex-wrap items-center justify-between gap-2">
      <h1 class="text-base font-bold sm:text-lg">Chat Taiksu</h1>
      <div class="flex flex-wrap items-center justify-end gap-2 text-sm">
        <% if (user) { %>
          <span class="hidden text-emerald-50 sm:inline"><%= user.name %></span>
          <div class="flex h-9 w-9 items-center justify-center overflow-hidden rounded-full bg-white text-xs font-bold text-emerald-700">
            <% if (user.avatar) { %>
              <img src="<%= user.avatar %>" alt="Avatar de <%= user.name %>" class="h-full w-full object-cover">
            <% } else { %>
              <span><%= user.name.charAt(0).toUpperCase() %></span>
            <% } %>
          </div>
          <a href="/dashboard" class="rounded-lg bg-white/20 px-3 py-2 text-xs font-semibold transition hover:bg-white/30 sm:text-sm">Dashboard</a>
          <a href="/chat/rooms" class="rounded-lg bg-white/20 px-3 py-2 text-xs font-semibold transition hover:bg-white/30 sm:text-sm">Chat</a>
          <a href="/widget-test" class="rounded-lg bg-white/20 px-3 py-2 text-xs font-semibold transition hover:bg-white/30 sm:text-sm">Teste Widget</a>
          <a href="/auth/logout" class="rounded-lg bg-white/20 px-3 py-2 text-xs font-semibold transition hover:bg-white/30 sm:text-sm">Sair</a>
        <% } %>
      </div>
    </div>
  </nav>

  <div class="flex min-h-0 flex-1 px-2 py-3 sm:px-4 sm:py-5">
    <% const roomIsClosed = ['concluido', 'closed'].includes(String(room.status || '').toLowerCase()); %>
    <div class="mx-auto flex min-h-0 w-full max-w-5xl flex-1 flex-col overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
      <div class="flex flex-wrap items-center justify-between gap-3 bg-green-700 px-3 py-3 text-white sm:px-4 sm:py-4">
        <div class="min-w-0">
          <a href="/chat/rooms" class="inline-block rounded-lg bg-white/20 px-3 py-2 text-xs font-semibold text-white transition hover:bg-white/30">Voltar</a>
          <h2 class="mt-2 truncate text-base font-bold text-white sm:text-lg">Chat de Atendimento</h2>
          <p class="truncate text-xs text-green-100 sm:text-sm"><%= room.name %> - <%= room.description %></p>
          <div class="mt-2 flex items-center gap-2">
            <span id="unreadBadge" class="hidden rounded-full bg-rose-500 px-2 py-1 text-[11px] font-semibold text-white">0</span>
            <% if (roomIsClosed) { %>
              <span class="rounded-full bg-amber-400 px-2 py-1 text-[11px] font-semibold text-amber-950">Concluido</span>
            <% } %>
          </div>
          <% if (canManageRoom) { %>
            <div class="mt-2 flex flex-wrap items-center gap-2">
              <button type="button" onclick="clearRoomMessages()" class="rounded-lg border border-amber-200 bg-amber-50 px-2.5 py-1.5 text-xs font-semibold text-amber-700 transition hover:bg-amber-100">
                Limpar chat
              </button>
              <button type="button" onclick="deleteRoom()" class="rounded-lg border border-rose-200 bg-rose-50 px-2.5 py-1.5 text-xs font-semibold text-rose-700 transition hover:bg-rose-100">
                Excluir sala
              </button>
            </div>
          <% } %>
        </div>

        <div class="hidden items-center gap-2 sm:flex">
          <% participants.forEach(p => { %>
            <div class="relative flex h-9 w-9 items-center justify-center overflow-hidden rounded-full text-xs font-bold text-white <%= p.status === 'online' ? 'bg-emerald-600' : 'bg-gray-400' %>" data-participant-id="<%= p.id %>" title="<%= p.name %>">
              <% if (p.avatar) { %>
                <img src="<%= p.avatar %>" alt="Avatar de <%= p.name %>" class="h-full w-full object-cover">
              <% } else { %>
                <%= p.name.charAt(0).toUpperCase() %>
              <% } %>
              <span class="absolute bottom-0 right-0 h-2.5 w-2.5 rounded-full border border-white <%= p.status === 'online' ? 'bg-emerald-400' : 'bg-gray-300' %>"></span>
              <% if (canManageRoom && String(p.id) !== String(user.id) && String(p.id) !== String(room.owner_id)) { %>
                <button
                  type="button"
                  onclick="removeParticipant('<%= p.id %>')"
                  class="absolute -right-1 -top-1 flex h-4 w-4 items-center justify-center rounded-full bg-rose-500 text-[10px] text-white transition hover:bg-rose-600"
                  title="Remover <%= p.name %>"
                >
                  x
                </button>
              <% } %>
            </div>
          <% }); %>
        </div>
      </div>

      <div class="messages-area flex min-h-0 flex-1 flex-col justify-end gap-1 overflow-y-auto scroll-smooth bg-gray-50 px-4 py-4 sm:px-4 md:px-6" id="messagesArea" style="max-height: 560px; min-height: 380px;">
        <div id="loadingMessages" class="flex items-center justify-center py-6 text-gray-400">
          <svg class="h-7 w-7 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
        </div>
        <% messages.forEach(msg => { const isOwn = String(msg.user_id) === String(user.id); %>
          <div class="message message-enter <%= isOwn ? 'own justify-end' : '' %> mb-1 flex items-end gap-2 sm:gap-3" data-id="<%= msg.id %>" data-user-id="<%= msg.user_id %>">
            <div class="message-avatar <%= isOwn ? 'order-2 bg-emerald-700' : 'bg-emerald-600' %> flex h-8 w-8 shrink-0 items-center justify-center overflow-hidden rounded-full text-xs font-semibold text-white" title="<%= msg.name %>">
              <% if (msg.avatar) { %>
                <img src="<%= msg.avatar %>" alt="Avatar de <%= msg.name %>" class="h-full w-full object-cover">
              <% } else { %>
                <%= msg.name.charAt(0).toUpperCase() %>
              <% } %>
            </div>
            <div class="message-content <%= isOwn ? 'items-end text-right' : 'items-start text-left' %> flex max-w-[84%] min-w-0 flex-col sm:max-w-[70%]">
              <div class="message-sender mb-0.5 text-xs font-semibold text-gray-500">
                <%= isOwn ? 'Voce' : msg.name %>
              </div>
              <div class="message-bubble <%= isOwn ? 'bg-emerald-700 text-white border border-emerald-800' : 'bg-gray-100 text-gray-700 border border-gray-200' %> rounded-2xl px-3 py-2 text-sm leading-relaxed break-words">
                <% if (msg.type === 'text') { %>
                  <%= msg.content %>
                <% } else if (msg.type === 'image') { %>
                  <img src="<%= msg.file_url %>" alt="Imagem" class="message-attachment max-w-full rounded-lg sm:max-w-[300px]">
                <% } else if (msg.type === 'video') { %>
                  <video controls class="message-attachment max-w-full rounded-lg sm:max-w-[300px]" src="<%= msg.file_url %>"></video>
                <% } else if (msg.type === 'audio') { %>
                  <div class="audio-player audio-wa" data-audio-url="<%= msg.file_url %>">
                    <button type="button" class="audio-toggle audio-wa-play" aria-label="Reproduzir audio">
                      <svg class="audio-icon-play h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5.14v13.72a1 1 0 0 0 1.55.83l10-6.86a1 1 0 0 0 0-1.66l-10-6.86A1 1 0 0 0 8 5.14z"/></svg>
                      <svg class="audio-icon-pause hidden h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5h3v14H8zm5 0h3v14h-3z"/></svg>
                    </button>
                    <div class="audio-wa-main">
                      <div class="audio-wa-wave">
                        <span class="audio-wa-dot"></span>
                        <div class="audio-bars flex flex-1 items-end">
                          <% for (let i = 0; i < 26; i++) { %>
                            <span class="audio-bar inline-block" style="height: <%= 18 + ((i * 7) % 62) %>%"></span>
                          <% } %>
                        </div>
                      </div>
                      <div class="audio-wa-meta">
                        <span class="audio-time">00:00</span>
                      </div>
                    </div>
                    <audio preload="metadata" class="native-audio hidden" src="<%= msg.file_url %>"></audio>
                  </div>
                <% } else { %>
                  <a href="<%= msg.file_url %>" download class="text-emerald-700 underline">Arquivo: <%= msg.file_type %></a>
                <% } %>
              </div>
              <div class="message-time mt-1 text-[11px] text-gray-500">
                <%= new Date(msg.created_at).toLocaleTimeString('pt-BR', {hour: '2-digit', minute:'2-digit'}) %>
              </div>
              <% if (msg.is_read) { %>
                <div class="message-read mt-0.5 text-[11px] text-emerald-600">Lido</div>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>

      <div class="border-t border-gray-200 bg-white px-3 py-3 sm:px-4 <%= roomIsClosed ? 'opacity-60' : '' %>" style="padding-bottom: calc(0.75rem + env(safe-area-inset-bottom));">
        <% if (roomIsClosed) { %>
          <div class="mb-2 flex items-center justify-center gap-2 rounded-lg border border-gray-300 bg-gray-50 px-3 py-2 text-sm font-medium text-gray-500">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
            Chat fechado - chamado concluido
          </div>
        <% } %>
        <div class="flex min-w-0 items-end gap-2">
          <div class="relative">
            <button class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-600 text-lg text-white transition hover:bg-emerald-700 disabled:cursor-not-allowed disabled:opacity-40" id="fileBtn" onclick="toggleFileTypeDropdown()" title="Selecionar tipo de arquivo" type="button" <%= roomIsClosed ? 'disabled' : '' %>>
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M12 5v14M5 12h14"/>
              </svg>
            </button>
            <div class="absolute bottom-12 left-0 z-20 hidden min-w-40 overflow-hidden rounded-xl border border-green-100 bg-white shadow-lg" id="fileTypeDropdown">
              <button class="flex w-full items-center gap-2 px-4 py-2 text-left text-sm text-green-700 transition hover:bg-green-50" onclick="setFileType('image'); document.getElementById('fileInput').click();" type="button">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="8.5" cy="9.5" r="1.5"/><path d="M21 15l-5-5L5 20"/></svg>
                <span>Foto</span>
              </button>
              <button class="flex w-full items-center gap-2 px-4 py-2 text-left text-sm text-green-700 transition hover:bg-green-50" onclick="setFileType('video'); document.getElementById('fileInput').click();" type="button">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="6" width="13" height="12" rx="2"/><path d="M16 10l5-3v10l-5-3z"/></svg>
                <span>Video</span>
              </button>
              <button class="flex w-full items-center gap-2 px-4 py-2 text-left text-sm text-green-700 transition hover:bg-green-50" onclick="setFileType('audio'); document.getElementById('fileInput').click();" type="button">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
                <span>Audio</span>
              </button>
              <button class="flex w-full items-center gap-2 px-4 py-2 text-left text-sm text-green-700 transition hover:bg-green-50" onclick="setFileType('document'); document.getElementById('fileInput').click();" type="button">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
                <span>Documento</span>
              </button>
            </div>
            <input type="file" id="fileInput" class="hidden" onchange="sendFile(this)">
          </div>

          <textarea class="message-input min-h-11 max-h-28 w-full resize-none rounded-xl border border-green-200 px-3 py-2 text-sm text-green-700 outline-none ring-0 placeholder:text-gray-500 focus:border-emerald-500 focus:shadow-[0_0_0_3px_rgba(16,185,129,0.15)] disabled:cursor-not-allowed disabled:bg-gray-100" id="messageInput" placeholder="<%= roomIsClosed ? 'Chat fechado para novas mensagens' : 'Digite sua mensagem...' %>" onkeypress="handleKeyPress(event)" onkeyup="updateActionButton()" onkeydown="setTypingStatus(true)" <%= roomIsClosed ? 'disabled' : '' %>></textarea>

          <button class="hidden h-10 w-10 items-center justify-center rounded-full bg-emerald-600 text-white transition hover:bg-emerald-700 disabled:cursor-not-allowed disabled:opacity-40" id="sendBtn" onclick="sendMessage()" title="Enviar mensagem" type="button" <%= roomIsClosed ? 'disabled' : '' %>>
            <svg class="h-4 w-4 translate-x-[1px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M3 11.5L21 3l-5.8 18-3.4-6.5L3 11.5zM10.8 13.8l2.2 4.3 3.3-10.1-8.6 4.1 3.1 1.7z"/>
            </svg>
          </button>
          <button class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-600 text-white transition hover:bg-emerald-700 disabled:cursor-not-allowed disabled:opacity-40" id="micBtn" title="Mensagem de voz" type="button" <%= roomIsClosed ? 'disabled' : '' %>>
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
              <rect x="9" y="3.5" width="6" height="11" rx="3"></rect>
              <path d="M6.5 11.5a5.5 5.5 0 0 0 11 0"></path>
              <path d="M12 17v3"></path>
              <path d="M9 20h6"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <script>
    const roomId = '<%= room.id %>';
    const userId = '<%= user.id %>';
    const userName = '<%= user.name %>';
    const canManageRoom = <%= canManageRoom ? 'true' : 'false' %>;
    let selectedFileType = null;
    let mediaRecorder = null;
    let audioChunks = [];
    let isRecording = false;
    let typingTimeout = null;
    let typingIsActive = false;
    let chatEventSource = null;
    let reconnectTimeout = null;
    const renderedMessageIds = new Set();
    let currentAudioElement = null;
    let roomDeletedHandled = false;
    let stickToBottom = true;
    let unreadCount = 0;
    let isWindowVisible = document.visibilityState === 'visible';

    document.addEventListener('DOMContentLoaded', () => {
      initRenderedMessageIds();
      hideLoadingMessages();
      updateActionButton();
      setupMicrophoneButton();
      initAudioPlayers();
      bindMessageAreaScroll();
      scrollMessagesToBottom(true);
    });

    function getMessagesArea() {
      return document.getElementById('messagesArea');
    }

    function isNearBottom(area, offset = 80) {
      return (area.scrollHeight - area.scrollTop - area.clientHeight) <= offset;
    }

    function scrollMessagesToBottom(force = false) {
      const area = getMessagesArea();
      if (!area) return;
      if (!force && !stickToBottom) return;
      area.scrollTop = area.scrollHeight;
    }

    function bindMessageAreaScroll() {
      const area = getMessagesArea();
      if (!area) return;
      area.addEventListener('scroll', () => {
        stickToBottom = isNearBottom(area);
      });
    }

    function initRenderedMessageIds() {
      document.querySelectorAll('.message[data-id]').forEach((el) => {
        const id = el.getAttribute('data-id');
        if (id) renderedMessageIds.add(String(id));
      });
    }

    function hideLoadingMessages() {
      const loading = document.getElementById('loadingMessages');
      if (loading) loading.remove();
    }

    function setUnreadCount(value) {
      const badge = document.getElementById('unreadBadge');
      unreadCount = Math.max(0, Number(value || 0));
      if (!badge) return;
      if (unreadCount <= 0) {
        badge.classList.add('hidden');
        badge.textContent = '0';
        return;
      }
      badge.classList.remove('hidden');
      badge.textContent = String(unreadCount > 99 ? '99+' : unreadCount);
    }

    function setupMicrophoneButton() {
      const micBtn = document.getElementById('micBtn');
      micBtn.addEventListener('click', toggleAudioRecording);
    }

    function setMicRecordingVisual(active) {
      const micBtn = document.getElementById('micBtn');
      if (!micBtn) return;
      if (active) {
        micBtn.classList.remove('bg-emerald-600', 'hover:bg-emerald-700');
        micBtn.classList.add('bg-rose-600', 'hover:bg-rose-700');
      } else {
        micBtn.classList.remove('bg-rose-600', 'hover:bg-rose-700');
        micBtn.classList.add('bg-emerald-600', 'hover:bg-emerald-700');
      }
    }

    function finalizeRecordingState() {
      isRecording = false;
      setMicRecordingVisual(false);
      hideRecordingIndicator();
    }

    async function toggleAudioRecording() {
      if (!isRecording) {
        try {
          const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
          mediaRecorder = new MediaRecorder(stream);
          audioChunks = [];

          mediaRecorder.ondataavailable = (event) => {
            audioChunks.push(event.data);
          };

          mediaRecorder.onstop = () => {
            const audioBlob = new Blob(audioChunks, { type: 'audio/webm' });
            if (audioBlob.size > 0) {
              sendAudio(audioBlob);
            }
            stream.getTracks().forEach((track) => track.stop());
            finalizeRecordingState();
          };

          mediaRecorder.onerror = () => {
            stream.getTracks().forEach((track) => track.stop());
            finalizeRecordingState();
          };

          mediaRecorder.start();
          isRecording = true;
          setMicRecordingVisual(true);
          showRecordingIndicator();
        } catch (error) {
          console.error('Erro ao acessar microfone:', error);
          finalizeRecordingState();
          alert('Nao foi possivel acessar o microfone');
        }
      } else {
        if (mediaRecorder && mediaRecorder.state !== 'inactive') {
          mediaRecorder.stop();
        } else {
          finalizeRecordingState();
        }
      }
    }

    function showRecordingIndicator() {
      const input = document.getElementById('messageInput');
      const indicator = document.createElement('div');
      indicator.className = 'recording-indicator flex h-11 min-w-0 flex-1 items-center gap-2 rounded-xl border border-rose-200 bg-rose-50/90 px-3 py-2 text-sm text-rose-700';
      indicator.id = 'recordingIndicator';
      indicator.innerHTML = `
        <span class="record-pulse inline-flex h-2.5 w-2.5 rounded-full bg-rose-500"></span>
        <svg class="h-4 w-4 text-rose-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
          <rect x="9" y="3.5" width="6" height="11" rx="3"></rect>
          <path d="M6.5 11.5a5.5 5.5 0 0 0 11 0"></path>
          <path d="M12 17v3"></path>
          <path d="M9 20h6"></path>
        </svg>
        <span class="font-semibold">Gravando audio...</span>
      `;
      input.parentElement.insertBefore(indicator, input);
      input.classList.add('hidden');
    }

    function hideRecordingIndicator() {
      const indicator = document.getElementById('recordingIndicator');
      const input = document.getElementById('messageInput');
      if (indicator) indicator.remove();
      input.classList.remove('hidden');
    }

    function sendAudio(audioBlob) {
      const formData = new FormData();
      formData.append('roomId', roomId);
      formData.append('file', audioBlob, 'audio.webm');
      formData.append('type', 'audio');

      fetch('/api/messages/send', {
        method: 'POST',
        body: formData
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          console.log('Audio enviado com sucesso');
        }
      })
      .catch(error => console.error('Erro ao enviar audio:', error));
    }

    function toggleFileTypeDropdown() {
      const dropdown = document.getElementById('fileTypeDropdown');
      dropdown.classList.toggle('hidden');
      document.addEventListener('click', closeDropdownOnClickOutside);
    }

    function closeDropdownOnClickOutside(e) {
      const dropdown = document.getElementById('fileTypeDropdown');
      const fileBtn = document.getElementById('fileBtn');

      if (!dropdown.contains(e.target) && !fileBtn.contains(e.target)) {
        dropdown.classList.add('hidden');
        document.removeEventListener('click', closeDropdownOnClickOutside);
      }
    }

    function setFileType(type) {
      selectedFileType = type;
      const fileInput = document.getElementById('fileInput');

      const acceptMap = {
        image: 'image/*',
        video: 'video/*',
        audio: 'audio/*',
        document: '.pdf,.doc,.docx,.txt,.xls,.xlsx,.ppt,.pptx,.zip'
      };

      fileInput.accept = acceptMap[type] || '*';
      document.getElementById('fileTypeDropdown').classList.add('hidden');
    }

    function updateActionButton() {
      const input = document.getElementById('messageInput');
      const sendBtn = document.getElementById('sendBtn');
      const micBtn = document.getElementById('micBtn');
      const hasText = input.value.trim().length > 0;

      if (hasText) {
        sendBtn.classList.remove('hidden');
        sendBtn.classList.add('flex');
        micBtn.classList.add('hidden');
        micBtn.classList.remove('flex');
      } else {
        sendBtn.classList.add('hidden');
        sendBtn.classList.remove('flex');
        micBtn.classList.remove('hidden');
        micBtn.classList.add('flex');
      }
    }

    function normalizeMessage(message) {
      if (!message) return null;
      return {
        ...message,
        id: message.id,
        user_id: message.user_id ?? message.userId,
        room_id: message.room_id ?? message.roomId,
        avatar: message.avatar ?? null,
        file_url: message.file_url ?? message.fileUrl ?? null,
        file_type: message.file_type ?? message.fileType ?? null,
        created_at: message.created_at ?? message.createdAt ?? new Date().toISOString()
      };
    }

    function connectSSE() {
      if (chatEventSource) {
        chatEventSource.close();
      }

      chatEventSource = new EventSource(`/api/messages/stream/${roomId}`);

      chatEventSource.onopen = () => {
        if (reconnectTimeout) {
          clearTimeout(reconnectTimeout);
          reconnectTimeout = null;
        }
      };

      chatEventSource.onmessage = (event) => {
        const data = JSON.parse(event.data);

        if (data.type === 'new_message') {
          addMessageToDOM(normalizeMessage(data.message));
          markAllAsRead();
        } else if (data.type === 'typing_status') {
          updateTypingStatus(data);
        } else if (data.type === 'message_deleted') {
          removeMessageFromDOM(data.messageId);
        } else if (data.type === 'room_cleared') {
          clearMessagesFromDOM();
        } else if (data.type === 'room_deleted') {
          handleRoomDeleted();
        } else if (data.type === 'participant_removed') {
          handleParticipantRemoved(data.userId);
        }
      };

      chatEventSource.onerror = () => {
        if (chatEventSource) {
          chatEventSource.close();
          chatEventSource = null;
        }

        if (!reconnectTimeout) {
          reconnectTimeout = setTimeout(() => {
            reconnectTimeout = null;
            connectSSE();
          }, 3000);
        }
      };
    }

    function sendMessage() {
      const input = document.getElementById('messageInput');
      const content = input.value.trim();

      if (!content) return;

      const formData = new FormData();
      formData.append('roomId', roomId);
      formData.append('content', content);
      formData.append('type', 'text');

      fetch('/api/messages/send', {
        method: 'POST',
        body: formData
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          input.value = '';
          updateActionButton();
          setTypingStatus(false);
        }
      });
    }

    function sendFile(input) {
      const file = input.files[0];
      if (!file) return;

      const formData = new FormData();
      formData.append('roomId', roomId);
      formData.append('file', file);
      formData.append('type', selectedFileType || getFileType(file.type));

      fetch('/api/messages/send', {
        method: 'POST',
        body: formData
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          input.value = '';
          selectedFileType = null;
        }
      });
    }

    function getFileType(mimeType) {
      if (mimeType.startsWith('image/')) return 'image';
      if (mimeType.startsWith('video/')) return 'video';
      if (mimeType.startsWith('audio/')) return 'audio';
      return 'file';
    }

    function handleKeyPress(event) {
      if (event.key === 'Enter' && !event.shiftKey) {
        event.preventDefault();
        sendMessage();
      }
    }

    function getMessageBubbleClass(isOwn) {
      return `message-bubble rounded-2xl px-3 py-2 text-sm leading-relaxed break-words ${isOwn ? 'border border-emerald-800 bg-emerald-700 text-white' : 'border border-gray-200 bg-gray-100 text-gray-700'}`;
    }

    function getMessageContentClass(isOwn) {
      return `message-content flex min-w-0 max-w-[84%] flex-col sm:max-w-[70%] ${isOwn ? 'items-end text-right' : 'items-start text-left'}`;
    }

    function getMessageAvatarClass(isOwn) {
      return `message-avatar flex h-8 w-8 shrink-0 items-center justify-center overflow-hidden rounded-full text-xs font-semibold text-white ${isOwn ? 'order-2 bg-emerald-700' : 'bg-emerald-600'}`;
    }

    function renderAvatarHtml(name, avatarUrl) {
      if (avatarUrl) {
        return `<img src="${escapeHtml(avatarUrl)}" alt="Avatar de ${escapeHtml(name || 'Usuario')}" class="h-full w-full object-cover">`;
      }
      const initial = name ? String(name).charAt(0).toUpperCase() : '?';
      return `<span>${escapeHtml(initial)}</span>`;
    }

    function formatAudioTime(seconds) {
      if (!Number.isFinite(seconds)) return '00:00';
      const mins = Math.floor(seconds / 60);
      const secs = Math.floor(seconds % 60);
      return `${String(mins).padStart(2, '0')}:${String(secs).padStart(2, '0')}`;
    }

    function getAudioLabel(audio) {
      const hasDuration = Number.isFinite(audio.duration) && audio.duration > 0;
      if (!hasDuration) return '00:00';
      if (audio.paused && audio.currentTime <= 0) return formatAudioTime(audio.duration);
      return formatAudioTime(audio.currentTime || 0);
    }

    function buildAudioPlayerHtml(url) {
      const safeUrl = escapeHtml(url || '');
      let bars = '';
      for (let i = 0; i < 26; i += 1) {
        const height = 18 + ((i * 7) % 62);
        bars += `<span class="audio-bar inline-block" style="height:${height}%"></span>`;
      }
      return `
        <div class="audio-player audio-wa" data-audio-url="${safeUrl}">
          <button type="button" class="audio-toggle audio-wa-play" aria-label="Reproduzir audio">
            <svg class="audio-icon-play h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5.14v13.72a1 1 0 0 0 1.55.83l10-6.86a1 1 0 0 0 0-1.66l-10-6.86A1 1 0 0 0 8 5.14z"/></svg>
            <svg class="audio-icon-pause hidden h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5h3v14H8zm5 0h3v14h-3z"/></svg>
          </button>
          <div class="audio-wa-main">
            <div class="audio-wa-wave">
              <span class="audio-wa-dot"></span>
              <div class="audio-bars flex flex-1 items-end">${bars}</div>
            </div>
            <div class="audio-wa-meta">
              <span class="audio-time">00:00</span>
            </div>
          </div>
          <audio preload="metadata" class="native-audio hidden" src="${safeUrl}"></audio>
        </div>
      `;
    }

    function syncAudioVisualState(player, audio, isPlaying) {
      const playIcon = player.querySelector('.audio-icon-play');
      const pauseIcon = player.querySelector('.audio-icon-pause');
      if (isPlaying) {
        player.classList.add('is-playing');
        playIcon?.classList.add('hidden');
        pauseIcon?.classList.remove('hidden');
      } else {
        player.classList.remove('is-playing');
        pauseIcon?.classList.add('hidden');
        playIcon?.classList.remove('hidden');
      }
      const timeEl = player.querySelector('.audio-time');
      if (timeEl) {
        timeEl.textContent = getAudioLabel(audio);
      }
    }

    function initAudioPlayers(root = document) {
      const players = root.querySelectorAll('.audio-player:not([data-audio-init="1"])');
      players.forEach((player) => {
        player.dataset.audioInit = '1';
        const audio = player.querySelector('.native-audio');
        const toggleBtn = player.querySelector('.audio-toggle');
        if (!audio || !toggleBtn) return;

        toggleBtn.addEventListener('click', async () => {
          if (currentAudioElement && currentAudioElement !== audio) {
            currentAudioElement.pause();
          }
          try {
            if (audio.paused) {
              await audio.play();
              currentAudioElement = audio;
            } else {
              audio.pause();
            }
          } catch (err) {
            console.error('Nao foi possivel reproduzir audio:', err);
          }
        });

        audio.addEventListener('play', () => syncAudioVisualState(player, audio, true));
        audio.addEventListener('pause', () => syncAudioVisualState(player, audio, false));
        audio.addEventListener('ended', () => syncAudioVisualState(player, audio, false));
        audio.addEventListener('loadedmetadata', () => {
          const timeEl = player.querySelector('.audio-time');
          if (timeEl) timeEl.textContent = getAudioLabel(audio);
        });
        audio.addEventListener('timeupdate', () => {
          const timeEl = player.querySelector('.audio-time');
          if (timeEl) timeEl.textContent = getAudioLabel(audio);
        });
      });
    }

    function addMessageToDOM(message) {
      message = normalizeMessage(message);
      if (!message) return;

      if (message?.id && renderedMessageIds.has(String(message.id))) {
        return;
      }

      const area = document.getElementById('messagesArea');
      const isOwn = String(message.user_id) === String(userId);
      const shouldAutoScroll = isOwn || isNearBottom(area) || stickToBottom;
      let contentHTML = '';

      if (message.type === 'text') {
        contentHTML = escapeHtml(message.content);
      } else if (message.type === 'image') {
        contentHTML = `<img src="${message.file_url}" alt="Imagem" class="max-w-full rounded-lg sm:max-w-[300px]">`;
      } else if (message.type === 'video') {
        contentHTML = `<video controls class="max-w-full rounded-lg sm:max-w-[300px]" src="${message.file_url}"></video>`;
      } else if (message.type === 'audio') {
        contentHTML = buildAudioPlayerHtml(message.file_url);
      } else {
        contentHTML = `<a href="${message.file_url}" download class="text-emerald-700 underline">Arquivo: ${message.file_type || 'Documento'}</a>`;
      }

      const senderName = isOwn ? 'Voce' : (message.name || 'Usuario');
      const createdAt = message.created_at ? new Date(message.created_at) : new Date();
      const timeStr = createdAt.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });

      const msgHTML = `
        <div class="message message-enter ${isOwn ? 'own justify-end' : ''} mb-1 flex items-end gap-2 sm:gap-3" data-id="${message.id || ''}" data-user-id="${message.user_id}">
          <div class="${getMessageAvatarClass(isOwn)}" title="${escapeHtml(message.name || '')}">
            ${renderAvatarHtml(message.name || 'Usuario', message.avatar)}
          </div>
          <div class="${getMessageContentClass(isOwn)}">
            <div class="message-sender mb-0.5 text-xs font-semibold text-gray-500">${escapeHtml(senderName)}</div>
            <div class="${getMessageBubbleClass(isOwn)}">${contentHTML}</div>
            <div class="message-time mt-1 text-[11px] text-gray-500">${timeStr}</div>
          </div>
        </div>
      `;
      area.insertAdjacentHTML('beforeend', msgHTML);

      if (message?.id) {
        renderedMessageIds.add(String(message.id));
      }

      if (!isOwn && !isWindowVisible) {
        setUnreadCount(unreadCount + 1);
      }

      initAudioPlayers(area);
      if (shouldAutoScroll) {
        scrollMessagesToBottom(true);
      }
    }

    function removeMessageFromDOM(messageId) {
      const msg = document.querySelector(`[data-id="${messageId}"]`);
      if (msg) msg.remove();
    }

    function clearMessagesFromDOM() {
      document.querySelectorAll('.message[data-id]').forEach((el) => el.remove());
      renderedMessageIds.clear();
    }

    function handleRoomDeleted() {
      if (roomDeletedHandled) return;
      roomDeletedHandled = true;
      alert('Esta sala foi excluida.');
      window.location.href = '/chat/rooms';
    }

    function removeParticipantFromDOM(participantId) {
      document.querySelectorAll(`[data-participant-id="${participantId}"]`).forEach((el) => el.remove());
    }

    function handleParticipantRemoved(participantId) {
      const normalizedId = String(participantId);
      if (normalizedId === String(userId)) {
        alert('Voce foi removido desta sala.');
        window.location.href = '/chat/rooms';
        return;
      }
      removeParticipantFromDOM(normalizedId);
    }

    async function removeParticipant(participantId) {
      if (!canManageRoom) return;
      if (!confirm('Deseja remover este participante desta sala?')) return;

      try {
        const response = await fetch(`/api/chat/rooms/${roomId}/participants/${participantId}`, { method: 'DELETE' });
        const data = await response.json();
        if (!response.ok) throw new Error(data.error || 'Erro ao remover participante');
        removeParticipantFromDOM(String(participantId));
      } catch (error) {
        alert(error.message || 'Falha ao remover participante');
      }
    }

    async function clearRoomMessages() {
      if (!canManageRoom) return;
      if (!confirm('Deseja limpar todas as mensagens desta sala?')) return;

      try {
        const response = await fetch(`/api/chat/rooms/${roomId}/messages`, { method: 'DELETE' });
        const data = await response.json();
        if (!response.ok) throw new Error(data.error || 'Erro ao limpar chat');
        clearMessagesFromDOM();
      } catch (error) {
        alert(error.message || 'Falha ao limpar chat');
      }
    }

    async function deleteRoom() {
      if (!canManageRoom) return;
      if (!confirm('Deseja excluir esta sala permanentemente?')) return;

      try {
        const response = await fetch(`/api/chat/rooms/${roomId}`, { method: 'DELETE' });
        const data = await response.json();
        if (!response.ok) throw new Error(data.error || 'Erro ao excluir sala');
        handleRoomDeleted();
      } catch (error) {
        alert(error.message || 'Falha ao excluir sala');
      }
    }

    function markAllAsRead() {
      setUnreadCount(0);
    }

    function setTypingStatus(isTyping) {
      if (!isTyping) {
        if (!typingIsActive) return;
        typingIsActive = false;
        if (typingTimeout) clearTimeout(typingTimeout);
        fetch(`/api/messages/typing/${roomId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ isTyping: false })
        });
        return;
      }

      if (!typingIsActive) {
        typingIsActive = true;
        fetch(`/api/messages/typing/${roomId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ isTyping: true })
        });
      }

      if (typingTimeout) clearTimeout(typingTimeout);
      typingTimeout = setTimeout(() => {
        setTypingStatus(false);
      }, 1500);
    }

    function updateTypingStatus(data) {
      if (String(data.userId) === String(userId)) return;

      const container = document.getElementById('typingContainer');

      if (data.isTyping) {
        if (!container) {
          const area = document.getElementById('messagesArea');
          const typingDiv = document.createElement('div');
          typingDiv.id = 'typingContainer';
          typingDiv.className = 'mt-1 flex items-center gap-1 text-xs italic text-gray-500';
          typingDiv.innerHTML = `<strong class="not-italic text-green-700">${escapeHtml(data.userName || 'Usuario')}</strong> digitando <span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span>`;
          area.appendChild(typingDiv);
          if (isNearBottom(area)) {
            scrollMessagesToBottom(true);
          }
        }
      } else if (container) {
        container.remove();
      }
    }

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    window.addEventListener('beforeunload', () => {
      if (chatEventSource) {
        chatEventSource.close();
        chatEventSource = null;
      }
      if (reconnectTimeout) {
        clearTimeout(reconnectTimeout);
        reconnectTimeout = null;
      }
    });

    document.addEventListener('visibilitychange', () => {
      isWindowVisible = document.visibilityState === 'visible';
      if (isWindowVisible) {
        markAllAsRead();
      }
    });

    window.addEventListener('focus', () => {
      isWindowVisible = true;
      markAllAsRead();
    });

    window.addEventListener('blur', () => {
      isWindowVisible = false;
    });

    connectSSE();
    scrollMessagesToBottom(true);
  </script>
</body>
</html>
