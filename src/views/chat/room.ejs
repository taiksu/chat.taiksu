<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/tailwind.css">
  <style>
    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes typing {
      0%, 60%, 100% {
        opacity: 0.3;
        transform: translateY(0);
      }
      30% {
        opacity: 1;
        transform: translateY(-6px);
      }
    }

    .message-enter {
      animation: slideIn 0.18s ease;
    }

    .typing-dot {
      display: inline-block;
      width: 8px;
      height: 8px;
      border-radius: 9999px;
      background: #94a3b8;
      margin-right: 4px;
      animation: typing 1.4s infinite;
    }

    .typing-dot:nth-child(2) {
      animation-delay: 0.2s;
    }

    .typing-dot:nth-child(3) {
      animation-delay: 0.4s;
    }

    @keyframes equalize {
      0%, 100% { transform: scaleY(0.35); }
      50% { transform: scaleY(1); }
    }

    .audio-bar {
      transform-origin: center bottom;
    }

    .audio-player.is-playing .audio-bar {
      animation: equalize 0.9s ease-in-out infinite;
    }

    .audio-player.is-playing .audio-bar:nth-child(2n) {
      animation-duration: 1.05s;
    }

    .audio-player.is-playing .audio-bar:nth-child(3n) {
      animation-duration: 0.8s;
    }
  </style>
</head>
<body class="flex h-dvh min-h-dvh flex-col overflow-hidden bg-slate-100 text-slate-800">
  <nav class="bg-gradient-to-r from-emerald-600 to-emerald-700 px-3 py-3 text-white shadow-sm sm:px-5">
    <div class="mx-auto flex w-full max-w-7xl flex-wrap items-center justify-between gap-2">
      <h1 class="text-base font-bold sm:text-lg">Chat Taiksu</h1>
      <div class="flex flex-wrap items-center justify-end gap-2 text-sm">
        <% if (user) { %>
          <span class="hidden text-emerald-50 sm:inline"><%= user.name %></span>
          <div class="flex h-9 w-9 items-center justify-center rounded-full bg-white text-xs font-bold text-emerald-700"><%= user.name.charAt(0).toUpperCase() %></div>
          <a href="/dashboard" class="rounded-lg bg-white/20 px-3 py-2 text-xs font-semibold transition hover:bg-white/30 sm:text-sm">Dashboard</a>
          <a href="/chat/rooms" class="rounded-lg bg-white/20 px-3 py-2 text-xs font-semibold transition hover:bg-white/30 sm:text-sm">Chat</a>
          <a href="/auth/logout" class="rounded-lg bg-white/20 px-3 py-2 text-xs font-semibold transition hover:bg-white/30 sm:text-sm">Sair</a>
        <% } %>
      </div>
    </div>
  </nav>

  <div class="flex min-h-0 flex-1">
    <div class="mx-auto flex min-h-0 w-full max-w-7xl flex-1 flex-col">
      <div class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-200 bg-white px-3 py-3 sm:px-4 sm:py-4">
        <div class="min-w-0">
          <a href="/chat/rooms" class="inline-block rounded-lg bg-slate-100 px-3 py-2 text-xs font-semibold text-slate-700 transition hover:bg-slate-200">Voltar</a>
          <h2 class="mt-2 truncate text-base font-bold text-emerald-700 sm:text-lg"><%= room.name %></h2>
          <p class="truncate text-xs text-slate-500 sm:text-sm"><%= room.description %></p>
        </div>

        <div class="hidden items-center gap-2 sm:flex">
          <% participants.forEach(p => { %>
            <div class="relative flex h-9 w-9 items-center justify-center rounded-full text-xs font-bold text-white <%= p.status === 'online' ? 'bg-emerald-600' : 'bg-slate-400' %>">
              <%= p.name.charAt(0).toUpperCase() %>
              <span class="absolute bottom-0 right-0 h-2.5 w-2.5 rounded-full border border-white <%= p.status === 'online' ? 'bg-emerald-400' : 'bg-slate-300' %>"></span>
            </div>
          <% }); %>
        </div>
      </div>

      <div class="messages-area flex min-h-0 flex-1 flex-col gap-1 overflow-y-auto px-3 py-3 sm:px-4 md:px-6" id="messagesArea">
        <% messages.forEach(msg => { const isOwn = String(msg.user_id) === String(user.id); %>
          <div class="message message-enter <%= isOwn ? 'own justify-end' : '' %> mb-1 flex items-end gap-2 sm:gap-3" data-id="<%= msg.id %>" data-user-id="<%= msg.user_id %>">
            <div class="message-avatar <%= isOwn ? 'order-2 bg-emerald-700' : 'bg-emerald-600' %> flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-xs font-semibold text-white" title="<%= msg.name %>">
              <%= msg.name.charAt(0).toUpperCase() %>
            </div>
            <div class="message-content <%= isOwn ? 'items-end text-right' : 'items-start text-left' %> flex max-w-[84%] min-w-0 flex-col sm:max-w-[70%]">
              <div class="message-sender mb-0.5 text-xs font-semibold text-slate-600">
                <%= isOwn ? 'Voce' : msg.name %>
              </div>
              <div class="message-bubble <%= isOwn ? 'bg-emerald-700 text-white border border-emerald-800' : 'bg-emerald-100 text-emerald-900 border border-emerald-200' %> rounded-2xl px-3 py-2 text-sm leading-relaxed break-words">
                <% if (msg.type === 'text') { %>
                  <%= msg.content %>
                <% } else if (msg.type === 'image') { %>
                  <img src="<%= msg.file_url %>" alt="Imagem" class="message-attachment max-w-full rounded-lg sm:max-w-[300px]">
                <% } else if (msg.type === 'video') { %>
                  <video controls class="message-attachment max-w-full rounded-lg sm:max-w-[300px]" src="<%= msg.file_url %>"></video>
                <% } else if (msg.type === 'audio') { %>
                  <audio controls preload="metadata" class="message-attachment block w-[240px] max-w-full sm:w-[300px]" src="<%= msg.file_url %>">
                    Seu navegador não suporta áudio embutido.
                  </audio>
                <% } else { %>
                  <a href="<%= msg.file_url %>" download class="text-emerald-700 underline">Arquivo: <%= msg.file_type %></a>
                <% } %>
              </div>
              <div class="message-time mt-1 text-[11px] text-slate-400">
                <%= new Date(msg.created_at).toLocaleTimeString('pt-BR', {hour: '2-digit', minute:'2-digit'}) %>
              </div>
              <% if (msg.is_read) { %>
                <div class="message-read mt-0.5 text-[11px] text-emerald-600">Lido</div>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>

      <div class="border-t border-slate-200 bg-white px-3 py-3 sm:px-4" style="padding-bottom: calc(0.75rem + env(safe-area-inset-bottom));">
        <div class="flex min-w-0 items-end gap-2">
          <div class="relative">
            <button class="flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-600 text-lg text-white transition hover:bg-emerald-700" id="fileBtn" onclick="toggleFileTypeDropdown()" title="Selecionar tipo de arquivo" type="button">
              +
            </button>
            <div class="absolute bottom-12 left-0 z-20 hidden min-w-40 overflow-hidden rounded-xl border border-slate-200 bg-white shadow-lg" id="fileTypeDropdown">
              <button class="block w-full px-4 py-2 text-left text-sm text-slate-700 transition hover:bg-slate-100" onclick="setFileType('image'); document.getElementById('fileInput').click();" type="button">Foto</button>
              <button class="block w-full px-4 py-2 text-left text-sm text-slate-700 transition hover:bg-slate-100" onclick="setFileType('video'); document.getElementById('fileInput').click();" type="button">Video</button>
              <button class="block w-full px-4 py-2 text-left text-sm text-slate-700 transition hover:bg-slate-100" onclick="setFileType('audio'); document.getElementById('fileInput').click();" type="button">Audio</button>
              <button class="block w-full px-4 py-2 text-left text-sm text-slate-700 transition hover:bg-slate-100" onclick="setFileType('document'); document.getElementById('fileInput').click();" type="button">Documento</button>
            </div>
            <input type="file" id="fileInput" class="hidden" onchange="sendFile(this)">
          </div>

          <textarea class="message-input min-h-11 max-h-28 w-full resize-none rounded-xl border border-slate-300 px-3 py-2 text-sm text-slate-700 outline-none ring-0 placeholder:text-slate-400 focus:border-emerald-500 focus:shadow-[0_0_0_3px_rgba(16,185,129,0.15)]" id="messageInput" placeholder="Digite sua mensagem..." onkeypress="handleKeyPress(event)" onkeyup="updateActionButton()" onkeydown="setTypingStatus(true)"></textarea>

          <button class="hidden h-10 w-10 items-center justify-center rounded-lg bg-emerald-600 text-white transition hover:bg-emerald-700" id="sendBtn" onclick="sendMessage()" title="Enviar mensagem" type="button">
            >
          </button>
          <button class="flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-600 text-white transition hover:bg-emerald-700" id="micBtn" title="Mensagem de voz" type="button">
            Mic
          </button>
        </div>
      </div>
    </div>
  </div>

  <script>
    const roomId = '<%= room.id %>';
    const userId = '<%= user.id %>';
    const userName = '<%= user.name %>';
    let selectedFileType = null;
    let mediaRecorder = null;
    let audioChunks = [];
    let isRecording = false;
    let typingTimeout = null;
    let typingIsActive = false;
    let chatEventSource = null;
    let reconnectTimeout = null;
    const renderedMessageIds = new Set();

    document.addEventListener('DOMContentLoaded', () => {
      initRenderedMessageIds();
      updateActionButton();
      setupMicrophoneButton();
    });

    function initRenderedMessageIds() {
      document.querySelectorAll('.message[data-id]').forEach((el) => {
        const id = el.getAttribute('data-id');
        if (id) renderedMessageIds.add(String(id));
      });
    }

    function setupMicrophoneButton() {
      const micBtn = document.getElementById('micBtn');
      micBtn.addEventListener('click', toggleAudioRecording);
    }

    async function toggleAudioRecording() {
      if (!isRecording) {
        try {
          const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
          mediaRecorder = new MediaRecorder(stream);
          audioChunks = [];

          mediaRecorder.ondataavailable = (event) => {
            audioChunks.push(event.data);
          };

          mediaRecorder.onstop = () => {
            const audioBlob = new Blob(audioChunks, { type: 'audio/webm' });
            sendAudio(audioBlob);
            stream.getTracks().forEach(track => track.stop());
          };

          mediaRecorder.start();
          isRecording = true;
          showRecordingIndicator();
        } catch (error) {
          console.error('Erro ao acessar microfone:', error);
          alert('Nao foi possivel acessar o microfone');
        }
      } else {
        mediaRecorder.stop();
        isRecording = false;
        hideRecordingIndicator();
      }
    }

    function showRecordingIndicator() {
      const input = document.getElementById('messageInput');
      const indicator = document.createElement('div');
      indicator.className = 'recording-indicator flex items-center gap-2 rounded-xl border border-amber-300 bg-amber-50 px-3 py-2 text-sm text-amber-800';
      indicator.id = 'recordingIndicator';
      indicator.innerHTML = '<span class="inline-flex h-2.5 w-2.5 animate-pulse rounded-full bg-red-500"></span> Gravando audio...';
      input.parentElement.insertBefore(indicator, input);
      input.classList.add('hidden');
    }

    function hideRecordingIndicator() {
      const indicator = document.getElementById('recordingIndicator');
      const input = document.getElementById('messageInput');
      if (indicator) indicator.remove();
      input.classList.remove('hidden');
    }

    function sendAudio(audioBlob) {
      const formData = new FormData();
      formData.append('roomId', roomId);
      formData.append('file', audioBlob, 'audio.webm');
      formData.append('type', 'audio');

      fetch('/api/messages/send', {
        method: 'POST',
        body: formData
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          console.log('Audio enviado com sucesso');
        }
      })
      .catch(error => console.error('Erro ao enviar audio:', error));
    }

    function toggleFileTypeDropdown() {
      const dropdown = document.getElementById('fileTypeDropdown');
      dropdown.classList.toggle('hidden');
      document.addEventListener('click', closeDropdownOnClickOutside);
    }

    function closeDropdownOnClickOutside(e) {
      const dropdown = document.getElementById('fileTypeDropdown');
      const fileBtn = document.getElementById('fileBtn');

      if (!dropdown.contains(e.target) && !fileBtn.contains(e.target)) {
        dropdown.classList.add('hidden');
        document.removeEventListener('click', closeDropdownOnClickOutside);
      }
    }

    function setFileType(type) {
      selectedFileType = type;
      const fileInput = document.getElementById('fileInput');

      const acceptMap = {
        image: 'image/*',
        video: 'video/*',
        audio: 'audio/*',
        document: '.pdf,.doc,.docx,.txt,.xls,.xlsx,.ppt,.pptx,.zip'
      };

      fileInput.accept = acceptMap[type] || '*';
      document.getElementById('fileTypeDropdown').classList.add('hidden');
    }

    function updateActionButton() {
      const input = document.getElementById('messageInput');
      const sendBtn = document.getElementById('sendBtn');
      const micBtn = document.getElementById('micBtn');
      const hasText = input.value.trim().length > 0;

      if (hasText) {
        sendBtn.classList.remove('hidden');
        sendBtn.classList.add('flex');
        micBtn.classList.add('hidden');
        micBtn.classList.remove('flex');
      } else {
        sendBtn.classList.add('hidden');
        sendBtn.classList.remove('flex');
        micBtn.classList.remove('hidden');
        micBtn.classList.add('flex');
      }
    }

    function normalizeMessage(message) {
      if (!message) return null;
      return {
        ...message,
        id: message.id,
        user_id: message.user_id ?? message.userId,
        room_id: message.room_id ?? message.roomId,
        file_url: message.file_url ?? message.fileUrl ?? null,
        file_type: message.file_type ?? message.fileType ?? null,
        created_at: message.created_at ?? message.createdAt ?? new Date().toISOString()
      };
    }

    function connectSSE() {
      if (chatEventSource) {
        chatEventSource.close();
      }

      chatEventSource = new EventSource(`/api/messages/stream/${roomId}`);

      chatEventSource.onopen = () => {
        if (reconnectTimeout) {
          clearTimeout(reconnectTimeout);
          reconnectTimeout = null;
        }
      };

      chatEventSource.onmessage = (event) => {
        const data = JSON.parse(event.data);

        if (data.type === 'new_message') {
          addMessageToDOM(normalizeMessage(data.message));
          markAllAsRead();
        } else if (data.type === 'typing_status') {
          updateTypingStatus(data);
        } else if (data.type === 'message_deleted') {
          removeMessageFromDOM(data.messageId);
        }
      };

      chatEventSource.onerror = () => {
        if (chatEventSource) {
          chatEventSource.close();
          chatEventSource = null;
        }

        if (!reconnectTimeout) {
          reconnectTimeout = setTimeout(() => {
            reconnectTimeout = null;
            connectSSE();
          }, 3000);
        }
      };
    }

    function sendMessage() {
      const input = document.getElementById('messageInput');
      const content = input.value.trim();

      if (!content) return;

      const formData = new FormData();
      formData.append('roomId', roomId);
      formData.append('content', content);
      formData.append('type', 'text');

      fetch('/api/messages/send', {
        method: 'POST',
        body: formData
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          input.value = '';
          updateActionButton();
          setTypingStatus(false);
        }
      });
    }

    function sendFile(input) {
      const file = input.files[0];
      if (!file) return;

      const formData = new FormData();
      formData.append('roomId', roomId);
      formData.append('file', file);
      formData.append('type', selectedFileType || getFileType(file.type));

      fetch('/api/messages/send', {
        method: 'POST',
        body: formData
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          input.value = '';
          selectedFileType = null;
        }
      });
    }

    function getFileType(mimeType) {
      if (mimeType.startsWith('image/')) return 'image';
      if (mimeType.startsWith('video/')) return 'video';
      if (mimeType.startsWith('audio/')) return 'audio';
      return 'file';
    }

    function handleKeyPress(event) {
      if (event.key === 'Enter' && !event.shiftKey) {
        event.preventDefault();
        sendMessage();
      }
    }

    function getMessageBubbleClass(isOwn) {
      return `message-bubble rounded-2xl px-3 py-2 text-sm leading-relaxed break-words ${isOwn ? 'border border-emerald-800 bg-emerald-700 text-white' : 'border border-emerald-200 bg-emerald-100 text-emerald-900'}`;
    }

    function getMessageContentClass(isOwn) {
      return `message-content flex min-w-0 max-w-[84%] flex-col sm:max-w-[70%] ${isOwn ? 'items-end text-right' : 'items-start text-left'}`;
    }

    function getMessageAvatarClass(isOwn) {
      return `message-avatar flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-xs font-semibold text-white ${isOwn ? 'order-2 bg-emerald-700' : 'bg-emerald-600'}`;
    }

    function addMessageToDOM(message) {
      message = normalizeMessage(message);
      if (!message) return;

      if (message?.id && renderedMessageIds.has(String(message.id))) {
        return;
      }

      const area = document.getElementById('messagesArea');
      const isOwn = String(message.user_id) === String(userId);
      let contentHTML = '';

      if (message.type === 'text') {
        contentHTML = escapeHtml(message.content);
      } else if (message.type === 'image') {
        contentHTML = `<img src="${message.file_url}" alt="Imagem" class="max-w-full rounded-lg sm:max-w-[300px]">`;
      } else if (message.type === 'video') {
        contentHTML = `<video controls class="max-w-full rounded-lg sm:max-w-[300px]" src="${message.file_url}"></video>`;
      } else if (message.type === 'audio') {
        contentHTML = `<audio controls preload="metadata" class="block w-[240px] max-w-full sm:w-[300px]" src="${message.file_url}">Seu navegador não suporta áudio embutido.</audio>`;
      } else {
        contentHTML = `<a href="${message.file_url}" download class="text-emerald-700 underline">Arquivo: ${message.file_type || 'Documento'}</a>`;
      }

      const senderName = isOwn ? 'Voce' : (message.name || 'Usuario');
      const createdAt = message.created_at ? new Date(message.created_at) : new Date();
      const timeStr = createdAt.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });

      const msgHTML = `
        <div class="message message-enter ${isOwn ? 'own justify-end' : ''} mb-1 flex items-end gap-2 sm:gap-3" data-id="${message.id || ''}" data-user-id="${message.user_id}">
          <div class="${getMessageAvatarClass(isOwn)}" title="${escapeHtml(message.name || '')}">
            ${(message.name ? message.name.charAt(0).toUpperCase() : '?')}
          </div>
          <div class="${getMessageContentClass(isOwn)}">
            <div class="message-sender mb-0.5 text-xs font-semibold text-slate-600">${escapeHtml(senderName)}</div>
            <div class="${getMessageBubbleClass(isOwn)}">${contentHTML}</div>
            <div class="message-time mt-1 text-[11px] text-slate-400">${timeStr}</div>
          </div>
        </div>
      `;
      area.insertAdjacentHTML('beforeend', msgHTML);

      if (message?.id) {
        renderedMessageIds.add(String(message.id));
      }

      area.scrollTop = area.scrollHeight;
    }

    function removeMessageFromDOM(messageId) {
      const msg = document.querySelector(`[data-id="${messageId}"]`);
      if (msg) msg.remove();
    }

    function markAllAsRead() {
      // Implementar marcacao de leitura
    }

    function setTypingStatus(isTyping) {
      if (!isTyping) {
        if (!typingIsActive) return;
        typingIsActive = false;
        if (typingTimeout) clearTimeout(typingTimeout);
        fetch(`/api/messages/typing/${roomId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ isTyping: false })
        });
        return;
      }

      if (!typingIsActive) {
        typingIsActive = true;
        fetch(`/api/messages/typing/${roomId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ isTyping: true })
        });
      }

      if (typingTimeout) clearTimeout(typingTimeout);
      typingTimeout = setTimeout(() => {
        setTypingStatus(false);
      }, 1500);
    }

    function updateTypingStatus(data) {
      if (String(data.userId) === String(userId)) return;

      const container = document.getElementById('typingContainer');

      if (data.isTyping) {
        if (!container) {
          const area = document.getElementById('messagesArea');
          const typingDiv = document.createElement('div');
          typingDiv.id = 'typingContainer';
          typingDiv.className = 'mt-1 flex items-center gap-1 text-xs italic text-slate-500';
          typingDiv.innerHTML = `<strong class="not-italic text-slate-600">${escapeHtml(data.userName || 'Usuario')}</strong> digitando <span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span>`;
          area.appendChild(typingDiv);
          area.scrollTop = area.scrollHeight;
        }
      } else if (container) {
        container.remove();
      }
    }

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    window.addEventListener('beforeunload', () => {
      if (chatEventSource) {
        chatEventSource.close();
        chatEventSource = null;
      }
      if (reconnectTimeout) {
        clearTimeout(reconnectTimeout);
        reconnectTimeout = null;
      }
    });

    connectSSE();
    document.getElementById('messagesArea').scrollTop = document.getElementById('messagesArea').scrollHeight;
  </script>
</body>
</html>
