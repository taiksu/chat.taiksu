<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    :root {
      --tw-emerald-600: #10b981;
      --tw-emerald-700: #047857;
      --tw-emerald-800: #064e3b;
      --chat-bg: #e5ddd5;
      --bubble-sent: #dcf8c6;
      --bubble-received: #ffffff;
      --topbar-height: 4rem;
    }

    @keyframes slideIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes typing {
      0%, 60%, 100% { opacity: 0.3; transform: translateY(0); }
      30% { opacity: 1; transform: translateY(-6px); }
    }

    @keyframes twPulseMic {
      0% { box-shadow: 0 0 0 0 rgba(4, 120, 87, 0.4); }
      70% { box-shadow: 0 0 0 10px rgba(4, 120, 87, 0); }
      100% { box-shadow: 0 0 0 0 rgba(4, 120, 87, 0); }
    }

    .message-enter { animation: slideIn 0.2s cubic-bezier(0, 0, 0.2, 1) forwards; }

    .typing-dot {
      display: inline-block; width: 6px; height: 6px; border-radius: 9999px;
      background: currentColor; margin-right: 3px; animation: typing 1.4s infinite;
    }
    .typing-dot:nth-child(2) { animation-delay: 0.2s; }
    .typing-dot:nth-child(3) { animation-delay: 0.4s; }

    /* Avatar Stack */
    .tw-avatar-stack { display: flex; align-items: center; }
    .tw-avatar-item {
      width: 38px; height: 38px; border-radius: 50%; border: 2px solid var(--tw-emerald-700);
      background-color: #ddd; overflow: hidden; margin-left: -12px;
      position: relative; transition: transform 0.3s ease;
    }
    .tw-avatar-item:first-child { margin-left: 0; }
    .tw-avatar-item:hover { transform: translateY(-3px); z-index: 10; }
    .tw-avatar-item img { width: 100%; height: 100%; object-fit: cover; }
    .tw-avatar-more { 
      background: #262d31; color: white; display: flex; align-items: center; justify-content: center; 
      font-size: 11px; font-weight: bold; width: 38px; height: 38px; border-radius: 50%; 
      border: 2px solid var(--tw-emerald-700); margin-left: -12px; 
    }

    /* Floating Attach Menu */
    .tw-attach-menu {
      position: absolute; bottom: 85px; left: 24px; width: 52px;
      background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      display: flex; flex-direction: column; align-items: center; padding: 12px 0; gap: 14px;
      z-index: 60; border-radius: 26px; box-shadow: 0 8px 32px rgba(0,0,0,0.15);
      opacity: 0; transform: translateY(20px) scale(0.6); pointer-events: none;
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      border: 1px solid rgba(255,255,255,0.3);
    }
    .tw-attach-menu.open { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; }
    .tw-attach-item { 
      display: flex; flex-direction: column; align-items: center; cursor: pointer; 
      transition: transform 0.2s ease; border:0; background:transparent; padding:0;
    }
    .tw-attach-item:active { transform: scale(0.85); }
    .tw-attach-circle {
      width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
      color: white; box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .emoji-picker {
      position: absolute;
      bottom: 85px;
      left: 86px;
      width: min(520px, calc(100vw - 36px));
      max-height: 270px;
      overflow: hidden;
      border-radius: 16px;
      border: 1px solid rgba(16, 185, 129, 0.3);
      background: rgba(255, 255, 255, 0.98);
      box-shadow: 0 10px 32px rgba(0, 0, 0, 0.16);
      backdrop-filter: blur(8px);
      z-index: 60;
      display: none;
    }
    .emoji-picker.open { display: block; }
    .emoji-grid {
      max-height: 190px;
      overflow-y: auto;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(36px, 1fr));
      gap: 6px;
      padding: 10px;
    }
    .emoji-btn {
      height: 36px;
      border-radius: 10px;
      border: 1px solid transparent;
      background: transparent;
      font-size: 20px;
      line-height: 1;
      cursor: pointer;
      transition: background 0.2s ease;
    }
    .emoji-btn:hover { background: #ecfdf5; border-color: #bbf7d0; }

    /* Messages Area Background */
    .messages-area {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      background-image: url('https://user-images.githubusercontent.com/15075759/28719144-86dc0f70-73b1-11e7-911d-60d70fcded21.png');
      background-blend-mode: overlay; background-color: rgba(229, 221, 213, 0.85);
      scrollbar-width: thin; scrollbar-color: var(--tw-emerald-700) transparent;
      display: flex;
      flex-direction: column;
      overscroll-behavior: contain;
      -webkit-overflow-scrolling: touch;
      touch-action: pan-y;
    }

    .chat-shell {
      height: calc(100dvh - var(--topbar-height));
      max-height: calc(100dvh - var(--topbar-height));
      min-height: 0;
    }

    .messages-area::-webkit-scrollbar {
      width: 8px;
    }
    .messages-area::-webkit-scrollbar-track {
      background: transparent;
    }
    .messages-area::-webkit-scrollbar-thumb {
      background: var(--tw-emerald-700);
      border-radius: 4px;
    }

    /* Message Bubbles */
    .message-bubble { 
      box-shadow: 0 1px 0.5px rgba(0,0,0,0.13); 
      transition: border-radius 0.2s ease; 
    }
    .message.own .message-bubble { 
      background-color: var(--bubble-sent); 
      border-color: transparent !important; 
      color: #111 !important; 
      border-bottom-right-radius: 4px; 
    }
    .message:not(.own) .message-bubble { 
      background-color: var(--bubble-received); 
      border-color: transparent !important; 
      color: #111 !important; 
      border-bottom-left-radius: 4px; 
    }

    .message.grouped.own .message-bubble { border-top-right-radius: 4px; }
    .message.grouped:not(.own) .message-bubble { border-top-left-radius: 4px; }

    /* Audio Player Refined */
    .tw-audio-player { background: rgba(0,0,0,0.06); border-radius: 12px; display: flex; align-items: center; gap: 10px; min-width: 220px; padding: 8px 12px; }
    .message.own .tw-audio-player { background: rgba(0,0,0,0.04); }
    .tw-audio-toggle { width: 36px; height: 36px; border-radius: 50%; border: 0; background: var(--tw-emerald-700); color: white; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: transform 0.2s; }
    .tw-audio-toggle:active { transform: scale(0.9); }
    .tw-audio-main { flex: 1; display: flex; flex-direction: column; gap: 2px; }
    .tw-audio-wave { height: 18px; display: flex; align-items: center; gap: 2px; }
    .tw-audio-bar { width: 3px; background: rgba(0,0,0,0.1); border-radius: 2px; }
    .message.own .tw-audio-bar { background: rgba(0,0,0,0.08); }
    .tw-audio-time { font-size: 11px; font-weight: 700; color: #666; }

    .pulse-mic { animation: twPulseMic 1.5s infinite; }

    @media (max-width: 480px) {
      .message-content { max-width: 88% !important; }
    }
  </style>
</head>
<body class="h-dvh overflow-hidden text-green-900">
  <div id="sidebarOverlay" class="fixed inset-0 z-20 bg-black/30 opacity-0 pointer-events-none transition"></div>
  <%- include('../partials/sidebar', { user, active: 'rooms' }) %>
  <div class="flex h-dvh flex-col">
    <%- include('../partials/topbar', {
      user,
      pageTitle: 'Sala de Chat'
    }) %>

  <% 
    const includeAudioPlayer = (url) => { 
      return `
        <div class="tw-audio-player" data-audio-url="${url}">
          <button type="button" class="tw-audio-toggle">
             <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          </button>
          <div class="tw-audio-main">
             <div class="tw-audio-wave">
                ${Array(24).fill(0).map(() => `<span class="tw-audio-bar" style="height: ${20 + Math.random() * 60}%"></span>`).join('')}
             </div>
             <span class="tw-audio-time">00:00</span>
          </div>
          <audio preload="metadata" class="native-audio hidden" src="${url}"></audio>
        </div>
      `;
    };
  %>
  <div class="chat-shell flex min-h-0 px-3 py-4 sm:px-6 lg:px-10">
    <% const roomIsClosed = Boolean(initialRoomClosed); %>
    <div class="mx-auto flex h-full min-h-0 w-full max-w-6xl flex-col overflow-hidden rounded-3xl bg-white/85 shadow-2xl ring-1 ring-emerald-100 backdrop-blur">
      <div class="px-5 pt-4">
        <%- include('../components/breadcrumb/index', {
          link: '/chat/rooms',
          paginaAnterior: 'Salas de Chat',
          paginaAtual: 'Sala de Chat'
        }) %>
      </div>
      <div id="roomHeaderHost"></div>

      <!-- Pills bar -->
      <div class="flex flex-wrap items-center gap-3 border-b border-emerald-50 bg-emerald-50 px-5 py-3 text-emerald-800">
        <span class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1 text-sm font-semibold shadow-sm">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="9"/></svg>
          Rolagem suave
        </span>
        <span class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1 text-sm font-semibold shadow-sm">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16v12H5.17L4 17.17z"/><path d="M8 9h8M8 13h5"/></svg>
          Widget-like
        </span>
        <div class="ml-auto flex flex-wrap items-center gap-2 text-xs">
          <button type="button" class="rounded-full border border-emerald-200 bg-white px-3 py-1 font-semibold text-emerald-700 transition hover:bg-emerald-100" onclick="markAllAsRead()">Marcar tudo como lido</button>
          <button type="button" class="rounded-full border border-emerald-200 bg-white px-3 py-1 font-semibold text-emerald-700 transition hover:bg-emerald-100" onclick="scrollMessagesToBottom(true)">Ir para o fim</button>
          <button type="button" class="rounded-full border border-emerald-200 bg-white px-3 py-1 font-semibold text-emerald-700 transition hover:bg-emerald-100" onclick="toggleAttachMenu()">Enviar mídia</button>
        </div>
      </div>

      <!-- Messages Area -->
      <div class="relative flex min-h-0 flex-1 flex-col overflow-hidden bg-[length:380px_380px] bg-[url('https://user-images.githubusercontent.com/15075759/28719144-86dc0f70-73b1-11e7-911d-60d70fcded21.png')]">
        <div class="messages-area flex min-h-0 flex-1 flex-col gap-1 overflow-y-auto scroll-smooth px-5 py-8 sm:px-8 md:px-10" id="messagesArea">
          <div id="loadingMessages" class="flex items-center justify-center py-6 text-gray-400">
            <svg class="h-8 w-8 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
            </svg>
          </div>
          <% let lastUser = null; %>
          <% messages.forEach((msg, idx) => { 
               const isOwn = String(msg.user_id) === String(user.id); 
               const isGrouped = lastUser === String(msg.user_id);
               lastUser = String(msg.user_id);
          %>
            <div class="message message-enter <%= isOwn ? 'own justify-end' : '' %> <%= isGrouped ? 'grouped' : 'mt-6' %> flex items-end gap-2" data-id="<%= msg.id %>" data-user-id="<%= msg.user_id %>">
              <% if (!isOwn && !isGrouped) { %>
                <div class="message-avatar flex h-8 w-8 shrink-0 items-center justify-center overflow-hidden rounded-full border-2 border-white bg-emerald-600 shadow-sm" title="<%= msg.name %>">
                  <% if (msg.avatar) { %>
                    <img src="<%= msg.avatar %>" alt="<%= msg.name %>" class="h-full w-full object-cover">
                  <% } else { %>
                    <span class="text-[10px] font-bold text-white"><%= msg.name.charAt(0).toUpperCase() %></span>
                  <% } %>
                </div>
              <% } else if (!isOwn) { %>
                <div class="w-8 shrink-0"></div> 
              <% } %>

              <div class="message-content flex min-w-0 max-w-[85%] flex-col sm:max-w-[72%] <%= isOwn ? 'items-end' : 'items-start' %>">
                <% if (!isGrouped) { %>
                  <div class="message-sender mb-0.5 px-1 text-[11px] font-bold text-emerald-800 uppercase tracking-tight">
                    <%= isOwn ? 'Você' : msg.name %>
                  </div>
                <% } %>
                
                <div class="message-bubble relative rounded-2xl px-3 py-2 text-[15px] leading-relaxed break-words shadow-sm">
                  <% if (msg.type === 'text') { %>
                    <%= msg.content %>
                  <% } else if (msg.type === 'image') { %>
                    <div class="mt-1 cursor-pointer overflow-hidden rounded-xl bg-black/5 p-1 shadow-sm" onclick="window.open('<%= msg.file_url %>', '_blank')">
                      <img src="<%= msg.file_url %>" alt="Imagem" class="max-w-full rounded-lg sm:max-w-[360px]">
                    </div>
                  <% } else if (msg.type === 'audio') { %>
                     <div class="tw-audio-player" data-audio-url="<%= msg.file_url %>">
                        <button type="button" class="tw-audio-toggle">
                           <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                        </button>
                        <div class="tw-audio-main">
                           <div class="tw-audio-wave">
                              <% for (let i = 0; i < 24; i++) { %>
                                 <span class="tw-audio-bar" style="height: <%= 20 + Math.random() * 60 %>%"></span>
                              <% } %>
                           </div>
                           <span class="tw-audio-time">00:00</span>
                        </div>
                        <audio preload="metadata" class="native-audio hidden" src="<%= msg.file_url %>"></audio>
                     </div>
                  <% } else { %>
                    <a href="<%= msg.file_url %>" download class="mt-1 flex items-center gap-3 rounded-xl bg-black/5 p-3 text-emerald-900 transition hover:bg-black/10">
                      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-white shadow-sm">
                         <svg class="h-6 w-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                      </div>
                      <div class="flex flex-col">
                         <span class="text-xs font-bold truncate max-w-[150px]"><%= msg.file_url.split('/').pop() %></span>
                         <span class="text-[10px] opacity-70 uppercase"><%= msg.file_type || 'Documento' %></span>
                      </div>
                    </a>
                  <% } %>
                </div>

                <div class="mt-1 flex items-center gap-1.5 px-1">
                  <span class="text-[10px] font-medium text-gray-500">
                    <%= new Date(msg.created_at).toLocaleTimeString('pt-BR', {hour: '2-digit', minute:'2-digit'}) %>
                  </span>
                  <% if (isOwn) { %>
                    <div class="message-read flex items-center <%= msg.is_read ? 'read text-sky-500' : 'text-gray-400' %>" data-read-for="<%= msg.id %>">
                      <svg width="15" height="14" viewBox="0 0 16 15" fill="none" class="check-sent"><path d="M1.5 8.5L4.5 11.5L14.5 1.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      <svg width="18" height="14" viewBox="0 0 19 15" fill="none" class="check-read hidden"><path d="M1.5 8.5L4.5 11.5L9.5 6.5M7.5 8.5L10.5 11.5L17.5 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
        <button id="scrollBottomBtn" class="pointer-events-auto invisible opacity-0 transition duration-200 ease-out absolute right-6 bottom-6 z-20 flex items-center gap-2 rounded-full bg-emerald-600 px-4 py-2 text-xs font-semibold text-white shadow-lg shadow-emerald-300/50 hover:bg-emerald-700">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
          Ir para o fim
        </button>
      </div>

      <div id="roomComposerHost"></div>
    </div>
  </div>

  <%- include('../partials/sidebar-script') %>
  <script src="/js/chat-template-core.js"></script>
  </div>

  <script>
    const templateCore = window.ChatTemplateCore || {};
    const escapeHtml = templateCore.escapeHtml || ((value) => {
      const div = document.createElement('div');
      div.textContent = String(value || '');
      return div.innerHTML;
    });
    const escapeAttr = templateCore.escapeAttr || ((value) => String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/"/g, '&quot;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;'));
    const formatTimePtBr = templateCore.formatTimePtBr || ((dateValue) => new Date(dateValue).toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' }));
    const insertTextAtCursor = templateCore.insertTextAtCursor || ((input, text) => {
      if (!input) return;
      const start = Number.isInteger(input.selectionStart) ? input.selectionStart : input.value.length;
      const end = Number.isInteger(input.selectionEnd) ? input.selectionEnd : input.value.length;
      input.value = `${input.value.slice(0, start)}${text}${input.value.slice(end)}`;
      const nextPos = start + String(text).length;
      input.selectionStart = nextPos;
      input.selectionEnd = nextPos;
      input.focus();
    });
    const roomId = '<%= room.id %>';
    const userId = '<%= user.id %>';
    const userName = '<%= user.name %>';
    const roomName = <%- JSON.stringify(String(room.name || '')) %>;
    const roomDescription = <%- JSON.stringify(String(room.description || 'Sala gerada pelo sistema')) %>;
    const roomIsClosed = <%= roomIsClosed ? 'true' : 'false' %>;
    const roomClosedReason = <%- JSON.stringify(String(roomClosedReason || 'Chat encerrado')) %>;
    const canManageRoom = <%= canManageRoom ? 'true' : 'false' %>;
    const roomParticipants = <%- JSON.stringify((participants || []).map((p) => ({ name: p.name, avatar: p.avatar, status: p.status }))) %>;
    const scrollBtn = document.getElementById('scrollBottomBtn');
    let selectedFileType = null;
    let mediaRecorder = null;
    let audioChunks = [];
    let isRecording = false;
    let typingTimeout = null;
    let typingIsActive = false;
    let chatEventSource = null;
    let reconnectTimeout = null;
    const renderedMessageIds = new Set();
    let currentAudioElement = null;
    let roomDeletedHandled = false;
    let stickToBottom = true;
    let recordingBusy = false;
    const emojiStorageKey = 'taiksu_recent_emojis_v1';
    const emojis = Array.isArray(templateCore.EMOJI_LIST) && templateCore.EMOJI_LIST.length
      ? templateCore.EMOJI_LIST
      : ["\u{1f44b}","\u{1f4ac}","\u{1f4e9}","\u{1f4e8}","\u{1f4de}","\u{1f4f1}","\u{1f4cc}","\u{1f4ce}","\u{1f5c2}\u{fe0f}","\u{1f4c1}","\u{1f4dd}","\u{1f9fe}","\u{1f4ca}","\u{1f4c8}","\u{1f4c9}","\u{1f4b0}","\u{1f4b3}","\u{1f3e6}","\u{1f9ee}","\u{1f4c5}","\u{1f5d3}\u{fe0f}","\u{23f0}","\u{1f50d}","\u{1f50e}","\u{2699}\u{fe0f}","\u{1f6e0}\u{fe0f}","\u{1f5a5}\u{fe0f}","\u{2328}\u{fe0f}","\u{1f5a8}\u{fe0f}","\u{1f310}","\u{1f517}","\u{1f512}","\u{1f510}","\u{1f6e1}\u{fe0f}","\u{1f511}","\u{26a0}\u{fe0f}","\u{1f6a8}","\u{2757}","\u{2753}","\u{2139}\u{fe0f}","\u{23f3}","\u{1f552}","\u{1f680}","\u{1f504}","\u{267b}\u{fe0f}","\u{1f4e4}","\u{1f4e5}","\u{1f4e6}","\u{1f3f7}\u{fe0f}","\u{1f4cb}","\u{1f4c4}","\u{1f4d1}","\u{1f91d}","\u{1f465}","\u{1f3e2}","\u{1f1e7}\u{1f1f7}","\u{1f64f}","\u{2705}","\u{2714}\u{fe0f}","\u{2611}\u{fe0f}","\u{274c}","\u{1f363}","\u{1f371}","\u{1f962}","\u{1f359}","\u{1f364}","\u{1f35c}","\u{1f35b}","\u{1f35a}","\u{1f358}","\u{1f365}","\u{1f991}","\u{1f41f}","\u{1f420}","\u{1f990}","\u{1f95f}","\u{1f362}","\u{1f361}","\u{1f375}","\u{1fad6}","\u{1f961}","\u{1f960}","\u{1f376}","\u{1f957}","\u{1f34b}","\u{1f336}\u{fe0f}","\u{1f9c2}","\u{1f525}","\u{1f468}\u{200d}\u{1f373}","\u{1f3ee}","\u{1f1ef}\u{1f1f5}"];
    scrollBtn?.addEventListener('click', () => scrollMessagesToBottom(true));
    let unreadCount = 0;
    let isWindowVisible = document.visibilityState === 'visible';
    let lastSenderId = null;

    document.addEventListener('DOMContentLoaded', () => {
      mountRoomHeader();
      mountRoomComposer();
      initRenderedMessageIds();
      hideLoadingMessages();
      updateActionButton();
      setupMicrophoneButton();
      initEmojiPicker();
      initAudioPlayers();
      bindMessageAreaScroll();
      scheduleInitialBottomSync();
      
      // Reconhecer último sender para grouping inicial
      const messages = document.querySelectorAll('.message[data-user-id]');
      if (messages.length) {
          lastSenderId = messages[messages.length - 1].getAttribute('data-user-id');
      }
    });

    function mountRoomHeader() {
      const host = document.getElementById('roomHeaderHost');
      if (!host) return;

      const backButtonHtml = `<a href="/chat/rooms" style="display:flex;height:40px;width:40px;align-items:center;justify-content:center;border-radius:9999px;background:rgba(255,255,255,.1);color:#fff;transition:background .2s" title="Voltar"><svg style="height:20px;width:20px" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg></a>`;
      const badgesHtml = `<span id="unreadBadge" class="hidden rounded-full bg-rose-500 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider">0</span>${roomIsClosed ? '<span class="rounded-full bg-amber-400/90 px-2 py-0.5 text-[10px] font-bold text-amber-950 uppercase tracking-wider">Encerrado</span>' : ''}`;
      const actionsHtml = canManageRoom
        ? `<div style="display:flex;align-items:center;gap:8px;border-left:1px solid rgba(255,255,255,.2);padding-left:16px"><button type="button" onclick="clearRoomMessages()" style="display:flex;height:36px;width:36px;align-items:center;justify-content:center;border-radius:9999px;background:rgba(255,255,255,.1);color:#fff;border:0;cursor:pointer" title="Limpar chat"><svg style="height:16px;width:16px" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg></button><button type="button" onclick="deleteRoom()" style="display:flex;height:36px;width:36px;align-items:center;justify-content:center;border-radius:9999px;background:rgba(244,63,94,.85);color:#fff;border:0;cursor:pointer" title="Excluir sala"><svg style="height:16px;width:16px" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg></button></div>`
        : '';

      if (typeof templateCore.renderConversationHeader === 'function') {
        host.innerHTML = templateCore.renderConversationHeader({
          title: roomName,
          subtitle: roomDescription,
          backButtonHtml,
          badgesHtml,
          participants: roomParticipants,
          actionsHtml,
          avatarLimit: 4,
          titleSize: 24
        });
        return;
      }

      host.innerHTML = '';
    }

    function mountRoomComposer() {
      const host = document.getElementById('roomComposerHost');
      if (!host) return;
      if (roomIsClosed) {
        host.innerHTML = `
          <div class="border-t border-gray-100 bg-white px-5 py-4">
            <div class="flex items-center gap-3 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-amber-900">
              <svg class="h-5 w-5 text-amber-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 118 0v4"/></svg>
              <div>
                <div class="text-sm font-bold uppercase tracking-wide">Chat encerrado</div>
                <div class="text-xs">${escapeHtml(roomClosedReason || 'Apenas leitura do historico')}</div>
              </div>
            </div>
          </div>
        `;
        return;
      }
      if (typeof templateCore.renderRoomComposer === 'function') {
        host.innerHTML = templateCore.renderRoomComposer({
          closed: roomIsClosed,
          placeholder: roomIsClosed ? 'Este chat esta fechado' : 'Digite uma mensagem...'
        });
        return;
      }

      const disabledAttr = roomIsClosed ? 'disabled' : '';
      const placeholder = roomIsClosed ? 'Este chat esta fechado' : 'Digite uma mensagem...';
      host.innerHTML = `
        <div class="relative border-t border-gray-100 bg-white px-4 py-4 sm:px-6" style="padding-bottom: calc(1rem + env(safe-area-inset-bottom));">
          <div class="tw-attach-menu" id="twAttachMenu"></div>
          <input type="file" id="fileInput" class="hidden" onchange="sendFile(this)">
          <div id="emojiPicker" class="emoji-picker">
            <div class="border-b border-green-100 px-3 py-2">
              <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Recentes</p>
              <div id="emojiRecent" class="emoji-grid max-h-[72px]"></div>
            </div>
            <div>
              <p class="px-3 pt-2 text-xs font-semibold uppercase tracking-wide text-gray-500">Todos</p>
              <div id="emojiAll" class="emoji-grid"></div>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <button class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-emerald-50 text-emerald-600 transition hover:bg-emerald-100 disabled:opacity-40" id="fileBtn" onclick="toggleAttachMenu()" title="Anexar" type="button" ${disabledAttr}></button>
            <button class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-emerald-50 text-emerald-600 transition hover:bg-emerald-100 disabled:opacity-40" id="emojiBtn" onclick="toggleEmojiPicker()" title="Emoji" type="button" ${disabledAttr}></button>
            <div class="group relative flex min-w-0 flex-1 items-center rounded-2xl bg-gray-100 px-3 transition-all focus-within:bg-gray-200/50 focus-within:ring-2 focus-within:ring-emerald-200">
              <textarea class="min-h-[48px] max-h-32 w-full resize-none bg-transparent py-3 text-[15.5px] text-gray-800 outline-none placeholder:text-gray-500 disabled:cursor-not-allowed" id="messageInput" placeholder="${placeholder}" onkeypress="handleKeyPress(event)" onkeyup="updateActionButton()" onkeydown="setTypingStatus(true)" ${disabledAttr}></textarea>
            </div>
            <button class="hidden h-12 w-12 shrink-0 items-center justify-center rounded-full bg-emerald-600 text-white shadow-lg transition hover:bg-emerald-700 disabled:opacity-40" id="sendBtn" onclick="sendMessage()" title="Enviar" type="button" ${disabledAttr}></button>
            <button class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-emerald-600 text-white shadow-lg transition hover:bg-emerald-700 disabled:opacity-40" id="micBtn" title="Gravar" type="button" ${disabledAttr}></button>
          </div>
        </div>
      `;
    }

    function getMessagesArea() {
      return document.getElementById('messagesArea');
    }

    function updateScrollButton() {
      const area = getMessagesArea();
      if (!area || !scrollBtn) return;
      const distance = area.scrollHeight - area.scrollTop - area.clientHeight;
      const show = distance > 120;
      scrollBtn.classList.toggle('invisible', !show);
      scrollBtn.classList.toggle('opacity-0', !show);
    }

    function isNearBottom(area, offset = 100) {
      return (area.scrollHeight - area.scrollTop - area.clientHeight) <= offset;
    }

    function forceScrollBottomFrames(area) {
      if (!area) return;
      const apply = () => { area.scrollTop = area.scrollHeight; };
      apply();
      requestAnimationFrame(() => {
        apply();
        requestAnimationFrame(() => {
          apply();
          updateScrollButton();
        });
      });
    }

    function scrollMessagesToBottom(force = false) {
      const area = getMessagesArea();
      if (!area) return;
      if (!force && !stickToBottom) return;
      if (force) {
        forceScrollBottomFrames(area);
      } else {
        area.scrollTo({ top: area.scrollHeight, behavior: 'smooth' });
      }
      stickToBottom = true;
      updateScrollButton();
    }

    function scheduleInitialBottomSync() {
      [0, 150, 500, 1200].forEach((ms) => {
        setTimeout(() => scrollMessagesToBottom(true), ms);
      });
    }

    function bindMessageAreaScroll() {
      const area = getMessagesArea();
      if (!area) return;
      area.addEventListener('scroll', () => {
        stickToBottom = isNearBottom(area);
        updateScrollButton();
      });
      updateScrollButton();
    }

    function initRenderedMessageIds() {
      document.querySelectorAll('.message[data-id]').forEach((el) => {
        const id = el.getAttribute('data-id');
        if (id) renderedMessageIds.add(String(id));
      });
    }

    function hideLoadingMessages() {
      const loading = document.getElementById('loadingMessages');
      if (loading) loading.remove();
    }

    function toggleAttachMenu() {
      const menu = document.getElementById('twAttachMenu');
      menu.classList.toggle('open');
      const btn = document.getElementById('fileBtn');
      btn.style.transform = menu.classList.contains('open') ? 'rotate(45deg)' : 'rotate(0deg)';
      btn.style.transition = 'transform 0.3s ease';
      
      if (menu.classList.contains('open')) {
          document.addEventListener('click', closeMenuOutside);
      }
    }

    function closeMenuOutside(e) {
        const menu = document.getElementById('twAttachMenu');
        const btn = document.getElementById('fileBtn');
        if (!menu.contains(e.target) && !btn.contains(e.target)) {
            menu.classList.remove('open');
            btn.style.transform = 'rotate(0deg)';
            document.removeEventListener('click', closeMenuOutside);
        }
    }

    function loadRecentEmojis() {
      if (typeof templateCore.loadRecentEmojis === 'function') {
        return templateCore.loadRecentEmojis(emojiStorageKey, emojis, 24);
      }
      try {
        const raw = localStorage.getItem(emojiStorageKey);
        const parsed = JSON.parse(raw || '[]');
        if (!Array.isArray(parsed)) return [];
        return parsed.filter((item) => emojis.includes(item)).slice(0, 24);
      } catch (_err) {
        return [];
      }
    }

    function saveRecentEmojis(list) {
      if (typeof templateCore.saveRecentEmojis === 'function') {
        templateCore.saveRecentEmojis(emojiStorageKey, list, 24);
        return;
      }
      localStorage.setItem(emojiStorageKey, JSON.stringify((list || []).slice(0, 24)));
    }

    function rememberEmoji(emoji) {
      if (typeof templateCore.rememberRecentEmoji === 'function') {
        templateCore.rememberRecentEmoji(emojiStorageKey, emoji, emojis, 24);
        return;
      }
      const current = loadRecentEmojis().filter((item) => item !== emoji);
      current.unshift(emoji);
      saveRecentEmojis(current);
    }

    function emojiButtonHtml(emoji) {
      return `<button type="button" class="emoji-btn" data-emoji="${emoji}" title="${emoji}">${emoji}</button>`;
    }

    function renderEmojiPicker() {
      const recentEl = document.getElementById('emojiRecent');
      const allEl = document.getElementById('emojiAll');
      if (!recentEl || !allEl) return;
      const recent = loadRecentEmojis();
      recentEl.innerHTML = (recent.length ? recent : emojis.slice(0, 12)).map(emojiButtonHtml).join('');
      allEl.innerHTML = emojis.map(emojiButtonHtml).join('');
    }

    function closeEmojiPicker() {
      const picker = document.getElementById('emojiPicker');
      if (picker) picker.classList.remove('open');
    }

    function toggleEmojiPicker() {
      const picker = document.getElementById('emojiPicker');
      if (!picker) return;
      renderEmojiPicker();
      picker.classList.toggle('open');
    }

    function insertEmoji(emoji) {
      const input = document.getElementById('messageInput');
      if (!input) return;
      insertTextAtCursor(input, emoji);
      updateActionButton();
      rememberEmoji(emoji);
      renderEmojiPicker();
      setTypingStatus(true);
    }

    function initEmojiPicker() {
      const picker = document.getElementById('emojiPicker');
      const emojiBtn = document.getElementById('emojiBtn');
      const input = document.getElementById('messageInput');
      if (!picker || !emojiBtn || !input) return;

      renderEmojiPicker();

      picker.addEventListener('click', (event) => {
        const target = event.target.closest('[data-emoji]');
        if (!target) return;
        insertEmoji(target.getAttribute('data-emoji'));
      });

      document.addEventListener('click', (event) => {
        if (!picker.classList.contains('open')) return;
        if (picker.contains(event.target) || emojiBtn.contains(event.target)) return;
        closeEmojiPicker();
      });

      input.addEventListener('focus', () => closeEmojiPicker());
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeEmojiPicker();
      });
    }

    function setUnreadCount(value) {
      const badge = document.getElementById('unreadBadge');
      unreadCount = Math.max(0, Number(value || 0));
      if (!badge) return;
      if (unreadCount <= 0) {
        badge.classList.add('hidden');
        badge.textContent = '0';
        return;
      }
      badge.classList.remove('hidden');
      badge.textContent = String(unreadCount > 99 ? '99+' : unreadCount);
    }

    function setupMicrophoneButton() {
      const micBtn = document.getElementById('micBtn');
      if (!micBtn || micBtn.dataset.bound === '1') return;
      micBtn.dataset.bound = '1';
      micBtn.addEventListener('click', toggleAudioRecording);
    }

    async function toggleAudioRecording() {
      if (recordingBusy) return;
      recordingBusy = true;
      if (!isRecording) {
        try {
          const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
          mediaRecorder = new MediaRecorder(stream);
          audioChunks = [];

          mediaRecorder.ondataavailable = (e) => audioChunks.push(e.data);
          mediaRecorder.onstop = () => {
            const blob = new Blob(audioChunks, { type: 'audio/webm' });
            if (blob.size > 0) sendAudio(blob);
            stream.getTracks().forEach(t => t.stop());
            finalizeRecordingState();
          };

          mediaRecorder.start();
          isRecording = true;
          setMicRecordingVisual(true);
          showRecordingIndicator();
          setTypingStatus(true, 'recording');
        } catch (err) {
          console.error('Microfone offline:', err);
          finalizeRecordingState();
          alert('Permissão de microfone negada ou indisponível.');
        } finally {
          recordingBusy = false;
        }
      } else {
        try {
          if (mediaRecorder && mediaRecorder.state !== 'inactive') mediaRecorder.stop();
          else finalizeRecordingState();
        } finally {
          recordingBusy = false;
        }
      }
    }

    function finalizeRecordingState() {
      isRecording = false;
      setMicRecordingVisual(false);
      hideRecordingIndicator();
      setTypingStatus(false, 'idle');
    }

    function setMicRecordingVisual(active) {
      const btn = document.getElementById('micBtn');
      if (!btn) return;
      if (active) {
        btn.classList.add('pulse-mic', 'bg-rose-600');
        btn.classList.remove('bg-emerald-600');
      } else {
        btn.classList.remove('pulse-mic', 'bg-rose-600');
        btn.classList.add('bg-emerald-600');
      }
    }

    function showRecordingIndicator() {
      const input = document.getElementById('messageInput');
      const parent = input.parentElement;
      const existing = parent.querySelector('[data-recording-indicator="1"]');
      if (existing) {
        input.classList.add('hidden');
        return;
      }
      const indicator = document.createElement('div');
      indicator.id = 'recordingIndicator';
      indicator.dataset.recordingIndicator = '1';
      indicator.className = 'flex flex-1 items-center gap-3 py-3 px-1 text-rose-600 font-bold text-sm';
      indicator.innerHTML = `<span class="h-3 w-3 rounded-full bg-rose-600 animate-pulse"></span> Gravando áudio...`;
      parent.appendChild(indicator);
      input.classList.add('hidden');
    }

    function hideRecordingIndicator() {
      const input = document.getElementById('messageInput');
      document.querySelectorAll('[data-recording-indicator="1"]').forEach((indicator) => indicator.remove());
      input.classList.remove('hidden');
    }

    function sendAudio(blob) {
      const fd = new FormData();
      fd.append('roomId', roomId);
      fd.append('file', blob, 'audio.webm');
      fd.append('type', 'audio');
      fetch('/api/messages/send', { method: 'POST', body: fd });
    }

    function setFileType(type) {
      selectedFileType = type;
      const input = document.getElementById('fileInput');
      input.accept = { image: 'image/*', video: 'video/*', document: '.pdf,.doc,.docx,.txt' }[type] || '*';
      document.getElementById('twAttachMenu').classList.remove('open');
      document.getElementById('fileBtn').style.transform = 'rotate(0deg)';
    }

    function updateActionButton() {
      const val = document.getElementById('messageInput').value.trim();
      const s = document.getElementById('sendBtn');
      const m = document.getElementById('micBtn');
      if (val.length > 0) { s.classList.remove('hidden'); m.classList.add('hidden'); }
      else { s.classList.add('hidden'); m.classList.remove('hidden'); }
    }

    function normalizeMessage(m) {
      if (!m) return null;
      return {
        ...m,
        id: m.id,
        user_id: m.user_id || m.userId,
        avatar: m.avatar || null,
        file_url: m.file_url || m.fileUrl || null,
        file_type: m.file_type || m.fileType || null,
        created_at: m.created_at || m.createdAt || new Date().toISOString()
      };
    }

    function connectSSE() {
      if (chatEventSource) chatEventSource.close();
      chatEventSource = new EventSource(`/api/messages/stream/${roomId}`);
      chatEventSource.onmessage = (e) => {
        const d = JSON.parse(e.data);
        if (d.type === 'new_message') {
           addMessageToDOM(d.message);
           markAllAsRead();
        } else if (d.type === 'messages_read') {
           applyReadReceipts(d.messageIds);
        } else if (d.type === 'typing_status') {
           updateTypingStatus(d);
        } else if (d.type === 'room_cleared') {
           document.getElementById('messagesArea').innerHTML = '';
           renderedMessageIds.clear();
           lastSenderId = null;
           scrollMessagesToBottom(true);
        } else if (d.type === 'room_deleted') {
           handleRoomDeleted();
        } else if (d.type === 'participant_removed') {
           handleParticipantRemoved(d.userId);
        }
      };
      chatEventSource.onerror = () => {
         chatEventSource.close();
         setTimeout(connectSSE, 3000);
      };
    }

    function addMessageToDOM(raw) {
      const msg = normalizeMessage(raw);
      if (!msg || renderedMessageIds.has(String(msg.id))) return;

      const area = getMessagesArea();
      if (!area) return;

      const isOwn = String(msg.user_id) === String(userId);
      const isGrouped = String(msg.user_id) === String(lastSenderId);
      lastSenderId = String(msg.user_id);

      const contentHTML = (typeof templateCore.renderMessageContent === 'function')
        ? templateCore.renderMessageContent({
            message: msg,
            resolveMediaUrl: (url) => url || '',
            audioRenderer: (url) => buildAudioPlayerHtml(url || ''),
            imageWrapperClass: 'cursor-pointer overflow-hidden rounded-xl bg-black/5 p-1 shadow-sm',
            imageClass: 'max-w-full rounded-lg sm:max-w-[320px]',
            imageOnClick: `window.open('${escapeAttr(msg.file_url || '')}','_blank')`,
            documentRenderer: (url, fileName, fileType) => `
              <a href="${escapeAttr(url)}" download class="mt-1 flex items-center gap-3 rounded-xl bg-black/5 p-3 text-emerald-900 transition hover:bg-black/10">
                <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-white shadow-sm">
                  <svg class="h-6 w-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                </div>
                <div class="flex flex-col">
                  <span class="text-xs font-bold truncate max-w-[150px]">${fileName}</span>
                  <span class="text-[10px] opacity-70 uppercase">${fileType}</span>
                </div>
              </a>
            `
          })
        : (msg.type === 'text'
            ? escapeHtml(msg.content)
            : (msg.type === 'audio'
                ? buildAudioPlayerHtml(msg.file_url || '')
                : (msg.type === 'image'
                    ? `<div class="cursor-pointer overflow-hidden rounded-xl bg-black/5 p-1 shadow-sm" onclick="window.open('${escapeAttr(msg.file_url || '')}','_blank')"><img src="${escapeAttr(msg.file_url || '')}" class="max-w-full rounded-lg sm:max-w-[320px]"></div>`
                    : `<a href="${escapeAttr(msg.file_url || '')}" download>${escapeHtml(msg.file_url || 'arquivo')}</a>`)));

      const avatarHTML = (!isOwn && !isGrouped)
        ? `<div class="message-avatar flex h-8 w-8 shrink-0 items-center justify-center overflow-hidden rounded-full border-2 border-white bg-emerald-600 shadow-sm" title="${escapeHtml(msg.name || '')}">${msg.avatar ? `<img src="${escapeAttr(msg.avatar)}" class="h-full w-full object-cover">` : `<span class="text-[10px] font-bold text-white">${escapeHtml((msg.name || 'U').charAt(0).toUpperCase())}</span>`}</div>`
        : (!isOwn ? '<div class="w-8 shrink-0"></div>' : '');

      const rowPayload = {
        own: isOwn,
        grouped: isGrouped,
        senderName: isOwn ? 'Você' : String(msg.name || ''),
        timeStr: formatTimePtBr(msg.created_at),
        readClass: Number(msg.is_read) === 1 ? 'read text-sky-500' : 'text-gray-400',
        bubbleHtml: contentHTML,
        avatarHtml: avatarHTML,
        messageId: String(msg.id || ''),
        userId: String(msg.user_id || ''),
        isRead: Number(msg.is_read) === 1
      };
      const rowHtml = (typeof templateCore.renderRoomMessageRow === 'function')
        ? templateCore.renderRoomMessageRow(rowPayload)
        : `
          <div class="message message-enter ${rowPayload.own ? 'own justify-end' : ''} ${rowPayload.grouped ? 'grouped' : 'mt-4'} flex items-end gap-2" data-id="${escapeAttr(rowPayload.messageId)}" data-user-id="${escapeAttr(rowPayload.userId)}">
            ${rowPayload.avatarHtml}
            <div class="message-content flex min-w-0 max-w-[85%] flex-col sm:max-w-[72%] ${rowPayload.own ? 'items-end' : 'items-start'}">
              ${rowPayload.grouped ? '' : `<div class="message-sender mb-0.5 px-1 text-[11px] font-bold text-emerald-800 uppercase tracking-tight">${escapeHtml(rowPayload.senderName)}</div>`}
              <div class="message-bubble relative rounded-2xl px-3 py-2 text-[15px] leading-relaxed break-words">${rowPayload.bubbleHtml}</div>
              <div class="mt-1 flex items-center gap-1.5 px-1">
                <span class="text-[10px] font-medium text-gray-500">${rowPayload.timeStr}</span>
                ${rowPayload.own ? `<div class="message-read flex items-center ${rowPayload.readClass}" data-read-for="${escapeAttr(rowPayload.messageId)}"><svg width="15" height="14" viewBox="0 0 16 15" fill="none" class="check-sent"><path d="M1.5 8.5L4.5 11.5L14.5 1.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg><svg width="18" height="14" viewBox="0 0 19 15" fill="none" class="check-read ${rowPayload.isRead ? '' : 'hidden'}"><path d="M1.5 8.5L4.5 11.5L9.5 6.5M7.5 8.5L10.5 11.5L17.5 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>` : ''}
              </div>
            </div>
          </div>
        `;

      area.insertAdjacentHTML('beforeend', rowHtml);
      renderedMessageIds.add(String(msg.id));
      if (shouldAutoScroll(area)) scrollMessagesToBottom(true);
      if (msg.type === 'audio') initAudioPlayers(area);
      updateScrollButton();
    }

    function shouldAutoScroll(area) {
        return stickToBottom || isNearBottom(area);
    }

    function buildAudioPlayerHtml(url) {
      let bars = '';
      for (let i = 0; i < 24; i++) bars += `<span class="tw-audio-bar" style="height:${20+Math.random()*60}%"></span>`;
      return `
        <div class="tw-audio-player" data-audio-url="${url}">
          <button type="button" class="tw-audio-toggle"><svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></button>
          <div class="tw-audio-main">
            <div class="tw-audio-wave">${bars}</div>
            <span class="tw-audio-time">00:00</span>
          </div>
          <audio preload="metadata" class="native-audio hidden" src="${url}"></audio>
        </div>
      `;
    }

    function initAudioPlayers(root = document) {
      root.querySelectorAll('.tw-audio-player:not([data-init])').forEach(p => {
        p.dataset.init = "1";
        const a = p.querySelector('audio');
        const b = p.querySelector('button');
        const t = p.querySelector('.tw-audio-time');
        b.onclick = () => {
          if (currentAudioElement && currentAudioElement !== a) currentAudioElement.pause();
          if (a.paused) { a.play(); currentAudioElement = a; }
          else a.pause();
        };
        a.onplay = () => { p.classList.add('playing'); b.innerHTML = '<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>'; };
        a.onpause = () => { p.classList.remove('playing'); b.innerHTML = '<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>'; };
        a.ontimeupdate = () => { t.textContent = formatTime(a.currentTime); };
        a.onloadedmetadata = () => { t.textContent = formatTime(a.duration); };
      });
    }

    function formatTime(s) {
      const m = Math.floor(s/60);
      const sec = Math.floor(s%60);
      return `${m}:${sec < 10 ? '0' : ''}${sec}`;
    }

    function sendMessage() {
      const i = document.getElementById('messageInput');
      const c = i.value.trim();
      if (!c) return;
      const fd = new FormData();
      fd.append('roomId', roomId);
      fd.append('content', c);
      fd.append('type', 'text');
      fetch('/api/messages/send', { method: 'POST', body: fd }).then(() => { i.value = ''; updateActionButton(); setTypingStatus(false); });
    }

    function sendFile(input) {
      if (!input.files.length) return;
      const fd = new FormData();
      fd.append('roomId', roomId);
      fd.append('file', input.files[0]);
      fd.append('type', selectedFileType || 'document');
      fetch('/api/messages/send', { method: 'POST', body: fd }).then(() => { input.value = ''; selectedFileType = null; });
    }

    function handleKeyPress(e) { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); } }

    function applyReadReceipts(ids) {
      ids.forEach(id => {
        const div = document.querySelector(`[data-read-for="${id}"]`);
        if (div) {
          div.classList.add('read', 'text-sky-500');
          div.classList.remove('text-gray-400');
          div.querySelector('.check-read').classList.remove('hidden');
          div.querySelector('.check-sent').classList.add('hidden');
        }
      });
    }

    function updateTypingStatus(d) {
      if (String(d.userId) === String(userId)) return;
      let c = document.getElementById('typingInfo');
      if (d.isTyping) {
        if (!c) {
          c = document.createElement('div');
          c.id = 'typingInfo';
          c.className = 'text-[10px] font-bold text-emerald-600 italic mt-1 px-10';
          getMessagesArea().appendChild(c);
        }
        const text = d.activity === 'recording' ? 'gravando áudio...' : 'digitando...';
        c.textContent = `${d.userName} está ${text}`;
        scrollMessagesToBottom();
      } else if (c) {
        c.remove();
      }
    }

    function setTypingStatus(is, act = 'typing') {
      if (!is) {
        if (!typingIsActive) return;
        typingIsActive = false;
        fetch(`/api/messages/typing/${roomId}`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ isTyping: false }) });
        return;
      }
      if (!typingIsActive) {
        typingIsActive = true;
        fetch(`/api/messages/typing/${roomId}`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ isTyping: true, activity: act }) });
      }
      if (typingTimeout) clearTimeout(typingTimeout);
      typingTimeout = setTimeout(() => setTypingStatus(false), 2000);
    }

    async function clearRoomMessages() {
      if (!canManageRoom || !confirm('Limpar mensagens?')) return;
      fetch(`/api/chat/rooms/${roomId}/messages`, { method: 'DELETE' });
    }

    async function deleteRoom() {
      if (!canManageRoom || !confirm('Excluir sala?')) return;
      fetch(`/api/chat/rooms/${roomId}`, { method: 'DELETE' }).then(() => window.location.href = '/chat/rooms');
    }

    function markAllAsRead() {
      setUnreadCount(0);
      fetch(`/api/messages/mark-read/${roomId}`, { method: 'POST' });
    }

    function handleRoomDeleted() { alert('Sala excluída'); window.location.href = '/chat/rooms'; }
    function handleParticipantRemoved(pid) { if (String(pid) === String(userId)) { alert('Removido'); window.location.href = '/rooms'; } else { document.querySelectorAll(`[data-participant-id="${pid}"]`).forEach(e => e.remove()); } }

    connectSSE();
  </script>
</body>
</html>
